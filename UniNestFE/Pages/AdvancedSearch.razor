@code {
    private bool isFilterModalOpen = false;
    private bool isLoading = true;

    // Filter Options Data
    private List<FilterItem> universitiesList = new();
    private List<FilterItem> propertyTypesList = new();
    private List<FilterItem> amenitiesList = new();
    private List<FilterItem> habitsList = new();

    // Active Selection State
    private string searchQuery = "";
    private int selectedUniversityId = 0;
    private double maxDistanceKm = 10;
    
    private decimal budgetMin = 0;
    private decimal budgetMax = 20000000;

    // UC-16 State
    private bool isAutoMatchActive = false;
    private bool isLoggedIn = true;
    private int currentUserId = 1; // Admin Demo ID
    
    // Using simple proxy properties to enforce spacing constraints on Dual Slider
    public decimal budgetMinProxy
    {
        get => budgetMin;
        set {
            if (value > budgetMax - 500000m) value = budgetMax - 500000m;
            budgetMin = value;
        }
    }
    
    public decimal budgetMaxProxy
    {
        get => budgetMax;
        set {
            if (value < budgetMin + 500000m) value = budgetMin + 500000m;
            budgetMax = value;
        }
    }

    private HashSet<int> selectedPropertyTypes = new();
    private HashSet<int> selectedAmenities = new();
    private HashSet<int> selectedHabits = new();

    // Results
    private List<ResultListing> results = new();

    // Pagination State
    private int currentPage = 1;
    private int pageSize = 9;
    
    private List<ResultListing> PagedResults => results.Skip((currentPage - 1) * pageSize).Take(pageSize).ToList();
    private int TotalPages => (int)Math.Ceiling(results.Count / (double)pageSize);

    // Card Dropdown State
    private int? openDropdownId = null;
    private HashSet<int> expandedAmenitiesCardIds = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadFilterOptions();
        await FetchResults(); 
    }

    private async Task LoadFilterOptions()
    {
        try
        {
            var url = "api/AdvancedSearch/filters";
            // Prepend base URL in real app if required, assuming Blazor automatically handles relative path or configured HttpClient
            var res = await Http.GetFromJsonAsync<JsonElement>(url); // Need to parse dynamic JSON mapping to simplify
            if (res.ValueKind != JsonValueKind.Undefined)
            {
                universitiesList = ParseItems(res, "universities", "uniId", "uniName");
                propertyTypesList = ParseItems(res, "propertyTypes", "propertyTypeId", "name");
                amenitiesList = ParseItems(res, "amenities", "amenityId", "name", "icon");
                habitsList = ParseItems(res, "lifestyleHabits", "lifestyleHabitId", "name");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading filters: " + ex.Message);
        }
    }

    private List<FilterItem> ParseItems(JsonElement root, string propName, string idName, string textName, string iconName = null)
    {
        var list = new List<FilterItem>();
        if (root.TryGetProperty(propName, out var array) && array.ValueKind == JsonValueKind.Array)
        {
            foreach (var item in array.EnumerateArray())
            {
                var f = new FilterItem
                {
                    Id = item.GetProperty(idName).GetInt32(),
                    Name = item.GetProperty(textName).GetString(),
                    Icon = iconName != null && item.TryGetProperty(iconName, out var ic) && ic.ValueKind != JsonValueKind.Null ? ic.GetString() : "check"
                };
                list.Add(f);
            }
        }
        return list;
    }

    private async Task FetchResults()
    {
        isLoading = true;
        currentPage = 1; // Reset to first page heavily on new search
        try
        {
            var pIds = string.Join(",", selectedPropertyTypes);
            var aIds = string.Join(",", selectedAmenities);
            var hIds = string.Join(",", selectedHabits);
            
            int sendUniId = selectedUniversityId;

            var qs = $"?universityId={sendUniId}&maxDistanceKm={maxDistanceKm}&minPrice={budgetMin}&maxPrice={budgetMax}" +
                     (string.IsNullOrEmpty(pIds) ? "" : $"&propertyTypeIds={pIds}") +
                     (string.IsNullOrEmpty(aIds) ? "" : $"&amenityIds={aIds}") +
                     (string.IsNullOrEmpty(hIds) ? "" : $"&habitIds={hIds}") +
                     (string.IsNullOrWhiteSpace(searchQuery) ? "" : $"&queryStr={Uri.EscapeDataString(searchQuery)}") +
                     (isAutoMatchActive && isLoggedIn ? $"&autoMatch=true&autoMatchUserId={currentUserId}" : "");

            var url = "api/AdvancedSearch" + qs;
            results = await Http.GetFromJsonAsync<List<ResultListing>>(url) ?? new List<ResultListing>();
        }
        catch(Exception e)
        {
            Console.WriteLine(e);
        }
        finally
        {
            isLoading = false;
        }
    }

    // Handlers
    private void NextPage() 
    {
        if (currentPage < TotalPages) currentPage++;
    }

    private void PrevPage() 
    {
        if (currentPage > 1) currentPage--;
    }

    private void GoToPage(int page) 
    {
        if (page >= 1 && page <= TotalPages) currentPage = page;
    }

    private async Task HandleSearchEnter(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await FetchResults();
        }
    }

    private async Task ToggleAutoMatch()
    {
        isAutoMatchActive = !isAutoMatchActive;
        if (isAutoMatchActive)
        {
            // Clear manual filters intuitively
            selectedPropertyTypes.Clear();
            selectedAmenities.Clear();
            selectedHabits.Clear();
        }
        await FetchResults();
    }

    private void OpenFilterModal() => isFilterModalOpen = true;
    private void CloseFilterModal() => isFilterModalOpen = false;

    private async Task ApplyFilters()
    {
        isFilterModalOpen = false;
        await FetchResults();
    }

    private void ClearAllFilters()
    {
        selectedUniversityId = 0;
        maxDistanceKm = 10;
        budgetMin = 0;
        budgetMax = 20000000;
        selectedPropertyTypes.Clear();
        selectedAmenities.Clear();
        selectedHabits.Clear();
        // Do NOT fetch results yet, wait for user to hit "Apply Filters"
    }

    private async Task ClearPropertyTypesAndApply()
    {
        selectedPropertyTypes.Clear();
        await FetchResults();
    }

    private async Task TogglePropertyTypeAndApply(int id)
    {
        TogglePropertyType(id);
        await FetchResults();
    }

    private void TogglePropertyType(int id)
    {
        if (selectedPropertyTypes.Contains(id)) selectedPropertyTypes.Remove(id);
        else selectedPropertyTypes.Add(id);
    }

    private void ToggleAmenity(int id)
    {
        if (selectedAmenities.Contains(id)) selectedAmenities.Remove(id);
        else selectedAmenities.Add(id);
    }

    private void ToggleHabit(int id)
    {
        if (selectedHabits.Contains(id)) selectedHabits.Remove(id);
        else selectedHabits.Add(id);
    }

    private void ToggleSchoolDropdown(int listingId)
    {
        openDropdownId = openDropdownId == listingId ? null : listingId;
    }

    private async Task SelectSchool(int listingId, int uniId)
    {
        openDropdownId = null;
        var listing = results.FirstOrDefault(r => r.ListingId == listingId);
        if (listing != null)
        {
            listing.CustomUniversityId = uniId;
            try 
            {
                var res = await Http.GetFromJsonAsync<JsonElement>($"api/AdvancedSearch/distance?listingId={listingId}&universityId={uniId}");
                if (res.TryGetProperty("distanceKm", out var dKm))
                {
                    listing.CustomDistanceKm = dKm.GetDouble();
                }
            } 
            catch { }
        }
    }

    private string GetAmenityIcon(string amenityName)
    {
        var match = amenitiesList.FirstOrDefault(a => a.Name.Contains(amenityName, StringComparison.OrdinalIgnoreCase));
        if (match != null && !string.IsNullOrEmpty(match.Icon)) return match.Icon;
        return "check";
    }

    public class FilterItem
    {
        public int Id { get; set; }
        public string Name { get; set; }
        public string Icon { get; set; }
    }

    public class ResultListing
    {
        public int ListingId { get; set; }
        public string Title { get; set; }
        public decimal Price { get; set; }
        public double AreaSquareMeters { get; set; }
        public string District { get; set; }
        public double DistanceKm { get; set; }
        public int? CustomUniversityId { get; set; }
        public double? CustomDistanceKm { get; set; }
        public int MatchPercent { get; set; }
        public string PrimaryImageUrl { get; set; }
        public List<string> Amenities { get; set; }
        public DateTime CreatedAt { get; set; }
    }
}
