@page "/create-listing"
@inject HttpClient Http
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IConfiguration Configuration

<div class="edit-listing-container">
    <div class="edit-listing-header">
        <div class="header-subtitle">
            <i class="material-icons">add_box</i> Create A Listing
        </div>
        <h1 class="header-title">Create Your Listing</h1>
        <p class="header-desc">List your space details to find the rerfect room mate in Da Nang.</p>
    </div>
    <!-- 1. General Information -->
    <div class="section-card">

        <div class="section-header">
            <div class="section-icon info">
                <i class="material-icons">info</i>
            </div>
            <h2>General Information</h2>
        </div>

        <div class="form-group-space">
            
            <div class="form-group">
                <label class="form-label">Listing Title <span class="text-red-500 text-lg" title="Information must be entered">*</span></label>
                <input type="text" @bind="listing.Title" class="form-input" placeholder="e.g. Modern Studio near Duy Tan University" />
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Monthly Rent (VND) <span class="text-red-500 text-lg" title="Information must be entered">*</span></label>
                    <div class="form-input-container">
                        <input type="number" @bind="listing.Price" class="form-input" placeholder="3,500,000" />
                        <span class="form-input-suffix">VND</span>
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Area (M²) <span class="text-red-500 text-lg" title="Information must be entered">*</span></label>
                    <div class="form-input-container" style="justify-content: flex-end;">
                        <input type="number" @bind="listing.AreaSquareMeters" class="form-input" placeholder="25" />
                        <span class="form-input-suffix">m²</span>
                    </div>
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Description </label>
                <textarea @bind="listing.Description" rows="4" class="form-textarea" placeholder="Describe the room, furniture, and surroundings..."></textarea>
            </div>

            <div class="form-group mb-4">
                <label class="form-label">
                    Property Type
                    <span class="text-red-500 text-lg" title="Information must be entered">*</span>
                </label>
                <div class="property-type-grid">
                    @foreach (var type in propertyTypes)
                    {
                        <div class="type-card @(listing.PropertyTypeId == type.PropertyTypeId ? "active" : "")" 
                             @onclick="() => listing.PropertyTypeId = type.PropertyTypeId">
                            <span class="type-name">@type.Name</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 3. Location -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-icon location">
                <i class="material-icons">location_on</i>
            </div>
            <h2>Location<span class="text-red-500 text-lg" title="Information must be entered">*</span></h2>
        </div>

        @if (!string.IsNullOrEmpty(locationErrorMessage))
        {
            <div class="error-msg" style="color: red; margin-bottom: 16px; background-color: #fee2e2; padding: 12px; border-radius: 8px;">
                <i class="material-icons" style="vertical-align: middle;">error</i> <strong>@locationErrorMessage</strong>
            </div>
        }

        <div class="form-row" style="margin-bottom: 24px;">
            <div class="form-group">
                <label class="form-label">District <span class="text-red-500 text-lg" title="Information must be entered">*</span></label>
                <div class="form-input-container">
                    <input type="text"
                           class="form-input"
                           @bind="listing.District" placeholder="Enter district..." title="District can be auto-filled or entered manually" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Address <span class="text-red-500 text-lg" title="Information must be entered">*</span></label>
                <div class="flex gap-2">
                    <input type="text" @bind="listing.Address"
                           @onkeyup='(e) => { if (e.Key == "Enter") SearchAddressOnMap(); }'
                           placeholder="Enter address or click map..." class="form-input flex-1" title="Specific address can be auto-filled or entered manually" />
                    <button type="button" class="bg-[#00BAF2] text-white px-4 rounded-xl hover:bg-[#05a0d3] transition-all active:scale-95 shadow-md flex items-center justify-center"
                            @onclick="SearchAddressOnMap" title="Update map from entered address">
                        <i class="material-icons">search</i>
                    </button>
                </div>
            </div>
        </div>

        <div class="flex justify-between items-center mb-4">
            <label class="form-label mb-0">Select on Map</label>
            @if (!showLargeMap)
            {
                <button type="button" @onclick="OpenLargeMap" disabled="@isMapLoading" class="text-[#00BAF2] hover:underline font-bold text-sm flex items-center gap-1">
                    <i class="material-icons-round text-lg">open_in_full</i>
                    @(isMapLoading ? "Connecting..." : "Expand Selection Map")
                </button>
            }
        </div>

        <div class="relative group">
            <!-- 🔥 MAP REAL -->
            <div id="map" style="height: 350px; border-radius: 12px; border: 1px solid #e2e8f0;"></div>

            @if (!showLargeMap)
            {
                <div class="absolute inset-0 z-[401] bg-black/5 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center pointer-events-none rounded-xl">
                    <button type="button" class="bg-white text-slate-800 font-extrabold px-6 py-2.5 rounded-full shadow-2xl pointer-events-auto transform transition-transform active:scale-95" @onclick="OpenLargeMap">
                        Show Large Map
                    </button>
                </div>
            }
        </div>

    </div>


    <!-- Portalled Modal to end of file -->
    <!-- 3. Amenities -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-icon amenities">
                <i class="material-icons">grid_view</i>
            </div>
            <h2>Amenities</h2>
        </div>

        <div class="amenities-grid">
            @foreach (var amenity in AvailableAmenities)
            {
                var isChecked = listing.AmenityIds.Contains(amenity.AmenityId);
                <label class="amenity-card @(isChecked ? "checked" : "")" @onclick="() => ToggleAmenity(amenity.AmenityId)">
                    <div class="checkbox-box"><i class="material-icons">check</i></div>
                    <i class="material-symbols-outlined amenity-icon">@amenity.Icon</i>
                    <span class="amenity-name">@amenity.Name</span>
                </label>
            }
        </div>
    </div>

    <!-- 4. Roommate Preferences -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-icon roommate">
                <i class="material-icons">group</i>
            </div>
            <h2>Roommate Preferences</h2>
        </div>

        <div class="form-row roommate-prefs">
            <div class="form-group">
                <label class="form-label">Preferred Gender</label>
                <div class="segmented-control">
                    <button type="button" class="segmented-btn @(listing.GenderPreference == "Any" ? "active" : "")" @onclick="@(() => listing.GenderPreference = "Any")">Any</button>
                    <button type="button" class="segmented-btn @(listing.GenderPreference == "Male" ? "active" : "")" @onclick="@(() => listing.GenderPreference = "Male")">Male</button>
                    <button type="button" class="segmented-btn @(listing.GenderPreference == "Female" ? "active" : "")" @onclick="@(() => listing.GenderPreference = "Female")">Female</button>
                </div>
            </div>
            <div class="form-group">
                <label class="form-label">Lifestyle Habits</label>
                <div class="habits-list">
                    @foreach (var habit in AvailableHabits)
                    {
                        var isChecked = listing.LifestyleHabitIds.Contains(habit.LifestyleHabitId);
                        <label class="habit-item @(isChecked ? "checked" : "")" @onclick="() => ToggleHabit(habit.LifestyleHabitId)">
                            <span class="habit-name">@habit.Name</span>
                            <div class="checkbox-box"><i class="material-icons">check</i></div>
                        </label>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- 5. Media Upload -->
    <div class="section-card">
        <div class="section-header">
            <div class="section-icon media">
                <i class="material-icons">image</i>
            </div>
            <h2>Media Upload</h2>
        </div>

        @if (!string.IsNullOrEmpty(uploadErrorMessage))
        {
            <div class="error-msg" style="color: red; margin-bottom: 16px;">
                <i class="material-icons" style="vertical-align: middle;">error</i> @uploadErrorMessage
            </div>
        }

        <div class="upload-zone" onclick="document.getElementById('fileInput').click()">
            <div class="upload-icon">
                <i class="material-icons">cloud_upload</i>
            </div>
            <h3 class="upload-title">Click to upload photos</h3>
            <p class="upload-desc">High-quality images get 5x more views. (Max 10 files)</p>
            <InputFile id="fileInput" OnChange="HandleFileSelected" multiple accept="image/*" style="display: none;" />
            <button type="button" class="btn-upload">Browse Files</button>
        </div>

        <div class="media-grid">
            @foreach (var preview in selectedImagePreviews)
            {
                <div class="media-item @(preview.IsPrimary ? "primary" : "")" style="background-image: url('@preview.Base64'); background-size: cover; background-position: center;">
                    @if (preview.IsPrimary)
                    {
                        <div class="primary-badge">Primary</div>
                    }
                    else
                    {
                        <button type="button" class="btn-set-primary" @onclick="() => SetPrimary(preview)" @onclick:stopPropagation="true" style="position: absolute; top: 8px; left: 8px; background: rgba(0,0,0,0.5); color: white; border: none; border-radius: 4px; padding: 4px 8px; font-size: 10px; cursor: pointer;">Set Primary</button>
                    }

                    <button type="button" class="btn-remove-img" @onclick="() => RemoveImage(preview)" @onclick:stopPropagation="true" style="position: absolute; top: 8px; right: 8px; background: rgba(255,0,0,0.7); color: white; border: none; border-radius: 50%; width: 24px; height: 24px; cursor: pointer; display: flex; align-items: center; justify-content: center;">
                        <i class="material-icons" style="font-size: 14px;">close</i>
                    </button>
                </div>
            }

            @if (selectedImagePreviews.Count < 10)
            {
                <div class="media-item add-new" onclick="document.getElementById('fileInput').click()">
                    <i class="material-icons">add</i>
                </div>
            }
        </div>
    </div>

    <!-- Footer Actions -->
    <div class="footer-actions flex justify-between items-center w-full">
        <button type="button" class="btn-prev" @onclick="Cancel">
            <i class="material-icons">arrow_back</i> Previous Section
        </button>
        <div class="footer-right flex gap-3">
            <button type="button" class="btn-cancel bg-slate-100 hover:bg-slate-200 dark:bg-[#1e293b] dark:hover:bg-[#334155] border-none text-slate-600 dark:text-slate-300 font-bold px-6 py-3 rounded-full shadow-sm flex items-center gap-2 transition-all active:scale-95" @onclick='() => SubmitListing("Draft")'>
                <i class="material-icons-round text-[18px]">save</i> Save as Draft
            </button>
            <button type="button" class="btn-save-main" @onclick='() => SubmitListing("Pending")'>
                Post Listing <i class="material-icons">check</i>
            </button>
        </div>
    </div>


    <!-- Large Map Modal for Selection (Placed at root to avoid stacking context issues) -->
    @if (showLargeMap)
    {
        <div class="fixed inset-0 z-[9999] bg-white flex flex-col animate-fade-in-up">
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-white shadow-sm z-10">
                <div>
                    <h2 class="text-xl font-extrabold text-slate-800">Select Location</h2>
                    <p class="text-xs text-slate-500 flex items-center gap-1 mt-0.5"><i class="material-icons-round text-sm text-[#00BAF2]">info</i> Click on the map to set the property location</p>
                </div>
                <button type="button" @onclick="CloseLargeMap" class="p-2 rounded-full hover:bg-slate-100 transition-colors">
                    <i class="material-icons-round text-3xl text-slate-400">close</i>
                </button>
            </div>
            <div class="flex-1 relative">
                <div id="largeSelectionMap" class="w-full h-full"></div>

                <div class="absolute bottom-6 left-6 right-6 z-[400] bg-white/95 backdrop-blur-md p-6 rounded-2xl shadow-2xl border border-white max-w-2xl mx-auto">
                    <div class="flex items-start gap-4 mb-4">
                        <div class="w-10 h-10 bg-[#00BAF2]/10 rounded-full flex items-center justify-center text-[#00BAF2] shrink-0">
                            <i class="material-icons-round text-xl">location_on</i>
                        </div>
                        <div class="flex-1">
                            <span class="block font-extrabold text-slate-800 text-sm">Selected Address</span>
                            <p class="text-sm text-slate-600 leading-snug">@(string.IsNullOrEmpty(listing.Address) ? "No location selected yet. Click on the map." : listing.Address)</p>
                        </div>
                    </div>
                    <div class="flex gap-3">
                        <button type="button" @onclick="CloseLargeMap"
                                class="flex-1 bg-[#00BAF2] text-white py-3 rounded-xl font-bold hover:bg-[#05a0d3] shadow-lg shadow-[#00BAF2]/20 transition-all active:scale-95">
                            Confirm Location
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
<link href="css/EditListing.css" rel="stylesheet" />

@code {
    CreateListingDto listing = new CreateListingDto();

    public class CreateListingDto
    {
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public decimal Price { get; set; }
        public double AreaSquareMeters { get; set; }
        public bool IsAvailable { get; set; } = true;
        public string GenderPreference { get; set; } = "Any";
        public string District { get; set; } = "";
        public string Address { get; set; } = "";
        public double Latitude { get; set; }
        public double Longitude { get; set; }
        public string ApprovalStatus { get; set; } = "Pending";
        public int? PropertyTypeId { get; set; }
        public List<int> AmenityIds { get; set; } = new List<int>();
        public List<int> LifestyleHabitIds { get; set; } = new List<int>();
    }

    public class AmenityItem { public int AmenityId { get; set; } public string Name { get; set; } public string Icon { get; set; } }
    List<AmenityItem> AvailableAmenities = new();

    public class HabitItem { public int LifestyleHabitId { get; set; } public string Name { get; set; } }

    public class PropertyType { public int PropertyTypeId { get; set; } public string Name { get; set; } }
    List<HabitItem> AvailableHabits = new();
    List<PropertyType> propertyTypes = new();

    void ToggleAmenity(int id)
    {
        if (listing.AmenityIds.Contains(id)) listing.AmenityIds.Remove(id);
        else listing.AmenityIds.Add(id);
    }

    void ToggleHabit(int id)
    {
        if (listing.LifestyleHabitIds.Contains(id)) listing.LifestyleHabitIds.Remove(id);
        else listing.LifestyleHabitIds.Add(id);
    }

    public class ImagePreview
    {
        public string Base64 { get; set; }
        public byte[] FileBytes { get; set; }
        public string FileName { get; set; }
        public string ContentType { get; set; }
        public bool IsPrimary { get; set; }
    }
    List<ImagePreview> selectedImagePreviews = new();
    string uploadErrorMessage = "";

    async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        uploadErrorMessage = "";
        var files = e.GetMultipleFiles(10);
        foreach (var file in files)
        {
            if (selectedImagePreviews.Count >= 10) break;

            try
            {
                // Store original file into memory immediately so Blazor doesn't lose the File ID later
                using var ms = new MemoryStream();
                await file.OpenReadStream(15 * 1024 * 1024).CopyToAsync(ms);
                var fileBytes = ms.ToArray();

                var resized = await file.RequestImageFileAsync("image/jpeg", 800, 800);
                using var stream = resized.OpenReadStream(10 * 1024 * 1024);
                var buffer = new byte[resized.Size];
                await stream.ReadAsync(buffer);
                string base64 = $"data:image/jpeg;base64,{Convert.ToBase64String(buffer)}";

                selectedImagePreviews.Add(new ImagePreview
                {
                    Base64 = base64,
                    FileBytes = fileBytes,
                    FileName = file.Name,
                    ContentType = file.ContentType,
                    IsPrimary = selectedImagePreviews.Count == 0 // First is primary
                });
            }
            catch (Exception ex)
            {
                Console.WriteLine("Error reading file: " + ex.Message);
            }
        }

        // Re-evaluate primary
        if (selectedImagePreviews.Count > 0 && !selectedImagePreviews.Any(p => p.IsPrimary))
        {
            selectedImagePreviews.First().IsPrimary = true;
        }
    }

    void RemoveImage(ImagePreview preview)
    {
        selectedImagePreviews.Remove(preview);
        if (preview.IsPrimary && selectedImagePreviews.Count > 0)
        {
            selectedImagePreviews.First().IsPrimary = true;
        }
    }

    void SetPrimary(ImagePreview preview)
    {
        foreach (var p in selectedImagePreviews) p.IsPrimary = false;
        preview.IsPrimary = true;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var res = await Http.GetFromJsonAsync<List<AmenityItem>>("https://localhost:7045/api/Amenities");
            if (res != null) AvailableAmenities = res;

            var habitsRes = await Http.GetFromJsonAsync<List<HabitItem>>("https://localhost:7045/api/LifestyleHabits");
            if (habitsRes != null) AvailableHabits = habitsRes;

            var typesRes = await Http.GetFromJsonAsync<List<PropertyType>>("api/PropertyTypes");
            if (typesRes != null) propertyTypes = typesRes;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    async Task SubmitListing(string status = "Pending")
    {
        listing.ApprovalStatus = status;

        if (status != "Draft")
        {
            if (string.IsNullOrWhiteSpace(listing.Title) ||
                listing.Price <= 0 ||
                listing.AreaSquareMeters <= 0 ||
                listing.PropertyTypeId == null || listing.PropertyTypeId == 0 ||
                string.IsNullOrWhiteSpace(listing.District) ||
                string.IsNullOrWhiteSpace(listing.Address))
            {
                uploadErrorMessage = "Information must be entered for all required fields (*).";
                return;
            }

            if (selectedImagePreviews.Count == 0)
            {
                uploadErrorMessage = "Information must be entered: You must upload at least one image before saving!";
                return;
            }
        }

        try
        {
            var response = await Http.PostAsJsonAsync(
                "https://localhost:7045/api/MyListings",
                listing
            );

            if (response.IsSuccessStatusCode)
            {
                var createdStr = await response.Content.ReadAsStringAsync();

                // Trích xuất ID từ JSON response nhỏ ( { "message": "...", "listingId": xxx } )
                // Cách lấy nhanh gọn nếu cấu trúc chuẩn là dùng JsonDocument
                using var doc = System.Text.Json.JsonDocument.Parse(createdStr);
                if (doc.RootElement.TryGetProperty("listingId", out var idElement))
                {
                    int newListingId = idElement.GetInt32();

                    // Nối bước upload ảnh
                    using var content = new MultipartFormDataContent();

                    var primaryImg = selectedImagePreviews.FirstOrDefault(p => p.IsPrimary);
                    if (primaryImg != null)
                    {
                        content.Add(new StringContent(primaryImg.FileName), "primaryFileName");
                    }

                    foreach (var p in selectedImagePreviews)
                    {
                        var streamContent = new ByteArrayContent(p.FileBytes);
                        streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(p.ContentType);
                        content.Add(streamContent, "files", p.FileName);
                    }

                    await Http.PostAsync($"https://localhost:7045/api/MyListings/{newListingId}/images", content);
                }

                Nav.NavigateTo("/mylistings");
            }
            else
            {
                var errorStr = await response.Content.ReadAsStringAsync();
                uploadErrorMessage = $"Create failed on server side: {response.StatusCode} - {errorStr}";
                Console.WriteLine($"Create failed: {response.StatusCode} - {errorStr}");
            }
        }
        catch (Exception ex)
        {
            uploadErrorMessage = "Exception occurred: " + ex.Message;
            Console.WriteLine(ex.Message);
        }
    }

    void Cancel()
    {
        Nav.NavigateTo("/mylistings");
    }

    DotNetObjectReference<CreateListing> objRef;
    bool showLargeMap = false;
    bool isMapLoading = false;
    bool mapInitialized = false;


    private async Task CloseLargeMap()
    {
        showLargeMap = false;
        StateHasChanged();
        // Re-init small map to reflect changes
        await Task.Delay(400);
        if (objRef == null) objRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("listingGoongMap.initMap", objRef, "map", listing.Latitude, listing.Longitude, 14);
        await DrawPois();
    }

    private async Task OpenLargeMap()
    {
        if (isMapLoading || showLargeMap) return;

        isMapLoading = true;
        showLargeMap = true;
        StateHasChanged();

        // Wait for modal to render element
        await Task.Delay(400);

        try
        {
            if (objRef == null) objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("listingGoongMap.initMap", objRef, "largeSelectionMap", listing.Latitude, listing.Longitude, 16);
            await DrawPois();
        }
        finally
        {
            isMapLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !mapInitialized)
        {
            mapInitialized = true;
            objRef = DotNetObjectReference.Create(this);

            // Load Keys right before init
            var mapKey = Configuration["GoongSettings:MapKey"];
            var apiKey = Configuration["GoongSettings:ApiKey"];
            await JS.InvokeVoidAsync("listingGoongMap.setKeys", mapKey, apiKey);

            await JS.InvokeVoidAsync("listingGoongMap.initMap", objRef, "map", 0, 0, 14); // 0, 0 means default marker for Da Nang
            await DrawPois();
        }
    }

    public class NominatimLocation { public string lat { get; set; } public string lon { get; set; } }

    async Task SearchAddressOnMap()
    {
        if (string.IsNullOrWhiteSpace(listing.Address))
        {
            uploadErrorMessage = "Please enter an address to search.";
            return;
        }

        try
        {
            locationErrorMessage = "";
            var addressText = listing.Address ?? "";
            var districtText = listing.District ?? "";

            var searchStr = addressText;
            if (!string.IsNullOrWhiteSpace(districtText) && !addressText.Contains(districtText, StringComparison.OrdinalIgnoreCase))
            {
                searchStr += $", {districtText}";
            }
            if (!addressText.Contains("Da Nang", StringComparison.OrdinalIgnoreCase) && !addressText.Contains("Đà Nẵng", StringComparison.OrdinalIgnoreCase))
            {
                searchStr += ", Da Nang, Vietnam";
            }

            var url = $"https://nominatim.openstreetmap.org/search?q={Uri.EscapeDataString(searchStr)}&format=json&limit=1&email=uninest.noreply@gmail.com";

            using var client = new HttpClient();
            var result = await client.GetFromJsonAsync<List<NominatimLocation>>(url);

            if (result == null || result.Count == 0)
            {
                var fallbackStr = districtText;
                if (!fallbackStr.Contains("Da Nang", StringComparison.OrdinalIgnoreCase) && !fallbackStr.Contains("Đà Nẵng", StringComparison.OrdinalIgnoreCase))
                {
                    fallbackStr += ", Da Nang, Vietnam";
                }

                var fallbackUrl = $"https://nominatim.openstreetmap.org/search?q={Uri.EscapeDataString(fallbackStr)}&format=json&limit=1&email=uninest.noreply@gmail.com";
                result = await client.GetFromJsonAsync<List<NominatimLocation>>(fallbackUrl);

                if (result != null && result.Count > 0)
                {
                    locationErrorMessage = "Không tìm thấy số nhà chính xác, bản đồ tạm hiển thị trung tâm khu vực. Bạn hãy nhấp chuột lên bản đồ để chọn lại vị trí đúng nhất nhé!";
                }
            }

            if (result != null && result.Count > 0)
            {
                var loc = result[0];
                listing.Latitude = double.Parse(loc.lat, System.Globalization.CultureInfo.InvariantCulture);
                listing.Longitude = double.Parse(loc.lon, System.Globalization.CultureInfo.InvariantCulture);

                await JS.InvokeVoidAsync("listingGoongMap.updateMarker", listing.Latitude, listing.Longitude, listing.Address);
                StateHasChanged();
            }
            else
            {
                locationErrorMessage = "Could not find location on map. Try adjusting your address text.";
            }
        }
        catch (Exception e)
        {
            Console.WriteLine(e);
            locationErrorMessage = "Error requesting location: Bạn đang bị chặn IP do nhấn quá nhanh. Vui lòng đợi 5 phút.";
        }
    }

    private bool isGeocoding = false;
    private string locationErrorMessage = "";

    [JSInvokable]
    public async Task OnMapClick(double lat, double lng)
    {
        if (isGeocoding) return;

        try
        {
            isGeocoding = true;
            locationErrorMessage = "";
            listing.Latitude = lat;
            listing.Longitude = lng;

            var latStr = lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lonStr = lng.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var url = $"https://nominatim.openstreetmap.org/reverse?lat={latStr}&lon={lonStr}&format=json&email=uninest.noreply@gmail.com";

            using var nominatimClient = new HttpClient();
            var result = await nominatimClient.GetFromJsonAsync<NominatimResponse>(url);

            if (result != null)
            {
                string rawAddress = result.display_name;
                listing.Address = rawAddress.Replace(" Ward", "").Trim();

                string rawDistrict = result.address?.city_district ?? result.address?.suburb ?? result.address?.city ?? "Unknown";
                listing.District = rawDistrict.Replace(" Ward", "").Trim();

                // Cập nhật marker trên GoongJS
                await JS.InvokeVoidAsync("listingGoongMap.updateMarker", lat, lng, listing.Address);

                StateHasChanged(); // refresh UI
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            locationErrorMessage = "Không thể tải địa chỉ! IP mạng của bạn đang bị chặn tạm thời vì thao tác quá nhanh. Xin vui lòng chờ 5 phút rồi thử lại!";
            StateHasChanged();
        }
        finally
        {
            isGeocoding = false;
        }
    }


