@page "/login"
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using UniNestFE.DTOs
@using System.Net.Http.Json

<PageTitle>Login | Da Nang Student Housing</PageTitle>

<div class="w-full min-h-screen overflow-y-auto custom-scrollbar flex flex-col items-center justify-center bg-[#fafaf9] dark:bg-[#121416] p-4 relative overflow-hidden font-sans">
    
    <!-- Background Decor (Subtle matching previous design) -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute top-20 -left-10 w-96 h-96 bg-primary/5 rounded-full blur-3xl opacity-60 mix-blend-screen pointer-events-none"></div>
        <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent-green/5 rounded-full blur-3xl opacity-60 mix-blend-screen pointer-events-none"></div>
    </div>

    <div class="w-full max-w-[420px] z-10 mt-10">
        
        <!-- Alerts (Rendered above card if assigned) -->
        <div class="flex flex-col gap-3 mb-6">
            @if (!string.IsNullOrEmpty(WarningMessage))
            {
                <div class="bg-[#fef8e8] border border-[#fde8b3] rounded-md px-4 py-3 flex items-start gap-2.5 shadow-sm animate-fade-in-up">
                    <span class="material-icons-round text-[#f4ba40] text-sm mt-0.5">warning</span>
                    <span class="text-xs text-[#a07412] leading-relaxed">@WarningMessage</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="bg-[#fdf2f2] border border-[#f9d7d7] rounded-md px-4 py-3 flex items-start gap-2.5 shadow-sm animate-fade-in-up">
                    <span class="material-icons-round text-[#e15959] text-sm mt-0.5">error_outline</span>
                    <span class="text-xs text-[#b33f3f] leading-relaxed">@ErrorMessage</span>
                </div>
            }
        </div>

        <!-- Login Card -->
        <div class="bg-white dark:bg-[#1c2126] rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-slate-100 dark:border-[#27353a] p-8 pb-10">
            
            <!-- Header -->
            <div class="text-center mb-6">
                <h1 class="text-[22px] font-bold text-slate-900 dark:text-white mb-2 tracking-tight">Welcome back</h1>
                <p class="text-slate-500 dark:text-slate-400 text-xs">Sign in to manage your accommodation.</p>
            </div>

            <!-- Form -->
            <EditForm Model="@item" OnValidSubmit="HandleLogin" class="space-y-4">
                <DataAnnotationsValidator />

                <!-- Email Address -->
                <div class="space-y-1.5 focus-within-group">
                    <label class="block text-[11px] font-semibold text-slate-700 dark:text-slate-300">Email Address</label>
                    <InputText @bind-Value="item.Email" class="w-full px-3.5 py-2.5 bg-white dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-lg focus:ring-[3px] focus:ring-primary/20 focus:border-primary outline-none transition-all text-slate-800 dark:text-white text-[13px] placeholder:text-slate-400" placeholder="e.g., student@university.vn" />
                    <ValidationMessage For="@(() => item.Email)" class="text-red-500 text-[10px] block" />
                </div>

                <!-- Password -->
                <div class="space-y-1.5 focus-within-group">
                    <div class="flex items-center justify-between">
                        <label class="block text-[11px] font-semibold text-slate-700 dark:text-slate-300">Password</label>
                        <a href="/forgot-password" tabindex="-1" class="text-[10px] font-medium text-primary hover:text-[#3ca4c5] transition-colors">Forgot Password?</a>
                    </div>
                    <div class="relative">
                        <InputText @bind-Value="item.Password" type="@(ShowPassword ? "text" : "password")" class="w-full pl-3.5 pr-10 py-2.5 bg-white dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-lg focus:ring-[3px] focus:ring-primary/20 focus:border-primary outline-none transition-all text-slate-800 dark:text-white text-[13px] placeholder:text-slate-400" placeholder="********" />
                        <button type="button" @onclick="TogglePasswordVisibility" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" tabindex="-1">
                            <span class="material-icons-round text-[16px]">@(ShowPassword ? "visibility_off" : "visibility")</span>
                        </button>
                    </div>
                    <ValidationMessage For="@(() => item.Password)" class="text-red-500 text-[10px] block" />
                </div>

                <!-- Remember Device -->
                <div class="flex items-center pt-1 pb-1">
                    <InputCheckbox @bind-Value="RememberDevice" id="rememberMe" class="w-3.5 h-3.5 text-primary bg-slate-50 border-slate-300 rounded focus:ring-primary focus:ring-2 cursor-pointer transition-all" />
                    <label for="rememberMe" class="ml-2 text-[11px] text-slate-500 dark:text-slate-400 cursor-pointer">
                        Remember this device
                    </label>
                </div>

                <!-- Login Button -->
                <button type="submit" disabled="@IsLoading" class="w-full mt-2 py-2.5 rounded-lg bg-[#4eb1d1] hover:bg-[#3ca4c5] dark:bg-primary dark:hover:bg-primary/90 text-white font-bold text-[13px] shadow-sm transition-all flex items-center justify-center gap-2">
                    @if (IsLoading)
                    {
                        <div class="w-3.5 h-3.5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                        <span>Logging in...</span>
                    }
                    else
                    {
                        <span>Login</span>
                    }
                </button>
            </EditForm>
            
            <!-- Divider -->
            <div class="relative flex items-center justify-center mt-7 mb-5">
                <div class="border-t border-slate-100 dark:border-slate-700/50 w-full absolute"></div>
                <span class="bg-white dark:bg-[#1c2126] px-3 z-10 text-[9px] uppercase font-extrabold tracking-widest text-slate-300 dark:text-slate-500">
                    OR LOGIN WITH
                </span>
            </div>

            <!-- Social Logins -->
            <div class="grid grid-cols-2 gap-3">
                <button type="button" class="flex items-center justify-center gap-2 w-full py-2 bg-white dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] hover:bg-slate-50 dark:hover:bg-[#32434a] rounded-lg transition-colors shadow-sm">
                    <svg class="w-3 h-3" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    <span class="text-[11px] font-semibold text-slate-600 dark:text-slate-300">Google</span>
                </button>
                <button type="button" class="flex items-center justify-center gap-2 w-full py-2 bg-white dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] hover:bg-slate-50 dark:hover:bg-[#32434a] rounded-lg transition-colors shadow-sm">
                    <span class="material-icons-round text-primary text-[14px]">school</span>
                    <span class="text-[11px] font-semibold text-slate-600 dark:text-slate-300">University SSO</span>
                </button>
            </div>
        </div>
        
        <!-- Registration Prompt outside the card -->
        <div class="mt-6 text-center">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium">
                Don't have an account? 
                <a href="/register" class="text-primary font-bold hover:underline">Apply for housing</a>
            </p>
        </div>
    </div>

    <!-- Page Bottom Footer -->
    <div class="absolute bottom-6 w-full text-center flex flex-col items-center gap-1.5 z-10">
        <p class="text-[9px] text-slate-400 font-medium">© 2024 Da Nang Student Housing Board. All rights reserved.</p>
        <div class="flex items-center justify-center gap-4 text-[9px] text-slate-400 font-medium">
            <a href="#" class="hover:underline hover:text-slate-500 transition-colors">Terms of Service</a>
            <a href="#" class="hover:underline hover:text-slate-500 transition-colors">Privacy Policy</a>
            <a href="#" class="hover:underline hover:text-slate-500 transition-colors">Support</a>
        </div>
    </div>

</div>

<style>
    .text-primary { color: #4eb1d1; }
    .bg-primary { background-color: #4eb1d1; }
    .bg-accent-green { background-color: #7CD933; }
    .animate-fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private LoginDto item = new();
    private string ErrorMessage = "";
    
    // WarningMessage is added to match your image design, easily hookable if needed
    // Setting this string will conditionally display the yellow box.
    private string WarningMessage = "Account locked due to multiple failed attempts."; 
    
    private bool IsLoading = false;
    private bool ShowPassword = false;
    private bool RememberDevice = false;

    // Remove or empty the warning message on init to simulate actual logic since usually not locked instantly
    protected override void OnInitialized()
    {
        // For demonstration purpose matching the screenshot exactly, I will keep both error and warning, 
        // but typically you should initialize them as empty.
        WarningMessage = ""; 
        ErrorMessage = "";
    }

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private async Task HandleLogin()
    {
        ErrorMessage = "";
        WarningMessage = "";
        IsLoading = true;
        
        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/login", item);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
                if (result != null)
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "userFullName", result.FullName);
                    NavManager.NavigateTo("/", forceLoad: true);
                }
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                
                // Simulate locking account logic
                if(content.Contains("locked"))
                {
                     WarningMessage = "Account locked due to multiple failed attempts.";
                }
                else
                {
                     ErrorMessage = "Invalid email or password. Please try again.";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred. Please try again.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }
}
