@page "/login"
@inject HttpClient Http
@inject NavigationManager NavManager
@inject IJSRuntime JSRuntime
@using UniNestFE.DTOs
@using System.Net.Http.Json

<PageTitle>Đăng nhập | UniNest</PageTitle>

<div class="w-full min-h-screen flex items-center justify-center bg-[#f0f4f8] dark:bg-slate-900 p-4 relative overflow-hidden font-body">
    <!-- Background Decor -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
        <div class="absolute top-20 -left-10 w-96 h-96 bg-[#004ac6]/5 rounded-full blur-3xl opacity-60 mix-blend-screen"></div>
        <div class="absolute bottom-10 right-10 w-80 h-80 bg-[#004ac6]/5 rounded-full blur-3xl opacity-60 mix-blend-screen"></div>
    </div>

    <div class="w-full max-w-[420px] bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 z-10 border border-slate-100 dark:border-slate-700 animate-fade-in-up">
        
        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-2xl font-bold text-[#171c1f] dark:text-white mb-2 tracking-tight">Chào mừng trở lại</h1>
            <p class="text-sm text-[#515f74] dark:text-slate-400">Đăng nhập để sử dụng các dịch vụ UniNest.</p>
        </div>

        <!-- Errors/Warnings -->
        <div class="flex flex-col gap-3 mb-6">
            @if (!string.IsNullOrEmpty(WarningMessage))
            {
                <div class="bg-amber-50 border border-amber-200 rounded-lg px-4 py-3 flex items-start gap-2.5 shadow-sm animate-fade-in-up">
                    <span class="material-symbols-outlined text-amber-500 text-sm mt-0.5">warning</span>
                    <span class="text-xs text-amber-700 leading-relaxed font-medium">@WarningMessage</span>
                </div>
            }
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 flex items-start gap-2.5 shadow-sm animate-fade-in-up">
                    <span class="material-symbols-outlined text-red-500 text-sm mt-0.5">error</span>
                    <span class="text-xs text-red-600 leading-relaxed font-medium">@ErrorMessage</span>
                </div>
            }
        </div>

        <!-- Form -->
        <EditForm Model="@item" OnValidSubmit="HandleLogin" class="space-y-5">
            <DataAnnotationsValidator />

            <!-- Email Address -->
            <div class="space-y-2">
                <label class="block text-[11px] font-bold uppercase text-[#515f74] dark:text-slate-400">Địa chỉ Email</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">mail</span>
                    <InputText @bind-Value="item.Email" class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-600 rounded-xl focus:ring-2 focus:ring-[#004ac6] outline-none transition-all text-sm text-[#171c1f] dark:text-white" placeholder="vd: user@gmail.com hoặc sv@duytan.edu.vn" />
                </div>
                <ValidationMessage For="@(() => item.Email)" class="text-red-500 text-xs mt-1 block" />
            </div>

            <!-- Password -->
            <div class="space-y-2">
                <div class="flex items-center justify-between">
                    <label class="block text-[11px] font-bold uppercase text-[#515f74] dark:text-slate-400">Mật khẩu</label>
                    <a href="/forgot-password" tabindex="-1" class="text-xs font-semibold text-[#004ac6] hover:underline">Quên mật khẩu?</a>
                </div>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                    <InputText @bind-Value="item.Password" type="@(ShowPassword ? "text" : "password")" class="w-full pl-10 pr-10 py-3 bg-slate-50 dark:bg-slate-700/50 border border-slate-200 dark:border-slate-600 rounded-xl focus:ring-2 focus:ring-[#004ac6] outline-none transition-all text-sm text-[#171c1f] dark:text-white" placeholder="••••••••" />
                    <button type="button" @onclick="TogglePasswordVisibility" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors" tabindex="-1">
                        <span class="material-symbols-outlined text-[18px]">@(ShowPassword ? "visibility_off" : "visibility")</span>
                    </button>
                </div>
                <ValidationMessage For="@(() => item.Password)" class="text-red-500 text-xs mt-1 block" />
            </div>

            <!-- Remember Device -->
            <div class="flex items-center pt-1 pb-1">
                <InputCheckbox @bind-Value="RememberDevice" id="rememberMe" class="w-4 h-4 text-[#004ac6] bg-slate-50 border-slate-300 rounded focus:ring-[#004ac6] cursor-pointer" />
                <label for="rememberMe" class="ml-2 text-xs font-semibold text-[#515f74] dark:text-slate-400 cursor-pointer">
                    Ghi nhớ thiết bị
                </label>
            </div>

            <!-- Login Button -->
            <button type="submit" disabled="@IsLoading" class="w-full py-3 rounded-xl bg-[#004ac6] hover:bg-blue-700 text-white font-bold text-sm shadow-md transition-all transform active:scale-95 flex items-center justify-center gap-2 mt-2 disabled:opacity-70">
                @if (IsLoading)
                {
                    <span class="material-symbols-outlined animate-spin text-sm">progress_activity</span>
                    <span>Đang đăng nhập...</span>
                }
                else
                {
                    <span>Đăng nhập</span>
                    <span class="material-symbols-outlined text-sm">login</span>
                }
            </button>
        </EditForm>
        
        <!-- Registration Prompt -->
        <div class="mt-6 text-center">
            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium">
                Chưa có tài khoản? 
                <a href="/register" class="text-[#004ac6] font-bold hover:underline">Đăng ký ngay</a>
            </p>
        </div>
    </div>

    <!-- Page Bottom Footer -->
    <div class="absolute bottom-6 w-full text-center flex flex-col items-center gap-1.5 z-10">
        <p class="text-[10px] text-slate-400 font-medium">© 2024 UniNest. All rights reserved.</p>
        <div class="flex items-center justify-center gap-4 text-[10px] text-slate-400 font-medium mt-1">
            <a href="/terms" class="hover:underline hover:text-slate-500 transition-colors">Điều khoản dịch vụ</a>
            <a href="/privacy" class="hover:underline hover:text-slate-500 transition-colors">Chính sách bảo mật</a>
        </div>
    </div>
</div>

<style>
    .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private LoginDto item = new();
    private string ErrorMessage = "";
    private string WarningMessage = ""; 
    
    private bool IsLoading = false;
    private bool ShowPassword = false;
    private bool RememberDevice = false;

    protected override void OnInitialized()
    {
        WarningMessage = ""; 
        ErrorMessage = "";
    }

    private void TogglePasswordVisibility()
    {
        ShowPassword = !ShowPassword;
    }

    private async Task HandleLogin()
    {
        ErrorMessage = "";
        WarningMessage = "";
        IsLoading = true;
        
        // Mock Admin Login
        if (item.Email == "admin@udn.vn" && item.Password == "123")
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", "admin-demo-token");
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", "userFullName", "Administrator");
            NavManager.NavigateTo("/admin/dashboard", forceLoad: true);
            IsLoading = false;
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/login", item);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<AuthResponseDto>();
                if (result != null)
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "userFullName", result.FullName);
                    NavManager.NavigateTo("/", forceLoad: true);
                }
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                
                if (content.Contains("locked"))
                {
                     WarningMessage = "Tài khoản tạm khóa do đăng nhập sai nhiều lần.";
                }
                else if (content.Contains("chờ quản trị viên xét duyệt") || content.Contains("chưa xác thực"))
                {
                     WarningMessage = "Tài khoản của bạn đang chờ hệ thống duyệt thẻ sinh viên. Vui lòng quay lại sau.";
                }
                else
                {
                     ErrorMessage = "Email hoặc mật khẩu không chính xác.";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "Đã xảy ra lỗi hệ thống. Vui lòng thử lại sau.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }
}
