@page "/reset-password"
@inject HttpClient Http
@inject NavigationManager NavManager
@using UniNestFE.DTOs
@using System.Net.Http.Json

<PageTitle>Reset Password | Da Nang Student Housing</PageTitle>

<div class="w-full min-h-screen overflow-y-auto custom-scrollbar flex items-center justify-center bg-[#fafaf9] dark:bg-[#121416] p-4 relative overflow-hidden">
    <!-- Background Decor (Matches Login/Forgot) -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-primary/20 rounded-full blur-3xl opacity-50 mix-blend-screen"></div>
        <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent-green/10 rounded-full blur-3xl opacity-50 mix-blend-screen"></div>
    </div>

    <!-- Main Card -->
    <div class="w-full max-w-[440px] bg-white dark:bg-[#1c2126] rounded-2xl shadow-2xl border border-slate-200 dark:border-[#27353a] relative z-10 animate-fade-in-up flex flex-col overflow-hidden">
        
        <div class="p-8 pb-6 text-center">
            <!-- Header -->
            <div class="mb-8">
                <h1 class="text-[22px] font-bold text-slate-900 dark:text-white mb-2 tracking-tight">Set New Password</h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed max-w-[280px] mx-auto">
                    Please create a strong password to secure your housing account.
                </p>
            </div>

            <!-- Error/Success Notification from backend -->
            @if (!string.IsNullOrEmpty(BackendErrorMessage))
            {
                <div class="mb-4 p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 text-left flex items-start gap-2">
                    <span class="material-icons-round text-red-500 text-sm mt-0.5">error_outline</span>
                    <span class="text-xs text-red-600">@BackendErrorMessage</span>
                </div>
            }

            @if (IsSuccess)
            {
                <div class="mb-4 p-4 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 text-center">
                    <span class="material-icons-round text-green-500 text-3xl mb-2">check_circle</span>
                    <h3 class="text-sm font-bold text-green-700 mb-1">Password Reset Successful</h3>
                    <p class="text-xs text-green-600 mb-3">You can now login using your new password.</p>
                    <a href="/login" class="inline-block px-6 py-2 bg-green-500 text-white rounded-lg text-sm font-bold shadow-sm hover:bg-green-600 transition-colors">Go to Login</a>
                </div>
            }

            <!-- Form -->
            @if (!IsSuccess)
            {
                <EditForm Model="@model" OnValidSubmit="HandleSubmit" class="space-y-5 text-left">
                    <DataAnnotationsValidator />

                    <!-- New Password -->
                    <div class="space-y-1">
                        <label class="text-xs font-bold text-slate-700 dark:text-slate-300">New Password</label>
                        <div class="relative group">
                            <InputText @bind-Value="model.NewPassword" @oninput="UpdatePasswordStrength" type="@(ShowNewPassword ? "text" : "password")" class="w-full px-4 py-3 bg-white dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-[#4eb1d1]/50 focus:border-[#4eb1d1] outline-none transition-all text-slate-800 dark:text-white text-sm" placeholder="********" />
                            <button type="button" @onclick="ToggleNewPassword" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none">
                                <span class="material-icons-round text-[18px]">@(ShowNewPassword ? "visibility_off" : "visibility")</span>
                            </button>
                        </div>
                        
                        <!-- Password Strength Visuals -->
                        @if (!string.IsNullOrEmpty(model.NewPassword))
                        {
                            <div class="pt-2">
                                <div class="flex items-center justify-between mb-1">
                                    <span class="text-[10px] font-bold text-slate-500 uppercase">PASSWORD STRENGTH</span>
                                    <span class="text-[10px] font-bold @GetStrengthColorText()">@GetStrengthLabel()</span>
                                </div>
                                <div class="flex gap-1 h-1.5 w-full">
                                    <div class="flex-1 rounded-full @GetStrengthClass(1)"></div>
                                    <div class="flex-1 rounded-full @GetStrengthClass(2)"></div>
                                    <div class="flex-1 rounded-full @GetStrengthClass(3)"></div>
                                </div>
                            </div>
                        }

                        <ValidationMessage For="@(() => model.NewPassword)" class="text-red-500 text-xs mt-1 block" />
                        <!-- Helper Text -->
                        <div class="flex items-center gap-1.5 mt-2">
                            <span class="material-icons-round text-slate-400 text-[12px]">info</span>
                            <span class="text-[11px] text-slate-500">At least 8 characters, 1 number, and 1 symbol</span>
                        </div>
                    </div>

                    <!-- Confirm Password -->
                    <div class="space-y-1 pt-1">
                        <label class="text-xs font-bold text-slate-700 dark:text-slate-300">Confirm New Password</label>
                        <div class="relative group">
                            <InputText @bind-Value="model.ConfirmNewPassword" type="@(ShowConfirmPassword ? "text" : "password")" class="w-full px-4 py-3 bg-white dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-[#4eb1d1]/50 focus:border-[#4eb1d1] outline-none transition-all text-slate-800 dark:text-white text-sm" placeholder="********" />
                            <button type="button" @onclick="ToggleConfirmPassword" class="absolute inset-y-0 right-0 pr-3 flex items-center text-slate-400 hover:text-slate-600 focus:outline-none">
                                <span class="material-icons-round text-[18px]">@(ShowConfirmPassword ? "visibility_off" : "visibility")</span>
                            </button>
                        </div>
                        <ValidationMessage For="@(() => model.ConfirmNewPassword)" class="text-red-500 text-[11px] mt-1 block" />
                    </div>

                    <!-- Submit Button -->
                    <button type="submit" disabled="@IsLoading" class="w-full mt-6 py-3.5 rounded-xl bg-[#4eb1d1] hover:bg-[#3ca4c5] text-white font-bold text-sm shadow-md transition-all transform active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                        @if (IsLoading)
                        {
                            <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                            <span>Resetting...</span>
                        }
                        else
                        {
                            <span>Reset Password</span>
                        }
                    </button>
                </EditForm>
                
                <div class="text-center mt-6">
                    <span class="text-[10px] text-slate-400">Reset Screen Variant 4 of 11</span>
                </div>
            }
        </div>
    </div>

    <!-- Bottom Footer (Outside Card) -->
    <div class="absolute bottom-6 w-full text-center flex flex-row items-center justify-center gap-6 z-10">
        <div class="flex items-center gap-1.5 text-slate-400">
            <span class="material-icons-round text-[13px]">shield</span>
            <span class="text-[10px] font-medium">Secure 256-bit Encryption</span>
        </div>
        <div class="flex items-center gap-1.5 text-slate-400">
            <span class="material-icons-round text-[13px]">location_on</span>
            <span class="text-[10px] font-medium">Da Nang, Vietnam</span>
        </div>
    </div>
</div>

<style>
    .text-primary { color: #06b5ef; }
    .bg-primary { background-color: #06b5ef; }
    .bg-accent-green { background-color: #7CD933; }
    .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(15px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Email { get; set; }

    [SupplyParameterFromQuery]
    public string? Token { get; set; }

    private ResetPasswordDto model = new();
    
    private bool ShowNewPassword = false;
    private bool ShowConfirmPassword = false;
    private bool IsLoading = false;
    private bool IsSuccess = false;
    private string BackendErrorMessage = "";
    private int PasswordStrengthScore = 0;

    protected override void OnInitialized()
    {
        model.Email = Email;
        model.Token = Token;
        
        if (string.IsNullOrEmpty(model.Email) || string.IsNullOrEmpty(model.Token))
        {
            BackendErrorMessage = "Invalid reset link. The link may be broken or expired.";
        }
    }

    private void ToggleNewPassword() => ShowNewPassword = !ShowNewPassword;
    private void ToggleConfirmPassword() => ShowConfirmPassword = !ShowConfirmPassword;

    private void UpdatePasswordStrength(ChangeEventArgs e)
    {
        string? pw = e.Value?.ToString();
        if (string.IsNullOrEmpty(pw))
        {
            PasswordStrengthScore = 0;
            return;
        }

        int score = 0;
        if (pw.Length >= 8) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pw, @"[A-Z]") && System.Text.RegularExpressions.Regex.IsMatch(pw, @"[a-z]")) score++;
        if (System.Text.RegularExpressions.Regex.IsMatch(pw, @"[0-9]") && System.Text.RegularExpressions.Regex.IsMatch(pw, @"[\W_]")) score++;

        PasswordStrengthScore = score;
    }

    private string GetStrengthClass(int barIndex)
    {
        if (PasswordStrengthScore >= barIndex)
        {
            if (PasswordStrengthScore == 1) return "bg-red-400";
            if (PasswordStrengthScore == 2) return "bg-amber-400";
            if (PasswordStrengthScore >= 3) return "bg-[#4eb1d1]";
        }
        return "bg-slate-200 dark:bg-slate-700";
    }

    private string GetStrengthLabel()
    {
        return PasswordStrengthScore switch
        {
            1 => "WEAK",
            2 => "MEDIUM",
            >= 3 => "STRONG",
            _ => "NONE"
        };
    }

    private string GetStrengthColorText()
    {
        return PasswordStrengthScore switch
        {
            1 => "text-red-500",
            2 => "text-amber-500",
            >= 3 => "text-[#4eb1d1]",
            _ => "text-slate-400"
        };
    }

    private async Task HandleSubmit()
    {
        if (string.IsNullOrEmpty(model.Email) || string.IsNullOrEmpty(model.Token))
        {
            BackendErrorMessage = "Cannot reset password. Missing token or email data.";
            return;
        }

        BackendErrorMessage = "";
        IsLoading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/reset-password", model);

            if (response.IsSuccessStatusCode)
            {
                IsSuccess = true;
            }
            else
            {
                var responseContent = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                BackendErrorMessage = responseContent?.message ?? "An error occurred while resetting your password.";
            }
        }
        catch (Exception)
        {
            BackendErrorMessage = "Network error or server is unavailable.";
        }
        finally
        {
            IsLoading = false;
        }
    }
    
    private class ErrorResponse
    {
        public string message { get; set; } = "";
    }
}
