@page "/admin/settings"
@layout Layout.AdminLayout
@inject HttpClient Http

<PageTitle>System Settings | UniNest Admin</PageTitle>

<div class="flex flex-col space-y-8 animate-fade-in-up">
    <!-- Header -->
    <div class="flex justify-between items-end">
        <div>
            <h2 class="text-3xl font-extrabold text-[#171c1f] dark:text-white tracking-tight">System Settings</h2>
            <p class="text-sm text-[#515f74] dark:text-slate-400 mt-2">Global configurations and organizational security protocols.</p>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        
        <!-- Left Column: Domains -->
        <div class="lg:col-span-2 space-y-6">
            <div class="bg-white dark:bg-slate-800 rounded-2xl p-8 shadow-sm border border-slate-100 dark:border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <div>
                        <h3 class="text-lg font-bold text-[#171c1f] dark:text-white">Authorized Academic Domains</h3>
                        <p class="text-xs text-[#515f74] dark:text-slate-400 mt-1">Whitelist for instant registration via institutional emails.</p>
                    </div>
                    <button @onclick="ToggleAddDomain" class="bg-slate-100 dark:bg-slate-700 hover:bg-slate-200 text-[#171c1f] dark:text-white px-4 py-2 rounded-lg text-xs font-bold transition flex items-center gap-2">
                        <span class="material-symbols-outlined text-sm">add</span> Add Domain
                    </button>
                </div>

                @if (IsAddingDomain)
                {
                    <div class="bg-blue-50/50 dark:bg-blue-900/10 p-6 rounded-xl border border-blue-100 dark:border-blue-800 mb-6 flex gap-4 animate-fade-in-up">
                        <div class="flex-grow space-y-1">
                            <label class="text-[10px] font-bold text-[#004ac6] uppercase tracking-widest">Enter Institutional Domain</label>
                            <div class="relative flex items-center">
                                <span class="absolute left-4 text-slate-400 font-bold">@@</span>
                                <input type="text" @bind="NewDomain" placeholder="e.g. vku.edu.vn" class="w-full pl-8 pr-4 py-3 bg-white dark:bg-slate-900 border-none rounded outline-none shadow-sm focus:ring-2 focus:ring-[#004ac6] text-sm" />
                            </div>
                            <p class="text-[9px] text-slate-500 mt-1 italic">If you enter a full email, we'll automatically extract the domain.</p>
                        </div>
                        <div class="flex items-end">
                            <button @onclick="AddDomain" class="bg-[#004ac6] hover:bg-blue-700 text-white px-6 py-3 rounded text-sm font-bold shadow-md transition-all">Save Domain</button>
                        </div>
                    </div>
                }

                <div class="space-y-4">
                    <p class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest border-b border-slate-100 dark:border-slate-700 pb-2">Active Whitelist (@domains.Count)</p>
                    
                    @foreach (var domain in domains)
                    {
                        <div class="flex items-center justify-between p-4 bg-slate-50 dark:bg-slate-700/50 rounded-xl border border-transparent hover:border-slate-200 transition-all group">
                            <div class="flex items-center gap-4">
                                <div class="w-10 h-10 rounded-full bg-blue-100 text-[#004ac6] flex items-center justify-center">
                                    <span class="material-symbols-outlined text-[20px]">account_balance</span>
                                </div>
                                <div>
                                    <h4 class="font-bold border-b-2 border-transparent text-[#171c1f] dark:text-white">@@@domain.DomainName</h4>
                                    <p class="text-[10px] text-[#515f74] dark:text-slate-400">@domain.Description</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-4">
                                <span class="px-3 py-1 bg-emerald-100 text-emerald-700 text-[10px] font-bold uppercase tracking-widest rounded-full">Active</span>
                                <button @onclick="() => DeleteDomain(domain.DomainId)" class="text-slate-400 hover:text-red-500 opacity-0 group-hover:opacity-100 transition-all">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </button>
                            </div>
                        </div>
                    }
                    
                    <button class="w-full py-3 text-center border-t border-slate-100 dark:border-slate-700 mt-4 text-[#004ac6] font-bold text-xs uppercase cursor-pointer hover:bg-slate-50">
                        Show All
                    </button>
                </div>
            </div>
        </div>

        <!-- Right Column: Settings & Trends -->
        <div class="space-y-6">
            
            <!-- AI Governance -->
            <div class="bg-[#004ac6] text-white rounded-2xl p-6 relative overflow-hidden shadow-lg shadow-blue-900/20 group">
                <div class="absolute -top-10 -right-10 w-32 h-32 bg-white/10 rounded-full blur-2xl group-hover:scale-150 transition-all duration-700 pointer-events-none"></div>
                <div class="flex items-center gap-3 mb-4 relative z-10">
                    <span class="material-symbols-outlined rounded text-[#004ac6] bg-white p-1 shadow-sm">psychology</span>
                    <h3 class="font-bold text-lg">AI Governance</h3>
                </div>
                <p class="text-[11px] text-blue-100 mb-6 leading-relaxed relative z-10">
                    Enforce automated AI security filters to detect harmful content in listings and chats.
                </p>
                <div class="space-y-4 relative z-10">
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-bold tracking-widest uppercase text-white">Safety Check</span>
                        <button @onclick="() => AiSafety = !AiSafety" class="w-12 h-6 rounded-full transition-colors relative @(AiSafety ? "bg-white" : "bg-blue-800")">
                            <span class="absolute top-1 w-4 h-4 bg-[#004ac6] rounded-full transition-all @(AiSafety ? "right-1" : "left-1 bg-slate-400")"></span>
                        </button>
                    </div>
                    <div class="w-full h-px bg-blue-500/50"></div>
                    <div class="flex justify-between items-center">
                        <span class="text-xs font-bold tracking-widest uppercase text-white">Auto-Flagging</span>
                        <button @onclick="() => AiFlagging = !AiFlagging" class="w-12 h-6 rounded-full transition-colors relative @(AiFlagging ? "bg-white" : "bg-blue-800")">
                            <span class="absolute top-1 w-4 h-4 bg-[#004ac6] rounded-full transition-all @(AiFlagging ? "right-1" : "left-1 bg-slate-400")"></span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- System Health Toggles -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm border border-slate-100 dark:border-slate-700 relative">
                <div class="flex justify-between items-center mb-6">
                    <h4 class="text-sm font-black text-[#171c1f] dark:text-white border-b-2 border-emerald-500 pb-1">System Health</h4>
                    <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.5)]"></span>
                </div>

                <div class="space-y-4">
                    <div class="flex justify-between items-center bg-slate-50 dark:bg-slate-900/50 p-4 rounded-xl border border-slate-100">
                        <div class="flex gap-3 items-center">
                            <span class="material-symbols-outlined text-slate-400">build</span>
                            <div>
                                <h5 class="text-xs font-bold text-[#171c1f] dark:text-white">Maintenance Mode</h5>
                                <p class="text-[9px] text-slate-400 uppercase tracking-widest">Disable public access</p>
                            </div>
                        </div>
                        <button @onclick="() => Maintenance = !Maintenance" class="w-10 h-5 rounded-full bg-slate-300 relative">
                            <span class="absolute top-0.5 w-4 h-4 bg-white rounded-full transition-all @(Maintenance ? "right-0.5" : "left-0.5") shadow-sm"></span>
                        </button>
                    </div>

                    <div class="flex justify-between items-center bg-slate-50 dark:bg-slate-900/50 p-4 rounded-xl border border-slate-100">
                        <div class="flex gap-3 items-center">
                            <span class="material-symbols-outlined text-slate-400">lock</span>
                            <div>
                                <h5 class="text-xs font-bold text-[#171c1f] dark:text-white">Read-Only Mode</h5>
                                <p class="text-[9px] text-slate-400 uppercase tracking-widest">Suspend all write operations</p>
                            </div>
                        </div>
                        <button @onclick="() => ReadOnly = !ReadOnly" class="w-10 h-5 rounded-full bg-slate-300 relative">
                            <span class="absolute top-0.5 w-4 h-4 bg-white rounded-full transition-all @(ReadOnly ? "right-0.5 bg-blue-500" : "left-0.5") shadow-sm"></span>
                        </button>
                    </div>
                    
                    <button class="w-full flex items-center justify-between border border-red-200 bg-red-50 text-red-600 px-4 py-3 rounded-xl hover:bg-red-100 transition shadow-sm">
                        <div class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">gpp_bad</span>
                            <span class="text-xs font-bold uppercase tracking-widest">Emergency Freeze</span>
                        </div>
                        <span class="w-2.5 h-2.5 bg-red-500 rounded-full shadow-[0_0_8px_rgba(239,68,68,0.5)]"></span>
                    </button>
                </div>
            </div>
            
            <!-- Simple Metrics Widget -->
            <div class="bg-white dark:bg-slate-800 rounded-2xl p-6 shadow-sm border border-slate-100 text-center">
                <div class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-1">New Registrations This Month</div>
                <div class="text-3xl font-black text-[#171c1f] dark:text-white mb-2">+1,240</div>
                <div class="flex items-end justify-center h-12 gap-1 px-4 mt-4 opacity-70">
                    <div class="w-1/6 bg-blue-200 rounded-t h-[30%]"></div>
                    <div class="w-1/6 bg-blue-300 rounded-t h-[40%]"></div>
                    <div class="w-1/6 bg-blue-400 rounded-t h-[60%]"></div>
                    <div class="w-1/6 bg-blue-500 rounded-t h-[75%]"></div>
                    <div class="w-1/6 bg-blue-600 rounded-t h-[90%]"></div>
                    <div class="w-1/6 bg-blue-700 rounded-t h-[100%]"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private bool AiSafety = true;
    private bool AiFlagging = true;
    private bool Maintenance = false;
    private bool ReadOnly = false;

    private bool IsAddingDomain = false;
    private string NewDomain = "";

    private List<AllowedEmailDomain> domains = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadDomains();
    }

    private async Task LoadDomains()
    {
        try
        {
            var result = await Http.GetFromJsonAsync<List<AllowedEmailDomain>>("api/Admin/domains");
            if (result != null)
            {
                domains = result;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading domains: {ex.Message}");
        }
    }

    private void ToggleAddDomain()
    {
        IsAddingDomain = !IsAddingDomain;
    }

    private async Task AddDomain()
    {
        if (!string.IsNullOrWhiteSpace(NewDomain))
        {
            var cleanedDomain = NewDomain.Trim();
            if (cleanedDomain.Contains("@"))
            {
                cleanedDomain = cleanedDomain.Split('@').Last();
            }

            var newEntity = new AllowedEmailDomain
            {
                DomainName = cleanedDomain,
                Description = "Manually added via Admin System Settings"
            };

            try
            {
                var response = await Http.PostAsJsonAsync("api/Admin/domains", newEntity);
                if (response.IsSuccessStatusCode)
                {
                    await LoadDomains();
                    NewDomain = "";
                    IsAddingDomain = false;
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error adding domain: {ex.Message}");
            }
        }
    }

    private async Task DeleteDomain(int domainId)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Admin/domains/{domainId}");
            if (response.IsSuccessStatusCode)
            {
                await LoadDomains();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting domain: {ex.Message}");
        }
    }

    public class AllowedEmailDomain
    {
        public int DomainId { get; set; }
        public string DomainName { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
    }
}
