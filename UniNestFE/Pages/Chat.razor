    // === CONTENT MODERATION METHODS ===
    
    private void ScanChatHistory()
    {
        foreach (var msg in ChatHistory)
        {
            if (msg.SafetyAlert == null)
            {
                msg.SafetyAlert = _moderationService.ScanMessage(msg.Content);
            }
        }
    }
    
    private void DismissAlert(MessageDto msg)
    {
        if (msg.SafetyAlert != null)
        {
            msg.SafetyAlert.IsDismissed = true;
            StateHasChanged();
        }
    }
    
    private void ReportUserFromAlert(MessageDto msg)
    {
        if (SelectedConversation == null) return;
        
        ShowModal(
            "Report User", 
            $"Report {SelectedConversation.PartnerName} for suspicious activity? This message was flagged: \"{msg.Content}\"", 
            "Confirm", 
            async () =>
            {
                try
                {
                    var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
                    var request = new HttpRequestMessage(HttpMethod.Post, $"api/Chat/report/{SelectedConversation.PartnerId}");
                    request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                    await Http.SendAsync(request);
                }
                catch (Exception ex)
                {
                    Console.WriteLine("Report Error: " + ex.Message);
                }
                
                ShowModal("Report Submitted", $"Thank you for reporting. Our team will review this conversation.");
            }
        );
    }
    
