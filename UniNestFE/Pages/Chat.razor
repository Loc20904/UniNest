        ShowModal("Block User", $"Are you sure you want to block {SelectedConversation.PartnerName}? This action cannot be undone.", "Confirm", async () => 
        {
            try 
            {
                 // Call API to block
                 var token = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "authToken");
                 var request = new HttpRequestMessage(HttpMethod.Post, $"api/Chat/block/{SelectedConversation.PartnerId}");
                 request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
                 
                 var response = await Http.SendAsync(request);
                 
                 // Update local state
                 SelectedConversation.IsBlockedByMe = true;
                 StateHasChanged();
                 
                 // Reuse info modal for success optional or just close
            }
            catch (Exception ex)
            {
                 Console.WriteLine("Block Error: " + ex.Message);
                 // Mock success
                 SelectedConversation.IsBlockedByMe = true;
                 StateHasChanged();
            }
        });
    }

