    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try 
        {
            var file = e.File;
            if (file != null)
            {
                Console.WriteLine($"[Chat] File selected: {file.Name}, Size: {file.Size}");
                
                // Limit size: max 10MB
                if(file.Size > 10 * 1024 * 1024) {
                     ShowModal("File too large", "Please select a file smaller than 10MB.");
                     return;
                }

                // 1. Upload to API
                var content = new MultipartFormDataContent();
                var fileContent = new StreamContent(file.OpenReadStream(10 * 1024 * 1024));
                fileContent.Headers.ContentType = new MediaTypeHeaderValue(file.ContentType);
                content.Add(fileContent, "file", file.Name);
                
                // Use the injected Http client
                var response = await Http.PostAsync("api/Upload/chat-image", content);
                
                if (!response.IsSuccessStatusCode)
                {
                    var error = await response.Content.ReadAsStringAsync();
                    Console.WriteLine($"[Chat] Upload failed: {response.StatusCode} - {error}");
                    ShowModal("Upload Failed", "Could not upload file. Please try again.");
                    return;
                }

                var uploadResult = await response.Content.ReadFromJsonAsync<UploadResponseDto>();
                string mediaUrl = uploadResult?.Url ?? "";
                
                if (string.IsNullOrEmpty(mediaUrl))
                {
                     ShowModal("Error", "Upload succeeded but no URL returned.");
                     return;
                }

                string msgType = file.ContentType.StartsWith("video/") ? "Video" : "Image";
                
                // 2. Optimistic UI Update
                var tempMsg = new MessageDto 
                { 
                    SenderId = CurrentUserId, 
                    MessageType = msgType,
                    MediaUrl = mediaUrl,
                    Content = msgType == "Image" ? "[Image]" : "[Video]",
                    SentAt = DateTime.Now,
                    MessageId = 0
                };
                
                ChatHistory.Add(tempMsg);
                await ScrollToBottom();
                StateHasChanged();

                // 3. Send SignalR Message with URL
                if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
                {
                     var request = new SendMessageRequest
                     {
                         ReceiverId = SelectedConversation.PartnerId,
                         Content = msgType == "Image" ? "[Image]" : "[Video]",
                         MessageType = msgType,
                         MediaUrl = mediaUrl
                     };
                     await hubConnection.SendAsync("SendMessage", request);
                     Console.WriteLine("[Chat] Message sent to SignalR.");
                }
            }
        }
        catch(Exception ex)
        {
             Console.WriteLine($"[Chat] File Error: {ex.Message}");
             ShowModal("Error", "Failed to send file: " + ex.Message);
        }
    }

