    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(NewMessageInput) || SelectedConversation == null) return;
        
        var content = NewMessageInput;
        NewMessageInput = ""; // Clear input immediately

        // 1. Optimistic Update (Show immediately)
        var tempMsg = new MessageDto 
        { 
            SenderId = CurrentUserId, 
            Content = content, 
            SentAt = DateTime.Now,
            MessageId = 0 // Pending
        };
        
        // Scan outgoing message for safety threats
        tempMsg.SafetyAlert = _moderationService.ScanMessage(content);
        
        ChatHistory.Add(tempMsg);
        await ScrollToBottom();
        StateHasChanged(); // Force refresh
        
        if (hubConnection is not null && hubConnection.State == HubConnectionState.Connected)
        {
            try
            {
                var request = new SendMessageRequest
                {
                    ReceiverId = SelectedConversation.PartnerId,
                    Content = content,
                    MessageType = "Text"
                };
                
                await hubConnection.SendAsync("SendMessage", request);
            }
            catch(Exception ex)
            {
                Console.WriteLine("Send Failed: " + ex.Message);
            }
        }
        else
        {
            // Fallback / Offline Mode
            // Mock Reply
             _ = Task.Delay(1500).ContinueWith(async _ => 
            {
                var reply = new MessageDto { SenderId = SelectedConversation.PartnerId, Content = "Ok (Mock Reply)", SentAt = DateTime.Now };
                ChatHistory.Add(reply);
                await InvokeAsync(StateHasChanged);
                await ScrollToBottom();
            });
        }
    }
    
