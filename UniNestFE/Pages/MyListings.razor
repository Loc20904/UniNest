@page "/mylistings"
@inject HttpClient Http
@inject IJSRuntime JS



<div class="listings-container">
    @if (listings != null && listings.Any(l => (l.ExpireAt - DateTime.Now).TotalDays < 3))
    {
        var expiring = listings.FirstOrDefault(l => (l.ExpireAt - DateTime.Now).TotalDays < 3);
        <!-- Alert Section -->
        <div class="alert-banner">
            <div class="alert-content">
                <i class="fas fa-clock"></i>
                <div>
                    <strong>Expiring soon!</strong>
                    <span>"@expiring?.Title" listing is expiring in @((int)(expiring.ExpireAt - DateTime.Now).TotalDays) days. Extend its visibility now.</span>
                </div>
            </div>
            <button class="btn-extend-top">Extend now</button>
        </div>
    }

    <!-- Header Section -->
    <div class="header-section">
        <div class="title-group">
            <h1>My Listings</h1>
            <p>Manage and monitor your accommodation posts in Da Nang</p>
        </div>
        <button class="btn-new-listing" @onclick="CreateListingNav">
            <i class="fas fa-plus"></i> New Listing
        </button>
    </div>

    <!-- Summary Cards -->
    <div class="summary-cards">
        <div class="card @(currentFilter == "All" ? "selected" : "")" @onclick='() => SetFilter("All")' style="cursor: pointer;">
            <div class="card-info">
                <span>Total Listings</span>
                <span class="count">@(listings?.Count ?? 0)</span>
            </div>
            <i class="fas fa-list-ul"></i>
        </div>
        <div class="card active @(currentFilter == "Published" ? "selected" : "")" @onclick='() => SetFilter("Published")' style="cursor: pointer;">
            <div class="card-info">
                <span>Published</span>
                <span class="count">@(listings?.Count(l => (l.ApprovalStatus == "Approved" || l.ApprovalStatus == "Published") && l.ExpireAt >= DateTime.Now && l.IsAvailable) ?? 0)</span>
            </div>
            <i class="fas fa-check-circle"></i>
        </div>
        <div class="card pending @(currentFilter == "Pending" ? "selected" : "")" @onclick='() => SetFilter("Pending")' style="cursor: pointer;">
            <div class="card-info">
                <span>Pending</span>
                <span class="count">@(listings?.Count(l => l.ApprovalStatus == "Pending") ?? 0)</span>
            </div>
            <i class="fas fa-hourglass-half"></i>
        </div>
        <div class="card hidden-card @(currentFilter == "Hidden" ? "selected" : "")" @onclick='() => SetFilter("Hidden")' style="cursor: pointer;">
            <div class="card-info">
                <span>Hidden</span>
                <span class="count">@(listings?.Count(l => l.ApprovalStatus == "Hidden" || ((l.ApprovalStatus == "Published" || l.ApprovalStatus == "Approved") && l.ExpireAt >= DateTime.Now && !l.IsAvailable)) ?? 0)</span>
            </div>
            <i class="fas fa-eye-slash"></i>
        </div>
        <div class="card draft-card @(currentFilter == "Draft" ? "selected" : "")" @onclick='() => SetFilter("Draft")' style="cursor: pointer;">
            <div class="card-info">
                <span>Draft</span>
                <span class="count">@(listings?.Count(l => l.ApprovalStatus == "Draft") ?? 0)</span>
            </div>
            <i class="fas fa-file-alt"></i>
        </div>
        <div class="card reject-card @(currentFilter == "Not Approved" ? "selected" : "")" @onclick='() => SetFilter("Not Approved")' style="cursor: pointer;">
            <div class="card-info">
                <span>Not Approved</span>
                <span class="count">@(listings?.Count(l => l.ApprovalStatus == "Rejected" || l.ApprovalStatus == "Reject" || l.ApprovalStatus == "Not Approved") ?? 0)</span>
            </div>
            <i class="fas fa-times-circle"></i>
        </div>
        <div class="card expire-card @(currentFilter == "Expired" ? "selected" : "")" @onclick='() => SetFilter("Expired")' style="cursor: pointer;">
            <div class="card-info">
                <span>Expired</span>
                <span class="count">@(listings?.Count(l => l.ApprovalStatus == "Expired" || (l.ExpireAt < DateTime.Now && l.ApprovalStatus != "Draft" && l.ApprovalStatus != "Reject" && l.ApprovalStatus != "Rejected" && l.ApprovalStatus != "Pending")) ?? 0)</span>
            </div>
            <i class="fas fa-calendar-times"></i>
        </div>
    </div>

    <div class="filter-tabs">
        <button class="filter-btn @(currentFilter == "All" ? "active" : "")" @onclick='() => SetFilter("All")'>All</button>
        <button class="filter-btn @(currentFilter == "Published" ? "active" : "")" @onclick='() => SetFilter("Published")'>Published</button>
        <button class="filter-btn @(currentFilter == "Pending" ? "active" : "")" @onclick='() => SetFilter("Pending")'>Pending</button>
        <button class="filter-btn @(currentFilter == "Not Approved" ? "active" : "")" @onclick='() => SetFilter("Not Approved")'>Not Approved</button>
        <button class="filter-btn @(currentFilter == "Expired" ? "active" : "")" @onclick='() => SetFilter("Expired")'>Expired</button>
        <button class="filter-btn @(currentFilter == "Hidden" ? "active" : "")" @onclick='() => SetFilter("Hidden")'>Hidden</button>
        <button class="filter-btn @(currentFilter == "Draft" ? "active" : "")" @onclick='() => SetFilter("Draft")'>Draft</button>
    </div>

    <!-- Table Section -->
    <div class="table-container">
        <table class="listings-table">
            <thead>
                <tr>
                    <th>LISTING</th>
                    <th>STATUS</th>
                    <th>EXPIRY DATE</th>
                    <th>ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                @if (listings == null)
                {
                    <tr>
                        <td colspan="5" style="text-align:center; padding: 40px;">Loading listings...</td>
                    </tr>
                }
                else if (!FilteredListings.Any())
                {
                    <tr>
                        <td colspan="5" style="text-align:center; padding: 60px;">
                            <div class="empty-state" style="display: flex; flex-direction: column; align-items: center; justify-content: center;">
                                <i class="fas fa-folder-open" style="font-size: 40px; color: #e2e8f0; margin-bottom: 12px;"></i>
                                <p style="color: #94a3b8; font-size: 15px; font-weight: 500; margin: 0;">There are no posts in this section.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    var pagedListings = FilteredListings
                                        .Skip((currentPage - 1) * pageSize)
                                        .Take(pageSize)
                                        .ToList();

                    @foreach (var listing in pagedListings)
                    {
                        <tr>
                            <td>
                                <div class="listing-info">
                                    <img src="@(string.IsNullOrEmpty(listing.PrimaryImageUrl) ? "default.jpg" : "https://localhost:7045" + listing.PrimaryImageUrl)" alt="Listing Image" />
                                    <div class="listing-text">
                                        <div class="title">@listing.Title</div>
                                        <div class="location"><i class="fas fa-map-marker-alt"></i> @listing.FullAddress</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (listing.ApprovalStatus == "Draft")
                                {
                                    <span class="status-badge" style="background-color: #f1f5f9; color: #475569; padding: 4px 12px; border-radius: 9999px; font-weight: 700; font-size: 13px;">Draft</span>
                                }
                                else if (listing.ApprovalStatus == "Rejected" || listing.ApprovalStatus == "Reject" || listing.ApprovalStatus == "Not Approved")
                                {
                                    <span class="status-badge" style="background-color: #fee2e2; color: #ef4444; padding: 4px 12px; border-radius: 9999px; font-weight: 700; font-size: 13px;">Not Approved</span>
                                }
                                else if (listing.ApprovalStatus == "Expired")
                                {
                                    <span class="status-badge" style="background-color: #FEF9C3; color: #C2410C; padding: 4px 12px; border-radius: 9999px; font-weight: 700; font-size: 13px;">Expired</span>
                                }
                                else if (listing.ApprovalStatus == "Pending")
                                {
                                    <span class="status-badge pending">Pending</span>
                                }
                                else if (listing.ExpireAt < DateTime.Now)
                                {
                                    <span class="status-badge expired">Expired</span>
                                }
                                else if (!listing.IsAvailable)
                                {
                                    <span class="status-badge is-hidden">Hidden</span>
                                }
                                else
                                {
                                    <span class="status-badge published">Published</span>
                                }
                            </td>
                            <td>
                                <div class="expiry-date">
                                    <span>@listing.ExpireAt.ToString("MMM dd, yyyy")</span>
                                    @if ((listing.ExpireAt - DateTime.Now).TotalDays < 3 && (listing.ExpireAt - DateTime.Now).TotalDays >= 0)
                                    {
                                        <span class="expiry-warning">Expiring in @((int)(listing.ExpireAt - DateTime.Now).TotalDays) days</span>
                                    }
                                </div>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-icon" @onclick="() => EditListing(listing.ListingId)">
                                        <i class="fas fa-pencil-alt"></i>
                                    </button>
                                    <label class="toggle-switch" style="@(listing.ApprovalStatus == "Pending" || listing.ApprovalStatus == "Draft" || listing.ApprovalStatus == "Rejected" || listing.ApprovalStatus == "Reject" || listing.ApprovalStatus == "Expired" ? "opacity: 0.5; pointer-events: none;" : "")">
                                        <input type="checkbox"
                                               checked="@listing.IsAvailable"
                                               disabled="@(listing.ApprovalStatus == "Pending" || listing.ApprovalStatus == "Draft" || listing.ApprovalStatus == "Rejected" || listing.ApprovalStatus == "Reject" || listing.ApprovalStatus == "Expired")"
                                               @onchange="() => ToggleVisibility(listing.ListingId)" />
                                        <span class="slider"></span>
                                    </label>
                                    <button class="btn-extend" @onclick="() => ExtendListing(listing.ListingId)">
                                        Extend
                                    </button>
                                    <button class="btn-icon delete" @onclick="() => DeleteListing(listing.ListingId)">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (FilteredListings.Any())
        {
            <div class="table-footer">
                <div class="extension-tools">
                    <span>EXTENSION TOOLS:</span>
                    <div class="duration-select">
                        Listing Duration: <strong>+ 30 Days</strong>
                    </div>
                </div>
                
                @if (TotalPages > 1)
                {
                    <div class="pagination">
                        <span class="prev" @onclick="PrevPage" style="cursor:pointer">Previous</span>
                        @for (int i = 1; i <= TotalPages; i++)
                        {
                            int pageNum = i;
                            <span class="page-num @(currentPage == pageNum ? "active" : "")"
                                  @onclick="(() => GoToPage(pageNum))"
                                  style="cursor:pointer">
                                @pageNum
                            </span>
                        }
                        <span class="next" @onclick="NextPage" style="cursor:pointer">Next</span>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Info Cards -->
    <div class="info-cards">
        <div class="info-card help">
            <div class="icon-circle">
                <i class="fas fa-info"></i>
            </div>
            <div class="info-text">
                <h3>What is "Hidden" status?</h3>
                <p>Hidden listings won't appear in search results but will keep their views and statistics. Use this if you've temporarily found a roommate but want to keep the post for later.</p>
            </div>
        </div>
        <div class="info-card boost">
            <div class="icon-circle">
                <i class="fas fa-chart-line"></i>
            </div>
            <div class="info-text">
                <h3>Boost Visibility</h3>
                <p>Listings with high-quality photos get 3x more views. Update your thumbnails to attract more Roomies in Da Nang.</p>
                <a href="#">View Analytics</a>
            </div>
        </div>
    </div>
    <UniNestFE.Layout.ScrollButton />
</div>




@code {

    public class MyListingDto
    {
        public int ListingId { get; set; }
        public string? Title { get; set; }
        public decimal Price { get; set; }
        public double AreaSquareMeters { get; set; }
        public bool IsAvailable { get; set; }
        public string? ApprovalStatus { get; set; }
        public DateTime ExpireAt { get; set; }

        public string? FullAddress { get; set; }
        public string? City { get; set; }
        public string? District { get; set; }

        public string? PrimaryImageUrl { get; set; }


    }
    List<MyListingDto> listings;

    int currentPage = 1;
    int pageSize = 10;

    string currentFilter = "All";

    void SetFilter(string filter)
    {
        currentFilter = filter;
        currentPage = 1;
    }

    IEnumerable<MyListingDto> FilteredListings
    {
        get
        {
            if (listings == null) return Enumerable.Empty<MyListingDto>();

            var query = listings.AsEnumerable();

            switch (currentFilter)
            {
                case "Published":
                    query = query.Where(l => (l.ApprovalStatus == "Published" || l.ApprovalStatus == "Approved") && l.IsAvailable && l.ExpireAt >= DateTime.Now);
                    break;
                case "Pending":
                    query = query.Where(l => l.ApprovalStatus == "Pending");
                    break;
                case "Not Approved":
                    query = query.Where(l => l.ApprovalStatus == "Rejected" || l.ApprovalStatus == "Reject" || l.ApprovalStatus == "Not Approved");
                    break;
                case "Expired":
                    query = query.Where(l => l.ApprovalStatus == "Expired" || (l.ExpireAt < DateTime.Now && l.ApprovalStatus != "Draft" && l.ApprovalStatus != "Reject" && l.ApprovalStatus != "Rejected" && l.ApprovalStatus != "Pending"));
                    break;
                case "Hidden":
                    query = query.Where(l => l.ApprovalStatus == "Hidden" || ((l.ApprovalStatus == "Published" || l.ApprovalStatus == "Approved") && !l.IsAvailable && l.ExpireAt >= DateTime.Now));
                    break;
                case "Draft":
                    query = query.Where(l => l.ApprovalStatus == "Draft");
                    break;
            }
            return query.ToList();
        }
    }

    int TotalPages
    {
        get
        {
            var count = FilteredListings.Count();
            if (count == 0) return 1;
            return (int)Math.Ceiling((double)count / pageSize);
        }
    }

    public void GoToPage(int page)
    {
        currentPage = page;
        StateHasChanged();
    }

    public void NextPage()
    {
        if (currentPage < TotalPages)
        {
            currentPage++;
            StateHasChanged();
        }
    }

    public void PrevPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            StateHasChanged();
        }
    }
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Lấy token từ localStorage
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken"); //B1 Lấy mã định danh

            // Gắn token vào Authorization header
            Http.DefaultRequestHeaders.Authorization =
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token); //B2 Gắn mã định danh để gọi API

            // Gọi API
            listings = await Http.GetFromJsonAsync<List<MyListingDto>>(
                "https://localhost:7045/api/MyListings"
            ) ?? new List<MyListingDto>(); ;//B3 Lấy danh sách tin đăng
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            listings = new List<MyListingDto>();
        }
    }
    async Task DeleteListing(int id)
    {
        var response = await Http.DeleteAsync($"https://localhost:7045/api/MyListings/{id}");

        if (response.IsSuccessStatusCode)
        {
            listings.RemoveAll(l => l.ListingId == id);
        }
    }
    async Task ToggleVisibility(int id)
    {
        try
        {
            var content = new StringContent("", System.Text.Encoding.UTF8, "application/json");
            var response = await Http.PatchAsync(
                $"https://localhost:7045/api/MyListings/toggle-visibility/{id}",
                content
            );

            if (response.IsSuccessStatusCode)
            {
                var listing = listings.FirstOrDefault(l => l.ListingId == id);
                if (listing != null)
                {
                    listing.IsAvailable = !listing.IsAvailable;
                    listing.ApprovalStatus = listing.IsAvailable ? "Published" : "Hidden";
                    StateHasChanged();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }
    async Task ExtendListing(int id)
    {
        var dto = new
        {
            Days = 30
        };

        var response = await Http.PatchAsJsonAsync(
            $"https://localhost:7045/api/MyListings/extend/{id}",
            dto
        );

        if (response.IsSuccessStatusCode)
        {
            var listing = listings.FirstOrDefault(l => l.ListingId == id);

            if (listing != null)
            {
                listing.ExpireAt = listing.ExpireAt.AddDays(30);
            }
        }
    }

    [Inject] NavigationManager Nav { get; set; }

    void EditListing(int id)
    {
        Nav.NavigateTo($"/edit-listing/{id}");
    }

    void CreateListingNav()
    {
        Nav.NavigateTo("/create-listing");
    }
}