@page "/admin/listings"
@layout Layout.AdminLayout

<PageTitle>Quản lý Bài Đăng | Quản trị UniNest</PageTitle>

<div class="flex flex-col space-y-8 animate-fade-in-up">
    <!-- Header -->
    <div class="flex justify-between items-end">
        <div>
            <h3 class="text-xs font-bold text-[#515f74] uppercase tracking-widest mb-1">MANAGEMENT HUB</h3>
            <h2 class="text-3xl font-extrabold text-[#171c1f] dark:text-white tracking-tight">Listing Management</h2>
            <p class="text-sm text-[#515f74] dark:text-slate-400 mt-2">Giám sát hệ sinh thái nhà ở sinh viên. Kiểm duyệt các bài đăng phòng trọ.</p>
        </div>
        <div class="bg-white dark:bg-slate-800 border border-slate-100 dark:border-slate-700 px-6 py-4 rounded-xl flex items-center gap-6 shadow-sm">
            <div>
                <div class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-1">Tổng cộng (Active)</div>
                <div class="text-3xl font-black text-[#171c1f] dark:text-white">1,284</div>
            </div>
            <!-- Mock Line Graph -->
            <svg width="60" height="30" viewBox="0 0 60 30" fill="none" class="text-[#004ac6]">
                <path d="M0,25 C10,25 15,10 25,15 C35,20 40,5 50,20 C55,25 60,10 60,10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
        </div>
    </div>

    <!-- Filters -->
    <div class="bg-slate-50 dark:bg-slate-800/50 p-4 rounded-xl border border-slate-100 dark:border-slate-700 flex gap-4">
        <div class="flex-1 space-y-1.5">
            <label class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest pl-1">Lọc theo Khu vực</label>
            <div class="relative">
                <select class="w-full bg-white dark:bg-slate-800 border-none rounded-lg px-4 py-3 outline-none text-sm font-semibold tracking-wide text-[#171c1f] dark:text-white shadow-sm appearance-none focus:ring-2 focus:ring-[#004ac6]">
                    <option>Tất cả quận/huyện Đà Nẵng</option>
                    <option>Quận Hải Châu</option>
                    <option>Quận Liên Chiểu</option>
                    <option>Ngũ Hành Sơn</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-[#515f74]">expand_more</span>
            </div>
        </div>

        <div class="flex-1 space-y-1.5">
            <label class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest pl-1">Mức giá</label>
            <div class="relative">
                <select class="w-full bg-white dark:bg-slate-800 border-none rounded-lg px-4 py-3 outline-none text-sm font-semibold tracking-wide text-[#171c1f] dark:text-white shadow-sm appearance-none focus:ring-2 focus:ring-[#004ac6]">
                    <option>Bất kỳ giá nào</option>
                    <option>Dưới 2 Triệu</option>
                    <option>Từ 2 - 4 Triệu</option>
                    <option>Từ 4 - 6 Triệu</option>
                </select>
                <span class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 pointer-events-none text-[#515f74]">expand_more</span>
            </div>
        </div>

        <div class="flex items-end">
            <button class="bg-slate-200 dark:bg-slate-700 text-[#515f74] dark:text-slate-300 px-6 py-3 rounded-lg font-bold text-sm hover:bg-slate-300 transition-colors">Thiết lập lại</button>
        </div>
    </div>

    <!-- Data List -->
    <div class="bg-white dark:bg-slate-800 rounded-xl border border-slate-100 dark:border-slate-700 shadow-sm overflow-hidden flex flex-col sm:flex-row relative">
        <div class="flex-1">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-slate-50 dark:bg-slate-900 border-b border-slate-100 dark:border-slate-700">
                        <th class="px-6 py-4 text-[10px] uppercase tracking-widest font-extrabold text-[#515f74]">Chi tiết bài đăng</th>
                        <th class="px-6 py-4 text-[10px] uppercase tracking-widest font-extrabold text-[#515f74]">Chủ trọ</th>
                        <th class="px-6 py-4 text-[10px] uppercase tracking-widest font-extrabold text-[#515f74]">Vị trí</th>
                        <th class="px-6 py-4 text-[10px] uppercase tracking-widest font-extrabold text-[#515f74]">Giá thuê</th>
                        <th class="px-6 py-4 text-[10px] uppercase tracking-widest font-extrabold text-[#515f74]">Trạng thái</th>
                        <th class="px-6 py-4 text-[10px] uppercase tracking-widest font-extrabold text-[#515f74] text-right">Moderation</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 dark:divide-slate-700">
                    @foreach(var item in listings.Where(l => l.Visible))
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-4">
                                    <div class="w-16 h-16 rounded overflow-hidden shadow-sm bg-slate-200 flex-shrink-0">
                                        <img src="@item.ImageUrl" alt="room" class="w-full h-full object-cover">
                                    </div>
                                    <div>
                                        <div class="font-bold text-sm text-[#171c1f] dark:text-white line-clamp-1 max-w-[200px]">@item.Title</div>
                                        <div class="text-[10px] text-[#515f74] uppercase tracking-widest mt-1">Room Posting • ID: @item.Id</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <div class="w-6 h-6 rounded-full bg-blue-100 text-[#004ac6] flex items-center justify-center text-[10px] font-black">@item.Owner.Substring(0, 1)</div>
                                    <div class="text-xs font-bold text-[#171c1f] dark:text-slate-300">@item.Owner</div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-1.5 text-xs font-semibold text-[#515f74] dark:text-slate-400">
                                    <span class="material-symbols-outlined text-sm text-[#004ac6]">location_on</span>
                                    @item.District
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-xs font-black text-[#171c1f] dark:text-white">@item.Price <span class="text-[10px] text-[#515f74] font-semibold uppercase">VND/mo</span></div>
                            </td>
                            <td class="px-6 py-4">
                                @if(item.Status == "Active")
                                {
                                    <span class="px-2.5 py-1 bg-emerald-50 text-emerald-700 border border-emerald-200 text-[10px] font-black uppercase tracking-widest rounded-full">Active</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 bg-red-50 text-red-700 border border-red-200 text-[10px] font-black uppercase tracking-widest rounded-full animate-pulse">Flagged</span>
                                }
                            </td>
                            <td class="px-6 py-4 text-right">
                                <button class="w-8 h-8 rounded hover:bg-slate-200 dark:hover:bg-slate-700 text-slate-400 transition-colors">
                                    <span class="material-symbols-outlined text-[18px]">visibility_off</span>
                                </button>
                                <button @onclick="() => item.Visible = false" class="w-8 h-8 rounded hover:bg-red-100 text-red-500 transition-colors ml-1">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <div class="p-4 border-t border-slate-100 dark:border-slate-700 flex justify-between items-center bg-slate-50 dark:bg-slate-900/50">
                <span class="text-[11px] font-bold text-[#515f74] uppercase tracking-widest">Hiển thị @listings.Count(l => l.Visible) trên 1,284 kết quả lọc</span>
                <div class="flex space-x-1">
                    <button class="w-8 h-8 flex items-center justify-center bg-white border border-slate-200 rounded text-slate-400">
                        <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                    </button>
                    <button class="w-8 h-8 flex items-center justify-center bg-[#004ac6] text-white rounded font-bold text-xs">1</button>
                    <button class="w-8 h-8 flex items-center justify-center bg-white border border-slate-200 rounded text-[#171c1f] font-bold text-xs">2</button>
                    <button class="w-8 h-8 flex items-center justify-center bg-white border border-slate-200 rounded text-[#171c1f] font-bold text-xs">3</button>
                    <button class="w-8 h-8 flex items-center justify-center bg-white border border-slate-200 rounded text-slate-600">
                        <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                    </button>
                </div>
            </div>
        </div>

        <!-- Sidebar Widget: System Health -->
        <div class="w-80 border-l border-slate-100 dark:border-slate-700 bg-slate-50/50 dark:bg-slate-900/50 p-6 absolute right-0 top-32 z-10 shadow-2xl rounded-2xl hidden lg:block">
            <div class="flex justify-between items-center mb-6">
                <h4 class="text-xs font-black uppercase tracking-widest text-[#171c1f] dark:text-white">System Health</h4>
                <div class="w-2.5 h-2.5 bg-emerald-500 rounded-full shadow-[0_0_8px_rgba(16,185,129,0.8)]"></div>
            </div>
            
            <div class="flex justify-between items-end mb-2">
                <span class="text-[11px] font-bold text-[#515f74]">Bài đang chờ kiểm duyệt</span>
                <span class="text-xs font-black text-red-600">12 Flagged</span>
            </div>
            <div class="w-full h-1.5 bg-slate-200 rounded-full mb-6 overflow-hidden">
                <div class="w-[85%] h-full bg-red-500 rounded-full"></div>
            </div>

            <button class="w-full bg-[#004ac6] text-white font-bold text-xs uppercase tracking-widest py-3 rounded-lg shadow-md hover:bg-blue-700 transition">
                Duyệt các cảnh báo cấp bách
            </button>
        </div>
    </div>
</div>

<style>
    .animate-fade-in-up { animation: fadeInUp 0.4s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private List<ListingMock> listings = new()
    {
        new ListingMock { Id = "62910", ImageUrl = "https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?auto=format&fit=crop&w=200&q=80", Title = "Studio cao cấp gần ĐH Đại Nam", Owner = "Nguyen Hoang", District = "Quận Hải Châu", Price = "3.500.000", Status = "Active", Visible = true },
        new ListingMock { Id = "77124", ImageUrl = "https://images.unsplash.com/photo-1502672260266-1c1c24240f36?auto=format&fit=crop&w=200&q=80", Title = "Phòng share chung sinh viên VN-UK", Owner = "Tran Pham", District = "Q. Ngũ Hành Sơn", Price = "1.800.000", Status = "Flagged", Visible = true },
        new ListingMock { Id = "91022", ImageUrl = "https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?auto=format&fit=crop&w=200&q=80", Title = "Master Room Biệt thự Sơn Trà", Owner = "Le Van", District = "Quận Sơn Trà", Price = "7.200.000", Status = "Active", Visible = true },
        new ListingMock { Id = "65239", ImageUrl = "https://images.unsplash.com/photo-1493663284031-b7e3aefcae8e?auto=format&fit=crop&w=200&q=80", Title = "Trọ giá rẻ sạch sẽ gần Bách Khoa", Owner = "Tu Anh", District = "Quận Liên Chiểu", Price = "2.200.000", Status = "Active", Visible = true }
    };

    public class ListingMock
    {
        public string Id { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string Title { get; set; } = "";
        public string Owner { get; set; } = "";
        public string District { get; set; } = "";
        public string Price { get; set; } = "";
        public string Status { get; set; } = "";
        public bool Visible { get; set; } = true;
    }
}
