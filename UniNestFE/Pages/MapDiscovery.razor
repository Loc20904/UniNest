@code {
    // --- KHAI BÁO BIẾN ---

    // Giá trị: "Any", "Male", "Female"
    private string SelectedGender = "Any"; 
    private bool IsStudentVerified = false;
    private double MinPrice = 1500000;
    private double MaxPrice = 4000000;

    private bool IsMapLoaded = false;
    private bool IsLoading = true;
    private bool _areMarkersDrawn = false;
    
    private List<RoomDto> Rooms = new();
    private List<RoomDto> FilteredRooms = new(); // List hiển thị
    private string CurrentDistance = "-- km";
    private RoomDto? SelectedRoom;
    private DotNetObjectReference<MapDiscovery>? objRef;

    [JSInvokable]
    public async Task OnMarkerClick(int id)
    {
        SelectedRoom = Rooms.FirstOrDefault(r => r.Id == id);
        CurrentDistance = "Calculating...";
        StateHasChanged();
        
        if (SelectedRoom != null)
        {
             // Call JS to calculate distance from User Location -> Room
             // Note: User location is tracked by Mapbox GL Geolocation Control, accessed via mapInterop.js
             await JSRuntime.InvokeVoidAsync("uniNestMap.calculateDistanceTo", SelectedRoom.Lat, SelectedRoom.Lng);
        }
    }

    [JSInvokable]
    public void UpdateDistanceResult(string distanceText)
    {
        CurrentDistance = distanceText;
        StateHasChanged();
    }

    // Danh sách trường Đại học (Cố định)
private List<UniversityDto> Universities = new()
{
    // --- ĐẠI HỌC ĐÀ NẴNG (UD) ---
    new UniversityDto { Name = "ĐH Bách Khoa (DUT)", Lat = 16.0738, Lng = 108.1499 },
    new UniversityDto { Name = "ĐH Kinh Tế (DUE)", Lat = 16.0469, Lng = 108.2430 },
    new UniversityDto { Name = "ĐH Sư Phạm (UED)", Lat = 16.0604, Lng = 108.1585 },
    new UniversityDto { Name = "ĐH Ngoại Ngữ (UFLS)", Lat = 16.0594, Lng = 108.2135 },
    new UniversityDto { Name = "ĐH Sư phạm Kỹ thuật (UTE)", Lat = 16.0780, Lng = 108.2130 },
    new UniversityDto { Name = "ĐH CNTT & TT Việt - Hàn (VKU)", Lat = 15.9751, Lng = 108.2532 },
    new UniversityDto { Name = "Viện Nghiên cứu & Đào tạo Việt - Anh (VNUK)", Lat = 16.0762, Lng = 108.2205 },
    new UniversityDto { Name = "Khoa Y Dược - ĐHĐN (SMP)", Lat = 16.0245, Lng = 108.2120 }, // Khu đô thị ĐHQG (Hòa Quý) hoặc 99 Hùng Vương

    // --- ĐẠI HỌC CÔNG LẬP KHÁC ---
    new UniversityDto { Name = "ĐH Thể dục Thể thao Đà Nẵng", Lat = 16.0583, Lng = 108.1834 },
    new UniversityDto { Name = "ĐH Kỹ thuật Y Dược Đà Nẵng", Lat = 16.0688, Lng = 108.2202 },
    new UniversityDto { Name = "Học viện Chính trị khu vực III", Lat = 16.0645, Lng = 108.2325 }, // 232 Nguyễn Công Trứ

