@page "/"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@implements IDisposable
@inject IConfiguration Configuration

@* --- 1. STYLE TÙY CHỈNH --- *@
<style>
    /* Thanh cuộn đẹp */
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #121416; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #27353a; border-radius: 10px; }

    /* Nền chấm bi cho Map khi đang load */
    .map-bg {
        background-image: radial-gradient(#27353a 1px, transparent 1px);
        background-size: 20px 20px;
    }

    /* Màu chủ đạo */
    .text-primary { color: #06b5ef; }
    .bg-primary { background-color: #06b5ef; }
    .border-primary { border-color: #06b5ef; }
    .text-accent-green { color: #7CD933; }
    .bg-accent-green { background-color: #7CD933; }

    /* Ẩn nút định vị mặc định xấu xí của GoongJS */
    .mapboxgl-ctrl-geolocate { display: none !important; }

    /* Hiệu ứng nhấp nháy cho Marker Trường Đại Học */
    .university-marker {
        animation: pulse-blue 2s infinite;
    }
    @@keyframes pulse-blue {
        0% { box-shadow: 0 0 0 0 rgba(6, 181, 239, 0.7); }
        70% { box-shadow: 0 0 0 15px rgba(6, 181, 239, 0); }
        100% { box-shadow: 0 0 0 0 rgba(6, 181, 239, 0); }
    }
</style>

@* --- 2. LAYOUT CHÍNH (Full màn hình) --- *@
<div class="h-[100dvh] w-full flex flex-col bg-[#fafaf9] dark:bg-[#121416] text-slate-900 dark:text-white overflow-hidden font-sans">

    <main class="flex flex-1 overflow-hidden relative w-full h-full">
        
        @* --- A. SIDEBAR --- *@
        <aside class="w-[380px] flex flex-col border-r border-slate-200 dark:border-[#27353a] bg-[#fafaf9] dark:bg-[#121416] z-40 overflow-y-auto custom-scrollbar shrink-0">
            <div class="p-6 flex flex-col gap-6">
                @* Header Sidebar *@
                <div>
                    <h1 class="text-2xl font-extrabold tracking-tight">Find Your Base</h1>
                    <p class="text-slate-500 dark:text-[#9bb3bb] text-sm">Campus-centric living in Da Nang</p>
                </div>
                
                @* Search Bar *@
<div class="relative z-50"> <label class="flex flex-col w-full">
        <div class="flex w-full items-stretch rounded-xl h-12 bg-slate-100 dark:bg-[#27353a] border border-transparent focus-within:border-primary/50 transition-all relative">
            <div class="text-slate-400 flex items-center justify-center pl-4">
                <span class="material-icons-round">search</span>
            </div>
            
            @* --- SỬA ĐỔI: Thêm @bind và @oninput --- *@
            <input @bind="SearchQuery" 
                   @oninput="OnSearchInput"
                   class="w-full border-none bg-transparent focus:ring-0 outline-none text-sm font-medium px-3 dark:text-white" 
                   placeholder="Tìm địa điểm, trường học..."/>

            @* Nút Xóa Search *@
            @if (!string.IsNullOrEmpty(SearchQuery))
            {
                <button @onclick="ClearSearch" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-red-500">
                    <span class="material-icons-round text-sm">close</span>
                </button>
            }
        </div>
    </label>

    @* --- BỔ SUNG: Danh sách Gợi ý (Dropdown) --- *@
    @if (Suggestions.Any())
    {
        <ul class="absolute top-14 left-0 w-full bg-white dark:bg-[#1c2126] rounded-xl shadow-2xl border border-slate-200 dark:border-[#27353a] overflow-hidden max-h-80 overflow-y-auto custom-scrollbar animate-fade-in-up">
            @foreach (var item in Suggestions)
            {
                <li @onclick="() => SelectPlace(item)" 
                    class="px-4 py-3 hover:bg-slate-50 dark:hover:bg-[#27353a] cursor-pointer border-b border-slate-100 dark:border-[#27353a] last:border-none flex items-start gap-3 transition-colors">
                    
                    <div class="mt-1 text-slate-400">
                        <span class="material-icons-round text-sm">location_on</span>
                    </div>
                    <div>
                        <div class="text-sm font-bold text-slate-700 dark:text-slate-200">
                            @item.structured_formatting.main_text
                        </div>
                        <div class="text-xs text-slate-500 truncate">
                            @item.structured_formatting.secondary_text
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

                @* List Rooms *@
                <div class="pt-4 border-t border-slate-200 dark:border-[#27353a]">
                    <p class="text-xs font-bold text-slate-400 mb-4">SHOWING @Rooms.Count ROOMS</p>
                    @if (IsLoading)
                    {
                         <div class="flex justify-center py-4"><span class="text-slate-400 text-sm">Loading listings...</span></div>
                    }
                    else
                    {
                        <div class="flex flex-col gap-3">
                            @foreach (var room in Rooms)
                            {
                                <div @onclick="() => PanToRoom(room)" class="flex gap-3 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-[#1c2126] transition-all cursor-pointer group @(SelectedRoom?.Id == room.Id ? "bg-slate-100 dark:bg-[#1c2126]" : "")">
                                    <div class="size-16 rounded-lg bg-cover bg-center shrink-0 border border-slate-200 dark:border-[#27353a] bg-gray-600"
                                         style="background-image: url('@(string.IsNullOrEmpty(room.Image) ? "https://via.placeholder.com/150" : room.Image)');">
                                    </div>
                                    <div class="flex flex-col justify-center overflow-hidden">
                                        <h4 class="text-sm font-bold truncate group-hover:text-primary">@room.Title</h4>
                                        <p class="text-xs text-slate-500 truncate">@room.Address</p>
                                        <p class="text-sm font-extrabold text-primary mt-1">@FormatPrice(room.Price)</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </aside>

        @* --- B. MAP AREA --- *@
        <section class="flex-1 relative bg-[#1c2126] overflow-hidden map-bg min-w-0">
            @* Container chứa Map *@
            <div id="google-map" class="absolute inset-0 w-full h-full z-0"></div>

            @* Loading Overlay *@
            @if (!IsMapLoaded)
            {
                <div class="absolute inset-0 flex items-center justify-center bg-[#1c2126] z-50">
                    <div class="flex flex-col items-center gap-2">
                        <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-primary"></div>
                        <span class="text-slate-400 text-sm">Loading Map...</span>
                    </div>
                </div>
            }

            @* --- CONTROLS (Góc dưới bên phải) --- *@
            <div class="absolute bottom-8 right-8 flex flex-col gap-2 z-10">
                
                @* Nút Vị trí của tôi *@
<div class="absolute bottom-12 right-0 flex flex-col gap-3 z-10">
    <button @onclick="LocateUser"
            class="size-12 rounded-xl bg-primary text-[#121416] flex items-center justify-center shadow-xl hover:bg-primary/90 active:scale-95 transition-all"
            title="Vị trí của tôi">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="size-6">
            <path d="M12 8c-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4-1.79-4-4-4zm8.94 3c-.46-4.17-3.77-7.48-7.94-7.94V1h-2v2.06C6.83 3.52 3.52 6.83 3.06 11H1v2h2.06c.46 4.17 3.77 7.48 7.94 7.94V23h2v-2.06c4.17-.46 7.48-3.77 7.94-7.94H23v-2h-2.06zM12 19c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-7z"/>
        </svg>
    </button>
</div>
                @* Nút Zoom (Visual Only - Mapbox tự có nút nếu bật NavigationControl) *@
                @* <button class="size-12 rounded-xl bg-[#121416] border border-[#27353a] text-white flex items-center justify-center shadow-xl hover:bg-[#1c2126] transition-colors cursor-default">
                    <span class="material-icons-round">add</span>
                </button>
                <button class="size-12 rounded-xl bg-[#121416] border border-[#27353a] text-white flex items-center justify-center shadow-xl hover:bg-[#1c2126] transition-colors cursor-default">
                    <span class="material-icons-round">remove</span>
                </button> *@
            </div>

            @* --- AI LEGEND (Góc trên bên phải) --- *@
            @* <div class="absolute top-8 right-8 p-3 rounded-xl bg-[#121416]/80 backdrop-blur-md border border-[#27353a] flex items-center gap-4 z-10 pointer-events-none">
                <div class="flex items-center gap-2">
                    <div class="size-2 rounded-full bg-primary animate-pulse"></div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[#9bb3bb]">Live Matching</span>
                </div>
                <div class="h-4 w-px bg-[#27353a]"></div>
                <div class="flex items-center gap-1">
                    <span class="material-icons-round text-[14px] text-accent-green">school</span>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-[#9bb3bb]">Universities</span>
                </div>
            </div> *@

            @* --- POPUP CARD --- *@
            @if (SelectedRoom != null)
            {
                <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-50 animate-fade-in-up">
                    <div class="w-72 bg-[#121416] border border-[#27353a] rounded-xl overflow-hidden shadow-2xl relative">
                        <button @onclick="ClosePopup" class="absolute top-2 right-2 z-20 w-6 h-6 rounded-full bg-black/50 text-white flex items-center justify-center hover:bg-black/70">
                            <span class="material-icons-round text-sm">close</span>
                        </button>
                        
                        <div class="relative h-32 w-full bg-cover bg-center bg-gray-700" 
                             style="background-image: url('@(string.IsNullOrEmpty(SelectedRoom.Image) ? "https://via.placeholder.com/300" : SelectedRoom.Image)');">
                             <div class="absolute bottom-0 left-0 right-0 h-16 bg-gradient-to-t from-[#121416] to-transparent"></div>
                        </div>

                        <div class="p-4">
                            <h3 class="text-sm font-bold text-white truncate">@SelectedRoom.Title</h3>
                            <div class="flex items-center gap-1 mt-1 text-xs text-slate-400">
                                <span class="material-icons-round text-[14px]">location_on</span>
                                <span class="truncate">@SelectedRoom.Address</span>
                            </div>
                            <div class="flex justify-between items-center mt-3">
                                <p class="text-primary font-extrabold text-lg">@FormatPrice(SelectedRoom.Price)</p>
                                <button class="text-xs bg-white/10 hover:bg-white/20 px-3 py-1 rounded text-white font-bold transition-colors">Details</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </section>
    </main>
</div>

