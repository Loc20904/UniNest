@page "/"
@using System.Net.Http.Json
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@implements IDisposable
@inject IConfiguration Configuration

@* --- 1. STYLE TÙY CHỈNH --- *@
<style>
    /* Thanh cuộn đẹp */
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #121416; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #27353a; border-radius: 10px; }

    /* Nền chấm bi cho Map khi đang load */
    .map-bg {
        background-image: radial-gradient(#27353a 1px, transparent 1px);
        background-size: 20px 20px;
    }

    /* Màu chủ đạo */
    .text-primary { color: #06b5ef; }
    .bg-primary { background-color: #06b5ef; }
    .border-primary { border-color: #06b5ef; }
    .text-accent-green { color: #7CD933; }
    .bg-accent-green { background-color: #7CD933; }

    /* Ẩn nút định vị mặc định xấu xí của GoongJS */
    .mapboxgl-ctrl-geolocate { display: none !important; }

    /* Hiệu ứng nhấp nháy cho Marker Trường Đại Học */
    .university-marker {
        animation: pulse-blue 2s infinite;
    }
    @@keyframes pulse-blue {
        0% { box-shadow: 0 0 0 0 rgba(6, 181, 239, 0.7); }
        70% { box-shadow: 0 0 0 15px rgba(6, 181, 239, 0); }
        100% { box-shadow: 0 0 0 0 rgba(6, 181, 239, 0); }
    }
</style>

@* --- 2. LAYOUT CHÍNH (Full màn hình) --- *@
<div class="h-full w-full flex flex-col bg-[#fafaf9] dark:bg-[#121416] text-slate-900 dark:text-white overflow-hidden font-sans">

    <main class="flex flex-1 overflow-hidden relative w-full h-full">
        
        @* --- A. SIDEBAR --- *@
        <aside class="w-[380px] flex flex-col border-r border-slate-200 dark:border-[#27353a] bg-[#fafaf9] dark:bg-[#121416] z-40 overflow-y-auto custom-scrollbar shrink-0">
            <div class="p-6 flex flex-col gap-6">
                @* Header Sidebar *@
                <div class="flex justify-between items-start">
                    <div>
                        <h1 class="text-2xl font-extrabold tracking-tight">Find Your Base</h1>
                        <p class="text-slate-500 dark:text-[#9bb3bb] text-sm">Campus-centric living in Da Nang</p>
                    </div>
                <div class="flex justify-between items-start">
                    <div>
                        <h1 class="text-2xl font-extrabold tracking-tight">Find Your Base</h1>
                        <p class="text-slate-500 dark:text-[#9bb3bb] text-sm">Campus-centric living in Da Nang</p>
                    </div>
                </div>
                </div>
                
                @* Search Bar *@
    <div class="relative z-50"> <label class="flex flex-col w-full">
        <div class="flex w-full items-stretch rounded-xl h-12 bg-slate-100 dark:bg-[#27353a] border border-transparent focus-within:border-primary/50 transition-all relative">
            <div class="text-slate-400 flex items-center justify-center pl-4">
                <span class="material-icons-round">search</span>
            </div>
            
            @* --- SỬA ĐỔI: Thêm @bind và @oninput --- *@
            <input @bind="SearchQuery" 
                   @oninput="OnSearchInput"
                   class="w-full border-none bg-transparent focus:ring-0 outline-none text-sm font-medium px-3 dark:text-white" 
                   placeholder="Find locations, schools..."/>

            @* Nút Xóa Search *@
            @if (!string.IsNullOrEmpty(SearchQuery))
            {
                <button @onclick="ClearSearch" class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-red-500">
                    <span class="material-icons-round text-sm">close</span>
                </button>
            }
        </div>
    </label>

    @* --- BỔ SUNG: Danh sách Gợi ý (Dropdown) --- *@
    @if (Suggestions.Any())
    {
        <ul class="absolute top-14 left-0 w-full bg-white dark:bg-[#1c2126] rounded-xl shadow-2xl border border-slate-200 dark:border-[#27353a] overflow-hidden max-h-80 overflow-y-auto custom-scrollbar animate-fade-in-up">
            @foreach (var item in Suggestions)
            {
                <li @onclick="() => SelectPlace(item)" 
                    class="px-4 py-3 hover:bg-slate-50 dark:hover:bg-[#27353a] cursor-pointer border-b border-slate-100 dark:border-[#27353a] last:border-none flex items-start gap-3 transition-colors">
                    
                    <div class="mt-1 text-slate-400">
                        <span class="material-icons-round text-sm">location_on</span>
                    </div>
                    <div>
                        <div class="text-sm font-bold text-slate-700 dark:text-slate-200">
                            @item.structured_formatting.main_text
                        </div>
                        <div class="text-xs text-slate-500 truncate">
                            @item.structured_formatting.secondary_text
                        </div>
                    </div>
                </li>
            }
        </ul>
    }
</div>

                @* --- BẮT ĐẦU: BỘ LỌC (FILTER SECTION) --- *@
@* 1. Gender Filters *@
<div class="space-y-3">
    @* Header: Icon + Text ngắn gọn *@
    <div class="flex items-center gap-2 text-slate-400 dark:text-[#6c878f]">
        <h3 class="text-xs font-bold uppercase tracking-widest">Gender</h3>
    </div>

    <div class="flex gap-2 w-full">
        @* Option: Any *@
        <div @onclick='() => SetGender("Any")'
             title="Any Gender"
             class="flex-1 h-11 items-center justify-center rounded-xl cursor-pointer transition-all border flex gap-2
                    @(SelectedGender == "Any" 
                        ? "bg-primary border-primary text-[#121416] shadow-lg shadow-primary/30" 
                        : "bg-white dark:bg-[#27353a] border-slate-200 dark:border-[#3a4e55] hover:border-primary/50 text-slate-500 dark:text-slate-300")">
            <i class="fa-solid fa-user-group text-lg"></i>
            <span class="text-xs font-bold">Any</span>
        </div>
        
        @* Option: Male *@
        <div @onclick='() => SetGender("Male")'
             title="Male Only"
             class="flex-1 h-11 items-center justify-center rounded-xl cursor-pointer transition-all border flex gap-2
                    @(SelectedGender == "Male" 
                        ? "bg-primary border-primary text-[#121416] shadow-lg shadow-primary/30" 
                        : "bg-white dark:bg-[#27353a] border-slate-200 dark:border-[#3a4e55] hover:border-primary/50 text-slate-500 dark:text-slate-300")">
            <i class="fa-solid fa-mars text-lg"></i>
            <span class="text-xs font-bold">Male</span>
        </div>
        
        @* Option: Female *@
        <div @onclick='() => SetGender("Female")'
             title="Female Only"
             class="flex-1 h-11 items-center justify-center rounded-xl cursor-pointer transition-all border flex gap-2
                    @(SelectedGender == "Female" 
                        ? "bg-primary border-primary text-[#121416] shadow-lg shadow-primary/30" 
                        : "bg-white dark:bg-[#27353a] border-slate-200 dark:border-[#3a4e55] hover:border-primary/50 text-slate-500 dark:text-slate-300")">
            <i class="fa-solid fa-venus text-lg"></i>
            <span class="text-xs font-bold">Female</span>
        </div>
    </div>
</div>

@* 2. Price Slider *@
<div class="space-y-4 pt-2">
    <div class="flex items-center justify-between">
        @* Header: Icon + Text *@
        <div class="flex items-center gap-2 text-slate-400 dark:text-[#6c878f]">
            <span class="material-icons-round text-lg">payments</span>
            <h3 class="text-xs font-bold uppercase tracking-widest">Price (VND)</h3>
        </div>
    </div>

    @* Slider Range *@
    <div class="pt-2 pb-0 px-1 relative h-6">
        @* Visual Track Background (Gray) *@
        <div class="absolute top-1/2 -translate-y-1/2 left-0 right-0 h-1 bg-slate-200 dark:bg-[#3a4e55] rounded-full z-0"></div>

        @* Visual Selected Range (Active Color) *@
        <div class="absolute top-1/2 -translate-y-1/2 h-1 bg-primary rounded-full z-0"
             style="left: @(MinPrice / 100000)%; width: @(Math.Max(0, (MaxPrice - MinPrice) / 100000))%;">
        </div>
        
        @* Slider Min *@
        <input type="range" min="0" max="10000000" step="500000" 
               @bind="MinPrice" @bind:event="oninput" @bind:after="FilterRooms"
               class="range-slider z-20" />
               
        @* Slider Max *@
        <input type="range" min="0" max="10000000" step="500000" 
               @bind="MaxPrice" @bind:event="oninput" @bind:after="FilterRooms"
               class="range-slider z-10" />
    </div>

    @* Inputs Min - Max *@
    <div class="flex items-center gap-2">
        <div class="relative flex-1">
            <input type="number" min="0" max="10000000" step="500000"
                   @bind="MinPrice" @bind:after="FilterRooms"
                   class="w-full pl-2 pr-1 py-1.5 text-xs font-bold text-center border border-slate-200 dark:border-[#27353a] rounded-lg bg-white dark:bg-[#1c2126] focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-700 dark:text-slate-200" />
            <span class="absolute right-8 top-1/2 -translate-y-1/2 text-[10px] text-slate-400 hidden">đ</span>
        </div>
        <span class="text-slate-400 font-bold">-</span>
        <div class="relative flex-1">
            <input type="number" min="0" max="10000000" step="500000"
                   @bind="MaxPrice" @bind:after="FilterRooms"
                   class="w-full pl-2 pr-1 py-1.5 text-xs font-bold text-center border border-slate-200 dark:border-[#27353a] rounded-lg bg-white dark:bg-[#1c2126] focus:ring-1 focus:ring-primary focus:border-primary outline-none text-slate-700 dark:text-slate-200" />
        </div>
    </div>
    
    @* CSS riêng cho Range Slider *@
    <style>
        .range-slider {
            -webkit-appearance: none;
            appearance: none;
            width: 100%;
            height: 100%; /* Full height to align vertically */
            background: transparent;
            pointer-events: none; /* Cho phép click xuyên qua track */
            position: absolute;
            left: 0;
            top: 0;
        }
        .range-slider::-webkit-slider-thumb {
            -webkit-appearance: none;
            pointer-events: auto; /* Bật lại click cho nút kéo */
            height: 16px;
            width: 16px;
            border-radius: 50%;
            background: #ffffff;
            border: 2px solid #06b5ef;
            cursor: pointer;
            margin-top: -6px; /* Canh giữa so với track (track cao 4px, thumb cao 16px -> -6px) */
            box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }
        .range-slider::-moz-range-thumb {
             pointer-events: auto;
             height: 16px;
             width: 16px;
             border: none;
             border-radius: 50%;
             background: #ffffff;
             border: 2px solid #06b5ef;
             cursor: pointer;
             box-shadow: 0 2px 6px rgba(0,0,0,0.2);
        }
        .range-slider::-webkit-slider-runnable-track {
            width: 100%;
            height: 4px;
            background: transparent; /* Track thật ẩn đi */
        }
    </style>
</div>

@* 3. Verification Toggle *@
<div @onclick="ToggleVerified" 
     class="flex items-center justify-between p-3 rounded-xl border cursor-pointer transition-all group
            @(IsStudentVerified 
                ? "bg-emerald-50 dark:bg-emerald-500/10 border-emerald-500/40 shadow-sm" 
                : "bg-white dark:bg-[#1c2126] border-slate-200 dark:border-[#27353a] hover:border-emerald-500/30")">
    
    <div class="flex items-center gap-3">
        <div class="size-9 rounded-full flex items-center justify-center transition-colors 
                    @(IsStudentVerified ? "bg-emerald-500 text-white shadow-md" : "bg-slate-100 dark:bg-[#27353a] text-slate-400")">
            <span class="material-icons-round text-[18px]">verified_user</span>
        </div>
        <div class="flex flex-col">
            <span class="text-xs font-bold uppercase tracking-wide @(IsStudentVerified ? "text-emerald-600 dark:text-emerald-400" : "text-slate-500 dark:text-slate-400")">
                Verified Host
            </span>
            <span class="text-[10px] text-slate-400">Student ID Check</span>
        </div>
    </div>
    
    @* Toggle Switch UI *@
    <div class="w-10 h-5 rounded-full relative transition-colors @(IsStudentVerified ? "bg-emerald-500" : "bg-slate-300 dark:bg-[#3a4e55]")">
        <div class="absolute top-0.5 size-4 bg-white rounded-full transition-all shadow-sm @(IsStudentVerified ? "right-0.5" : "left-0.5")"></div>
    </div>
</div>
                @* --- KẾT THÚC: BỘ LỌC --- *@

                @* List Rooms *@
                <div class="pt-4 border-t border-slate-200 dark:border-[#27353a]">
                    <p class="text-xs font-bold text-slate-400 mb-4">SHOWING @FilteredRooms.Count ROOMS</p>
                    @if (IsLoading)
                    {
                         <div class="flex justify-center py-4"><span class="text-slate-400 text-sm">Loading listings...</span></div>
                    }
                    else
                    {
                        <div class="flex flex-col gap-3">
                            @foreach (var room in FilteredRooms)
                            {
                                <div @onclick="() => PanToRoom(room)" class="flex gap-3 p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-[#1c2126] transition-all cursor-pointer group @(SelectedRoom?.Id == room.Id ? "bg-slate-100 dark:bg-[#1c2126]" : "")">
                                    <div class="size-16 rounded-lg bg-cover bg-center shrink-0 border border-slate-200 dark:border-[#27353a] bg-gray-600"
                                         style="background-image: url('@(string.IsNullOrEmpty(room.Image) ? "https://via.placeholder.com/150" : room.Image)');">
                                    </div>
                                    <div class="flex flex-col justify-center overflow-hidden">
                                        <h4 class="text-sm font-bold truncate group-hover:text-primary">@room.Title</h4>
                                        <p class="text-xs text-slate-500 truncate">@room.Address</p>
                                        <p class="text-sm font-extrabold text-primary mt-1">@FormatPrice(room.Price)</p>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </aside>

        @* --- B. MAP AREA --- *@
        <section class="flex-1 relative bg-[#1c2126] overflow-hidden map-bg min-w-0">
