// --- SEARCH LOGIC VARIABLES ---
    private string SearchQuery { get; set; } = "";
    private List<GoongPrediction> Suggestions = new();
   private System.Timers.Timer? _debounceTimer;
    private bool IsSearching = false;

    public class GoongAutoCompleteResponse { public List<GoongPrediction> predictions { get; set; } = new(); }
    public class GoongPrediction 
    { 
        public string description { get; set; } = ""; 
        public string place_id { get; set; } = "";
        public StructuredFormatting structured_formatting { get; set; } = new();
    }
    public class StructuredFormatting { public string main_text { get; set; } = ""; public string secondary_text { get; set; } = ""; }
    public class GoongDetailResponse { public GoongResult result { get; set; } = new(); }
    public class GoongResult { public GoongGeometry geometry { get; set; } = new(); }
    public class GoongGeometry { public GoongLocation location { get; set; } = new(); }
    public class GoongLocation { public double lat { get; set; } public double lng { get; set; } }

    // --- DTO CLASSES ---
    public class RoomDto 
    { 
        public int Id { get; set; } 
        public string? Title { get; set; } 
        public decimal Price { get; set; } 
        public double Lat { get; set; } 
        public double Lng { get; set; } 
        public string? Address { get; set; } 
        public string? Image { get; set; } 
        // --- BỔ SUNG PROPERTIES CHO FILTER ---
        public string Gender { get; set; } = "Any"; // Value: Male, Female, Any
        public bool IsVerified { get; set; } = false;
    }
    public class UniversityDto { public string Name { get; set; } = ""; public double Lat { get; set; } public double Lng { get; set; } }

    // --- LIFECYCLE ---
    protected override async Task OnInitializedAsync()
    {
        _debounceTimer = new System.Timers.Timer(500);
        _debounceTimer.AutoReset = false;
        _debounceTimer.Elapsed += async (sender, e) => await InvokeAsync(PerformSearch);
        objRef = DotNetObjectReference.Create(this);
        try
        {
            Rooms = await Http.GetFromJsonAsync<List<RoomDto>>("api/map/locations") ?? new List<RoomDto>();
            
            FilterRooms(); // Khởi tạo danh sách hiển thị
            Console.WriteLine($"[C#] API Loaded: {Rooms.Count} rooms.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[C#] API Error: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var mapKey = Configuration["GoongSettings:MapKey"];
                var apiKey = Configuration["GoongSettings:ApiKey"];
                await JSRuntime.InvokeVoidAsync("uniNestMap.setKeys", mapKey, apiKey);

                // 1. Init Map (Tọa độ ĐH Bách Khoa ĐN)
                await JSRuntime.InvokeVoidAsync("uniNestMap.initMap", objRef, "google-map", 16.0738, 108.1499, 14);

                // 2. Vẽ các trường Đại học (quan trọng)
                _ = DrawUniversities();
            }
            catch (Exception ex)
            {
                Console.WriteLine("Map Init Error: " + ex.Message);
            }
            finally 
            {
                IsMapLoaded = true;
                StateHasChanged();
            }

            // 3. Tự động định vị sau 1.5s
            await Task.Delay(1500);
            await LocateUser();
        }

        // 4. Vẽ Marker phòng trọ (sau khi có API và Map)
        if (IsMapLoaded && FilteredRooms.Any() && !_areMarkersDrawn)
        {
            await UpdateMapMarkers();
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        SearchQuery = e.Value?.ToString() ?? "";
        _debounceTimer?.Stop(); // Reset timer
        
        if (string.IsNullOrWhiteSpace(SearchQuery))
        {
            Suggestions.Clear();
            IsSearching = false;
            return;
        }
        
        IsSearching = true; // Show loading spinner
        _debounceTimer?.Start(); // Start countdown
    }
    private void ClearSearch()
    {
        SearchQuery = "";
        Suggestions.Clear();
        IsSearching = false;
    }

    private async Task PerformSearch()
    {
        try
        {
            var apiKey = Configuration["GoongSettings:ApiKey"];
            // API: Autocomplete (Có location bias ở Đà Nẵng để tìm chính xác hơn)
            var url = $"https://rsapi.goong.io/Place/AutoComplete?api_key={apiKey}&input={SearchQuery}&location=16.0738,108.1499";
            
            var result = await Http.GetFromJsonAsync<GoongAutoCompleteResponse>(url);
            Suggestions = result?.predictions ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Search Error: " + ex.Message);
        }
        finally
        {
            IsSearching = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SelectPlace(GoongPrediction item)
    {
        // 1. Ẩn gợi ý
        SearchQuery = item.structured_formatting.main_text; // Điền text vào ô
        Suggestions.Clear();

        try 
        {
            // 2. Gọi API Detail để lấy tọa độ
            var apiKey = Configuration["GoongSettings:ApiKey"];
            var url = $"https://rsapi.goong.io/Place/Detail?api_key={apiKey}&place_id={item.place_id}";
            var detail = await Http.GetFromJsonAsync<GoongDetailResponse>(url);

            if (detail?.result?.geometry?.location != null)
            {
                var lat = detail.result.geometry.location.lat;
                var lng = detail.result.geometry.location.lng;

                // 3. Bay tới đó
                await JSRuntime.InvokeVoidAsync("uniNestMap.map.flyTo", new { center = new[] { lng, lat }, zoom = 16 });

                // 4. Vẽ Marker Đỏ (Search Marker)
                await JSRuntime.InvokeVoidAsync("uniNestMap.addSearchMarker", lat, lng, item.description);
            }
        }
        catch(Exception ex)
        {
            Console.WriteLine("Select Place Error: " + ex.Message);
        }
    }
    // --- HELPERS ---
    private async Task DrawUniversities()
    {
        foreach (var uni in Universities)
        {
            // Gọi hàm addUniversityMarker bên JS
            await JSRuntime.InvokeVoidAsync("uniNestMap.addUniversityMarker", uni.Lat, uni.Lng, uni.Name);
        }
    }

    // --- LOGIC FILTERING ---
    private void SetGender(string gender)
    {
        SelectedGender = gender;
        FilterRooms();
    }
    private void ToggleVerified()
    {
        IsStudentVerified = !IsStudentVerified;
        FilterRooms();
    }
    
    private void FilterRooms()
    {
        // Ensure Min <= Max
        if (MinPrice > MaxPrice)
        {
            var temp = MinPrice;
            MinPrice = MaxPrice;
            MaxPrice = temp;
        }

        FilteredRooms = Rooms.Where(r => 
            // 1. Filter Gender (If user selects 'Male', show 'Male' + 'Any'. If 'Any', show all)
            (SelectedGender == "Any" || r.Gender == SelectedGender || r.Gender == "Any") &&
            
            // 2. Filter Verified
            (!IsStudentVerified || r.IsVerified) &&
            
            // 3. Filter Price
            (r.Price >= (decimal)MinPrice && r.Price <= (decimal)MaxPrice)
        ).ToList();

        // Trigger update map
        _ = UpdateMapMarkers();
        StateHasChanged();
    }

    private async Task UpdateMapMarkers()
    {
        if (!IsMapLoaded) return;
        
        // 1. Xóa marker cũ
        await JSRuntime.InvokeVoidAsync("uniNestMap.clearMarkers");
        
        // 2. Vẽ marker mới từ danh sách đã lọc
        await DrawMarkers();
        _areMarkersDrawn = true;
    }

    private async Task DrawMarkers()
    {
        // Chỉ vẽ những room trong FilteredRooms
        foreach (var room in FilteredRooms)
        {
            await JSRuntime.InvokeVoidAsync("uniNestMap.addMarker", objRef, room.Id, room.Lat, room.Lng, room.Title, FormatPrice(room.Price), room.Address);
        }
    }

    private async Task LocateUser()
    {
        try 
        {
            await JSRuntime.InvokeVoidAsync("uniNestMap.locateUser");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Locate Error (ignore if localhost): " + ex.Message);
        }
    }

    private async Task PanToRoom(RoomDto room)
    {
        SelectedRoom = room;
        await JSRuntime.InvokeVoidAsync("uniNestMap.map.flyTo", new { center = new[] { room.Lng, room.Lat }, zoom = 15.5 });
        await JSRuntime.InvokeVoidAsync("uniNestMap.triggerMarkerPopup", room.Id);
    }

    private void ClosePopup() => SelectedRoom = null;
    private string FormatPrice(decimal price) => price >= 1000000 ? $"{(price / 1000000):0.##}M" : $"{price:N0} đ";
    public void Dispose() {
        _debounceTimer?.Dispose();
         objRef?.Dispose();
    }
