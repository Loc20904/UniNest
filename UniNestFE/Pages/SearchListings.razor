@page "/search"
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager NavManager
@using UniNestFE.DTOs
<!-- UC14 -->
<div class="search-page-container w-full min-h-screen bg-slate-50 relative pb-20">
    <!-- Hero Section -->
    <div class="hero-section bg-white pt-16 pb-12 px-6 flex flex-col items-center justify-center text-center shadow-sm">
        <h1 class="text-4xl md:text-5xl font-extrabold text-slate-900 tracking-tight mb-8 max-w-2xl">
            Find your perfect student home in <span class="text-primary">Da Nang</span>
        </h1>

        <!-- Search Bar -->
        <div class="search-bar-wrapper w-full max-w-3xl flex items-center bg-white border-2 border-slate-100 rounded-2xl shadow-lg p-2 transition-all hover:shadow-xl hover:border-primary/30 focus-within:border-primary">
            <i class="material-icons-round text-slate-400 pl-4 text-2xl">search</i>
            <input @bind="searchQuery" @bind:event="oninput"
                   type="text" 
                   placeholder="Search by district, title, or keywords..." 
                   class="flex-1 bg-transparent border-none outline-none px-4 py-3 text-slate-700 text-lg placeholder:text-slate-400" />
            
            <button class="bg-primary hover:bg-[#05a0d3] text-white font-bold py-3 px-8 rounded-xl flex items-center gap-2 transition-all active:scale-95 shadow-md shadow-primary/20">
                <i class="material-icons-round text-lg">tune</i>
                Search
            </button>
        </div>

        <!-- Recent Searches -->
        <div class="recent-searches w-full max-w-3xl mt-6 flex items-center gap-3 flex-wrap">
            <span class="text-xs font-bold uppercase text-slate-500 tracking-wider mr-2">Quick Try:</span>
            <button class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-full text-sm font-medium transition-colors flex items-center gap-1">
                <i class="material-icons-round text-[16px] text-slate-400">history</i> Hai Chau
            </button>
            <button class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-full text-sm font-medium transition-colors flex items-center gap-1">
                <i class="material-icons-round text-[16px] text-slate-400">history</i> Studio
            </button>
            <button class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-600 rounded-full text-sm font-medium transition-colors flex items-center gap-1">
                <i class="material-icons-round text-[16px] text-slate-400">history</i> Near Duy Tan UI
            </button>
            <button class="ml-auto text-primary hover:text-[#05a0d3] text-sm font-medium transition-colors flex items-center gap-1">
                <i class="material-icons-round text-[16px]">close</i> Clear all
            </button>
        </div>
    </div>

    <!-- Main Content -->
    <div class="main-content max-w-6xl mx-auto px-6 mt-12">
        <div class="mb-10 flex items-center justify-between">
            <h2 class="text-2xl font-bold text-slate-800">
                All Available Listings
            </h2>
            <span class="text-slate-500 font-medium bg-white px-3 py-1 rounded-full shadow-sm border border-slate-100">
                @(listings?.Count ?? 0) Results
            </span>
        </div>

        @if (isLoading)
        {
            <!-- Skeleton Loading -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="bg-white rounded-3xl p-4 shadow-sm border border-slate-100 animate-pulse">
                        <div class="w-full h-56 bg-slate-200 rounded-2xl mb-4"></div>
                        <div class="h-6 bg-slate-200 rounded-md w-3/4 mb-3"></div>
                        <div class="h-4 bg-slate-200 rounded-md w-1/2 mb-4"></div>
                        <div class="flex gap-2">
                            <div class="h-8 bg-slate-200 rounded-lg w-16"></div>
                            <div class="h-8 bg-slate-200 rounded-lg w-16"></div>
                        </div>
                    </div>
                }
            </div>
        }
        else if (listings != null && listings.Count > 0)
        {
            <!-- Listings Grid -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var listing in listings)
                {
                    var imgUrl = string.IsNullOrEmpty(listing.PrimaryImageUrl) ? "default.jpg" : "https://localhost:7045" + listing.PrimaryImageUrl;
                    
                    <div class="listing-card group bg-white rounded-3xl p-3 shadow-md border border-slate-100 hover:shadow-2xl transition-all duration-300 hover:-translate-y-1 cursor-pointer" @onclick="() => NavigateToDetail(listing.ListingId)">
                        <!-- Image Container -->
                        <div class="relative w-full h-64 rounded-2xl overflow-hidden mb-4">
                            <img src="@imgUrl" alt="@listing.Title" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
                            <div class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm px-3 py-1.5 rounded-full text-xs font-bold text-slate-700 shadow-sm flex items-center gap-1">
                                <i class="material-icons-round text-[14px] text-green-500">verified</i> Verified
                            </div>
                            <div class="absolute bottom-3 right-3 bg-primary text-white font-extrabold px-4 py-2 rounded-xl shadow-lg border-2 border-white/20">
                                @listing.Price.ToString("N0") VNĐ 
                                <span class="text-[10px] font-normal opacity-80 uppercase tracking-wide block leading-none mt-1">/ month</span>
                            </div>
                        </div>
                        
                        <!-- Content -->
                        <div class="px-3 pb-3">
                            <h3 class="font-bold text-lg text-slate-800 mb-1 line-clamp-1 group-hover:text-primary transition-colors">@listing.Title</h3>
                            <p class="text-slate-500 text-sm mb-4 flex items-center gap-1 line-clamp-1">
                                <i class="material-icons-round text-[16px]">location_on</i> @listing.FullAddress
                            </p>
                            
                            <!-- Tags -->
                            <div class="flex items-center gap-2 text-xs font-semibold text-slate-600">
                                <span class="bg-slate-100 flex items-center gap-1 px-3 py-1.5 rounded-lg">
                                    <i class="material-icons-round text-[16px] text-slate-400">square_foot</i> @listing.AreaSquareMeters m²
                                </span>
                                <span class="bg-slate-100 flex items-center gap-1 px-3 py-1.5 rounded-lg">
                                    <i class="material-icons-round text-[16px] text-slate-400">wc</i> @listing.GenderPreference
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <!-- Empty State -->
            <div class="w-full bg-white rounded-3xl p-16 text-center shadow-sm border border-slate-100 flex flex-col items-center justify-center">
                <div class="w-24 h-24 bg-slate-100 rounded-full flex items-center justify-center mb-6">
                    <i class="material-icons-round text-5xl text-slate-400">search_off</i>
                </div>
                <h3 class="text-2xl font-bold text-slate-800 mb-2">No listings found</h3>
                <p class="text-slate-500 text-lg">There are currently no listings available.</p>
            </div>
        }

        <!-- Interactive Map Promo -->
        <div class="mt-16 bg-gradient-to-r from-slate-900 to-slate-800 rounded-3xl overflow-hidden shadow-2xl flex flex-col md:flex-row items-center justify-between relative">
            <div class="p-10 md:w-1/2 relative z-10">
                <h3 class="text-3xl font-extrabold text-white mb-3">Prefer a map view?</h3>
                <p class="text-slate-300 text-lg mb-8 leading-relaxed max-w-md">Explore listings geographically to find the best spot near your campus or favorite hangout.</p>
                <div class="flex gap-4">
                    <a href="/" class="bg-primary hover:bg-[#05a0d3] text-white font-bold py-3 px-8 rounded-xl flex items-center gap-2 transition-all active:scale-95 shadow-lg shadow-primary/30">
                        <i class="material-icons-round">map</i> Open Interactive Map
                    </a>
                </div>
            </div>
            <div class="md:w-1/2 h-64 md:h-auto w-full absolute md:relative right-0 top-0 bottom-0 opacity-40 md:opacity-100 group">
                <img src="https://i.imgur.com/vHq0A6v.png" alt="Map View Outline" class="w-full h-full object-cover object-left mask-image-gradient" />
                <div class="absolute inset-0 bg-primary/20 mix-blend-overlay group-hover:bg-transparent transition-all duration-700"></div>
            </div>
        </div>
    </div>
    <UniNestFE.Layout.ScrollButton />
</div>

<style>
    .text-primary { color: #00BAF2; }
    .bg-primary { background-color: #00BAF2; }
    .mask-image-gradient {
        -webkit-mask-image: linear-gradient(to right, transparent, black 30%);
        mask-image: linear-gradient(to right, transparent, black 30%);
    }
</style>
<!-- Kết thúc UC14 -->
@code {
    <!-- UC14 -->
    private string searchQuery = "";
    <!-- Kết thúc UC14 -->



    private List<SearchListingDto> listings;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadListings();
    }

    private async Task LoadListings()
    {
        isLoading = true;
        try
        {
            //đây là UC-14: Nhúng Query QueryParameter vào Url API
            var url = "api/SearchListings";
            
            listings = await Http.GetFromJsonAsync<List<SearchListingDto>>(url);
            //kết thúc UC-14
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading listings: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToDetail(int id)
    {
        NavManager.NavigateTo($"/listing/{id}");
    }
}
