@page "/admin/reports"
@using System.Net.Http.Json
@inject HttpClient Http
@layout Layout.AdminLayout

<PageTitle>Moderation Queue | UniNest Admin</PageTitle>

<div class="flex flex-col space-y-8 animate-fade-in-up">
    <!-- Header -->
    <div class="flex justify-between items-end">
        <div>
            <h3 class="text-xs font-bold text-[#515f74] uppercase tracking-widest mb-1">Safety & Moderation</h3>
            <h2 class="text-3xl font-extrabold text-[#171c1f] dark:text-white tracking-tight">Report Manage</h2>
            <p class="text-sm text-[#515f74] dark:text-slate-400 mt-2">Manage and resolve community violation reports.</p>

        </div>
        <div class="flex space-x-4">
            <div class="bg-emerald-50 text-emerald-700 px-4 py-3 rounded-lg flex items-center gap-3">
                <span class="w-2.5 h-2.5 bg-emerald-500 rounded-full animate-pulse"></span>
                <span class="text-xs font-bold uppercase tracking-widest">Resolvers Online: <span class="text-emerald-900 font-black ml-1">4 Online</span></span>
            </div>
            <div class="bg-red-50 text-red-700 px-4 py-3 rounded-lg flex items-center gap-3">
                <span class="w-2.5 h-2.5 bg-red-500 rounded-full"></span>
                <span class="text-xs font-bold uppercase tracking-widest">High Severity: <span class="text-red-900 font-black ml-1">@reports.Count(r => r.Severity == "High")</span></span>
            </div>
        </div>
    </div>

    <!-- Stats Matrix -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-white p-6 rounded-xl border border-slate-100 flex flex-col justify-center">
            <div class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-2">Pending Reports</div>
            <div class="flex items-end gap-3">
                <div class="text-4xl font-black text-[#171c1f]">@pendingReports.Count</div>
                <div class="text-xs font-bold text-red-500 mb-1">+5%</div>
            </div>
        </div>
        
        <div class="bg-white p-6 rounded-xl border-t-4 border-t-red-500 border-x-slate-100 border-b-slate-100 border-x border-b shadow-sm flex flex-col justify-center">
            <div class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-2">High Priority</div>
            <div class="flex items-end gap-3">
                <div class="text-4xl font-black text-[#171c1f]">@pendingReports.Count(r => r.Priority == "High")</div>
                <div class="text-xs font-bold text-red-500 mb-1">-2%</div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-100 flex flex-col justify-center">
            <div class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-2">Resolved Today</div>
            <div class="flex items-end gap-3">
                <div class="text-4xl font-black text-[#171c1f]">128</div>
                <div class="text-xs font-bold text-emerald-500 mb-1">+15%</div>
            </div>
        </div>

        <div class="bg-white p-6 rounded-xl border border-slate-100 flex flex-col justify-center">
            <div class="text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-2">Avg Response Time</div>
            <div class="flex items-end gap-3">
                <div class="text-4xl font-black text-[#171c1f]">14m</div>
                <div class="text-xs font-bold text-emerald-500 mb-1">-3m</div>

            </div>
        </div>
    </div>

    <!-- Navigation Tabs -->
    <div class="flex items-center gap-4 border-b border-slate-200">
        <button @onclick='() => currentTab = "Pending"' class="pb-3 text-sm font-bold uppercase tracking-widest transition-all @(currentTab == "Pending" ? "text-[#004ac6] border-b-2 border-[#004ac6]" : "text-[#515f74] hover:text-[#171c1f]")">
            Hàng đợi kiểm duyệt
        </button>
        <button @onclick='() => currentTab = "Warned"' class="pb-3 text-sm font-bold uppercase tracking-widest transition-all @(currentTab == "Warned" ? "text-[#004ac6] border-b-2 border-[#004ac6]" : "text-[#515f74] hover:text-[#171c1f]")">
            Danh sách cảnh cáo
        </button>
        <button @onclick='() => currentTab = "Banned"' class="pb-3 text-sm font-bold uppercase tracking-widest transition-all @(currentTab == "Banned" ? "text-[#004ac6] border-b-2 border-[#004ac6]" : "text-[#515f74] hover:text-[#171c1f]")">
            Danh sách đen
        </button>
    </div>

    <!-- Filter Buttons (For Pending Tab) -->
    @if (currentTab == "Pending")
    {
        <div class="flex items-center gap-2">
            <button @onclick='() => SetFilter("All")' class="px-5 py-2.5 @(currentFilter == "All" ? "bg-[#004ac6] text-white" : "bg-white text-[#515f74] border border-slate-200") text-xs font-bold rounded-full transition-colors uppercase tracking-wider">All Reports</button>
            <button @onclick='() => SetFilter("Scam Alert")' class="px-5 py-2.5 @(currentFilter == "Scam Alert" ? "bg-[#004ac6] text-white" : "bg-white text-[#515f74] border border-slate-200") text-xs font-bold rounded-full transition-colors uppercase tracking-wider">Scam Alert</button>
            <button @onclick='() => SetFilter("Fake Listing")' class="px-5 py-2.5 @(currentFilter == "Fake Listing" ? "bg-[#004ac6] text-white" : "bg-white text-[#515f74] border border-slate-200") text-xs font-bold rounded-full transition-colors uppercase tracking-wider">Fake Listing</button>
            <div class="flex-grow"></div>
            <div class="text-[#515f74] text-xs font-medium">Keyboard Shortcuts: <kbd class="px-2 py-1 bg-white border border-slate-200 rounded font-mono text-[10px] ml-1">d</kbd> <kbd class="px-2 py-1 bg-white border border-slate-200 rounded font-mono text-[10px]">w</kbd> <kbd class="px-2 py-1 bg-white border border-slate-200 rounded font-mono text-[10px]">b</kbd></div>
        </div>
    }

    <!-- Tab 1: Pending Reports Grid -->
    @if (currentTab == "Pending")
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 relative">
            @if(isLoading)
            {
                <div class="col-span-2 text-center py-10 text-[#515f74]">Đang tải dữ liệu...</div>
            }
            else if (FilteredReports.Count == 0)
            {
                 <div class="col-span-2 bg-slate-50 border outline-dashed outline-2 outline-slate-200 p-12 rounded-xl text-center">
                    <span class="material-symbols-outlined text-4xl text-emerald-500 mb-2">task_alt</span>
                    <h3 class="text-lg font-bold text-[#171c1f]">Hàng đợi đã trống</h3>
                 </div>
            }
            else
            {
                @foreach(var report in FilteredReports)
                {
                    <div class="bg-white rounded-xl border border-slate-200 flex flex-col group overflow-hidden hover:shadow-lg transition-all" @key="report.ReportId">
                        
                        <!-- Top Bar (Priority & Reporter) -->
                        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                            <div class="flex items-center gap-2">
                                @if(report.Priority == "High" || report.Priority == "Escalated")
                                {
                                    <span class="material-symbols-outlined text-red-500 text-[18px]">error</span>
                                    <span class="text-[10px] font-black text-red-600 uppercase tracking-widest">@report.Priority PRIORITY</span>
                                }
                                else if (report.Priority == "Medium")
                                {
                                    <span class="material-symbols-outlined text-amber-500 text-[18px]">chat</span>
                                    <span class="text-[10px] font-black text-amber-600 uppercase tracking-widest">@report.Priority PRIORITY</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-[#004ac6] text-[18px]">info</span>
                                    <span class="text-[10px] font-black text-[#515f74] uppercase tracking-widest">STANDARD PRIORITY</span>
                                }
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="text-[10px] text-[#515f74]">Reported by: <span class="font-bold">@report.ReporterName</span> • @GetTimeAgo(report.CreatedAt)</div>
                                <span class="px-2 py-0.5 bg-red-50 text-red-600 text-[9px] font-bold rounded">New</span>
                            </div>
                        </div>

                        <!-- Content Area -->
                        <div class="p-6 flex-grow">
                            <!-- Target Info (User vs Listing) -->
                            <div class="flex gap-4 mb-4">
                                @if (report.TargetListingId.HasValue)
                                {
                                    <div class="w-12 h-12 rounded bg-blue-100 text-[#004ac6] flex items-center justify-center shrink-0">
                                        <span class="material-symbols-outlined">real_estate_agent</span>
                                    </div>
                                    <div>
                                        <h4 class="text-sm font-bold text-[#171c1f]">@report.TargetListingTitle</h4>
                                        <p class="text-[11px] text-[#515f74] mt-0.5">Listing ID: #LC-@report.TargetListingId • Host: @report.TargetListingOwner</p>
                                    </div>
                                }
                                else if (report.TargetUserId.HasValue)
                                {
                                    <img src="@(string.IsNullOrEmpty(report.TargetUserAvatar) ? "https://ui-avatars.com/api/?name=U" : $"http://localhost:5249{report.TargetUserAvatar}")" class="w-12 h-12 rounded bg-slate-200 shrink-0 object-cover" />
                                    <div>
                                        <h4 class="text-sm font-bold text-[#171c1f]">@report.TargetUserName</h4>
                                        <p class="text-[11px] text-[#515f74] mt-0.5">User ID: @report.TargetUserId • Chat Interaction</p>
                                    </div>
                                }
                            </div>

                            <!-- Reason Badge -->
                            <div class="inline-flex items-center gap-1.5 px-3 py-1 bg-slate-100 rounded text-[10px] font-bold text-[#515f74] uppercase tracking-widest mb-4">
                                <span class="material-symbols-outlined text-[14px]">flag</span> @report.Reason
                            </div>

                            <!-- User Description Text -->
                            <div class="text-sm text-[#171c1f] italic bg-slate-50/80 p-4 rounded-lg border-l-2 border-slate-200">
                                "@(string.IsNullOrEmpty(report.Description) ? "Người dùng không cung cấp mô tả chi tiết." : report.Description)"
                            </div>
                        </div>

                        <!-- Action Buttons Row -->
                        <div class="px-6 py-4 border-t border-slate-100 bg-white flex justify-between gap-3">
                            <button @onclick='() => Resolve(report.ReportId, "Dismiss")' disabled="@isProcessing" class="flex-1 py-2.5 flex justify-center items-center gap-2 border border-slate-200 text-[#515f74] hover:bg-slate-50 rounded-lg text-[11px] font-bold uppercase tracking-widest transition-colors shadow-sm disabled:opacity-50">
                                <span class="material-symbols-outlined text-[16px]">visibility_off</span> Dismiss
                            </button>
                            <button @onclick='() => Resolve(report.ReportId, "Warn")' disabled="@isProcessing" class="flex-1 py-2.5 flex justify-center items-center gap-2 border border-amber-500 text-amber-600 hover:bg-amber-50 rounded-lg text-[11px] font-bold uppercase tracking-widest transition-colors shadow-sm disabled:opacity-50">
                                <span class="material-symbols-outlined text-[16px]">warning</span> Warn
                            </button>
                            <button @onclick='() => Resolve(report.ReportId, report.TargetListingId.HasValue ? "RemovePost" : "BanUser")' disabled="@isProcessing" class="flex-1 py-2.5 flex justify-center items-center gap-2 bg-red-600 hover:bg-red-700 text-white rounded-lg text-[11px] font-bold uppercase tracking-widest transition-colors shadow-sm shadow-red-500/20 disabled:opacity-50">
                                <span class="material-symbols-outlined text-[16px]">delete</span> @(report.TargetListingId.HasValue ? "Remove Post" : "Ban User")
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    }

    <!-- Tab 2 & 3: Warned & Banned Lists -->
    @if (currentTab != "Pending")
    {
        <div class="bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50 border-b border-slate-200">
                        <th class="px-6 py-4 text-[10px] font-extrabold uppercase tracking-widest text-[#434655]">Type</th>
                        <th class="px-6 py-4 text-[10px] font-extrabold uppercase tracking-widest text-[#434655]">Tên / Tiêu đề</th>
                        <th class="px-6 py-4 text-[10px] font-extrabold uppercase tracking-widest text-[#434655]">Thông tin thêm</th>
                        <th class="px-6 py-4 text-[10px] font-extrabold uppercase tracking-widest text-[#434655]">Warnings</th>
                        <th class="px-6 py-4 text-[10px] font-extrabold uppercase tracking-widest text-[#434655] text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @if (isLoading)
                    {
                        <tr><td colspan="5" class="p-6 text-center text-[#515f74]">Đang tải...</td></tr>
                    }
                    else if ((currentTab == "Warned" && warnedList.Count == 0) || (currentTab == "Banned" && bannedList.Count == 0))
                    {
                        <tr><td colspan="5" class="p-6 text-center text-[#515f74]">Không có dữ liệu trong danh sách này.</td></tr>
                    }
                    else
                    {
                        var listToRender = currentTab == "Warned" ? warnedList : bannedList;
                        foreach (var item in listToRender)
                        {
                            <tr class="hover:bg-slate-50 transition-colors">
                                <td class="px-6 py-4">
                                    <span class="@(item.Type == "User" ? "bg-purple-100 text-purple-700" : "bg-blue-100 text-blue-700") px-2.5 py-1 rounded text-[10px] font-bold uppercase tracking-widest">
                                        @item.Type
                                    </span>
                                </td>
                                <td class="px-6 py-4 font-bold @(currentTab == "Warned" ? "text-amber-600" : "text-black")">@item.Name</td>
                                <td class="px-6 py-4 text-xs text-[#515f74]">@item.SubInfo</td>
                                <td class="px-6 py-4">
                                    <span class="flex gap-1">
                                        @for(int i=0; i<item.Warnings; i++){ <span class="w-1.5 h-4 bg-amber-500 rounded-sm"></span> }
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    @if(currentTab == "Warned")
                                    {
                                        <button @onclick='() => RemoveWarning(item)' class="px-3 py-1.5 border border-slate-200 hover:bg-slate-100 text-slate-600 rounded text-xs font-bold mr-2">Gỡ cờ</button>
                                        <button @onclick='() => DirectBan(item)' class="px-3 py-1.5 bg-red-600 hover:bg-red-700 text-white rounded text-xs font-bold">Ban</button>
                                    }
                                    else
                                    {
                                        <button @onclick='() => Unban(item)' class="px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white rounded text-xs font-bold mr-2">Gỡ Ban</button>
                                        <button @onclick='() => DeletePermanently(item)' class="px-3 py-1.5 bg-slate-800 hover:bg-black text-white rounded text-xs font-bold">Xóa Triệt Để</button>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }

</div>

@code {
    private string currentTab = "Pending";
    private string currentFilter = "All";
    private bool isLoading = true;
    private bool isProcessing = false;


    // DTOs matching Controller
    public class ReportDto
    {
        public int ReportId { get; set; }
        public string ReporterName { get; set; } = "";
        public DateTime CreatedAt { get; set; }
        public string Priority { get; set; } = "Standard";
        public string Reason { get; set; } = "";
        public string? Description { get; set; }
        
        public int? TargetUserId { get; set; }
        public string? TargetUserName { get; set; }
        public string? TargetUserAvatar { get; set; }

        public int? TargetListingId { get; set; }
        public string? TargetListingTitle { get; set; }
        public string? TargetListingOwner { get; set; }
    }

    public class PenalizedItemDto
    {
        public string Type { get; set; } = "";
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public int Warnings { get; set; }
        public string? SubInfo { get; set; }
    }

    private List<ReportDto> pendingReports = new();
    private List<PenalizedItemDto> warnedList = new();
    private List<PenalizedItemDto> bannedList = new();

    private List<ReportDto> FilteredReports => pendingReports.Where(r => currentFilter == "All" || r.Reason == currentFilter).ToList();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            pendingReports = await Http.GetFromJsonAsync<List<ReportDto>>("api/AdminReport/pending") ?? new();
            warnedList = await Http.GetFromJsonAsync<List<PenalizedItemDto>>("api/AdminReport/warned") ?? new();
            bannedList = await Http.GetFromJsonAsync<List<PenalizedItemDto>>("api/AdminReport/banned") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error: " + ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void SetFilter(string filter)
    {
        currentFilter = filter;
    }

    private string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.Now - dt;
        if(span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if(span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return $"{(int)span.TotalDays}d ago";
    }

    // ACTIONS API BINDINGS
    private async Task Resolve(int id, string actionType)
    {
        isProcessing = true;
        try
        {
            var res = await Http.PostAsJsonAsync($"api/AdminReport/resolve/{id}", new { ActionType = actionType });
            if (res.IsSuccessStatusCode)
            {
                await LoadData(); // Reload all lists since warning may push to warned list
            }
        }
        catch { }
        finally { isProcessing = false; }
    }

    private async Task RemoveWarning(PenalizedItemDto item)
    {
        isProcessing = true;
        await Http.PostAsync($"api/AdminReport/remove-warning?type={item.Type}&id={item.Id}", null);
        await LoadData();
        isProcessing = false;
    }

    private async Task DirectBan(PenalizedItemDto item)
    {
        isProcessing = true;
        await Http.PostAsync($"api/AdminReport/ban-direct?type={item.Type}&id={item.Id}", null);
        await LoadData();
        isProcessing = false;
    }

    private async Task Unban(PenalizedItemDto item)
    {
        isProcessing = true;
        await Http.PostAsync($"api/AdminReport/unban?type={item.Type}&id={item.Id}", null);
        await LoadData();
        isProcessing = false;
    }

    private async Task DeletePermanently(PenalizedItemDto item)
    {
        isProcessing = true;
        await Http.PostAsync($"api/AdminReport/delete-permanently?type={item.Type}&id={item.Id}", null);
        await LoadData();
        isProcessing = false;
    }
}
