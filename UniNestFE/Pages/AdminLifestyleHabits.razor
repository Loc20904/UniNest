@page "/admin/habits"
@inject HttpClient Http
@inject IJSRuntime JS

<link href="css/AdminLifestyleHabits.css" rel="stylesheet" />

<div class="admin-container">
    <h2 class="admin-title">Manage Lifestyle Habits (Admin Master Data)</h2>

    <div class="add-form" style="display: flex; flex-direction: row; align-items: flex-end; gap: 16px;">
        <div class="form-group-admin" style="flex: 2; margin: 0;">
            <label>Habit Name (e.g. Non-smoker)</label>
            <input @bind="newHabit.Name" placeholder="Enter habit name..." />
        </div>
        <div class="form-group-admin" style="flex: 1; margin: 0;">
            <label>Icon</label>
            <button class="btn-icon-picker" @onclick="() => showIconModal = true" style="padding: 10px 16px; border: 1px solid #ddd; border-radius: 8px; background: white; display: flex; align-items: center; justify-content: space-between; width: 100%; height: 46px; cursor: pointer;">
                <div style="display: flex; align-items: center; gap: 8px;">
                     @if(!string.IsNullOrEmpty(newHabit.Icon)) {
                         <span class="material-icons-round" style="color: #38bdf8;">@newHabit.Icon</span>
                     } else {
                         <span class="material-icons-round" style="color: #94a3b8;">image</span>
                         <span style="color: #64748b; font-size: 14px;">Select...</span>
                     }
                </div>
                <span class="material-icons-round" style="color: #64748b;">expand_more</span>
            </button>
        </div>
        <button class="btn-add" @onclick="AddHabit" disabled="@(string.IsNullOrEmpty(newHabit.Icon) || string.IsNullOrWhiteSpace(newHabit.Name))" style="width: 140px; margin: 0;">
            + Add New
        </button>
    </div>

    @if(showIconModal)
    {
        <div class="modal-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center;" @onclick="() => showIconModal = false">
            <div class="modal-content" style="background: white; padding: 24px; border-radius: 12px; max-width: 450px; width: 90%; max-height: 80vh; overflow-y: auto; box-shadow: 0 10px 25px rgba(0,0,0,0.2);" @onclick:stopPropagation>
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; font-size: 1.25rem; font-weight: 700; color: #1e293b;">Select Lifestyle Icon</h3>
                    <button @onclick="() => showIconModal = false" style="background: transparent; border: none; cursor: pointer; color: #64748b; display: flex;"><span class="material-icons-round">close</span></button>
                </div>
                
                <div style="display: flex; flex-wrap: wrap; gap: 12px; justify-content: center;">
                    @foreach(var icon in MaterialIcons)
                    {
                        <div @onclick="() => { newHabit.Icon = icon; showIconModal = false; }" 
                             style="cursor:pointer; padding: 12px; border-radius: 8px; border: 2px solid @(newHabit.Icon == icon ? "#38bdf8" : "#e2e8f0"); background: @(newHabit.Icon == icon ? "#f0f9ff" : "white"); transition: all 0.2s; text-align: center; display: flex; align-items: center; justify-content: center; width: 55px; height: 55px;">
                            <span class="material-icons-round" style="font-size: 28px; color: @(newHabit.Icon == icon ? "#38bdf8" : "#64748b");">@icon</span>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <table class="amenity-table">
        <thead>
            <tr>
                <th class="th-id">ID</th>
                <th style="width: 60px;">Icon</th>
                <th>Name</th>
                <th class="th-actions">Actions</th>
            </tr>
        </thead>
        <tbody>
            @{
                int index = 1;
            }
            @foreach (var habit in habits)
            {
                <tr>
                    <td>#@index</td>
                    <td>
                        <div style="display: flex; justify-content: center; align-items: center; width: 36px; height: 36px; background: #f1f5f9; border-radius: 8px;">
                            <span class="material-icons-round" style="font-size: 20px; color: #38bdf8;">@habit.Icon</span>
                        </div>
                    </td>
                    <td class="font-medium-name">@habit.Name</td>
                    <td class="td-actions">
                        <button class="btn-delete" @onclick="() => DeleteHabit(habit)">
                            Delete
                        </button>
                    </td>
                </tr>
                index++;
            }
            @if (habits.Count == 0)
            {
                <tr>
                    <td colspan="3" class="empty-state-text">
                        No lifestyle habits found in database.
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <UniNestFE.Layout.ScrollButton />
</div>
<link href="css/AdminLifestyleHabits.css" rel="stylesheet" />
@code {
    public class LifestyleHabitDto { public int LifestyleHabitId { get; set; } public string Name { get; set; } public string? Icon { get; set; } }
    List<LifestyleHabitDto> habits = new();
    LifestyleHabitDto newHabit = new();
    bool showIconModal = false;

    private List<string> MaterialIcons = new List<string>
    {
        "sports_esports", "music_note", "menu_book", "fitness_center", "restaurant", 
        "movie", "palette", "self_improvement", "celebration", "cleaning_services", 
        "pets", "volume_off", "people", "directions_run", "directions_bike", 
        "local_cafe", "flight", "beach_access", "smoke_free", "smoking_rooms", 
        "nightlife", "sports_soccer", "directions_walk", "bedtime", "alarm", 
        "laptop_mac", "park", "spa", "local_bar", "volume_up", "headphones", "mic",
        "camera_alt", "brush", "sports_basketball", "sports_tennis", "pool"
    };

    private async Task AttachTokenAsync()
    {
        var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
        if (!string.IsNullOrEmpty(token))
        {
            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var res = await Http.GetFromJsonAsync<List<LifestyleHabitDto>>("https://localhost:7045/api/LifestyleHabits");
            if (res != null) habits = res;
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
    }

    async Task AddHabit()
    {
        if (string.IsNullOrWhiteSpace(newHabit.Name))
            return;

        await AttachTokenAsync();
        var response = await Http.PostAsJsonAsync("https://localhost:7045/api/LifestyleHabits", newHabit);

        if (response.IsSuccessStatusCode)
        {
            var added = await response.Content.ReadFromJsonAsync<LifestyleHabitDto>();
            if (added != null)
            {
                habits.Add(added);
                newHabit = new LifestyleHabitDto(); // Reset form
            }
        }
    }

    async Task DeleteHabit(LifestyleHabitDto habit)
    {
        await AttachTokenAsync();
        var response = await Http.DeleteAsync($"https://localhost:7045/api/LifestyleHabits/{habit.LifestyleHabitId}");

        if (response.IsSuccessStatusCode)
        {
            habits.Remove(habit);
        }
    }
}
