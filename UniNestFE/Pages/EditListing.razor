    {
        Nav.NavigateTo("/mylistings");
    }

    DotNetObjectReference<EditListing> objRef;
    bool showLargeMap = false;
    bool isMapLoading = false;
    bool mapInitialized = false;


    private async Task CloseLargeMap()
    {
        showLargeMap = false;
        StateHasChanged();
        // Re-init small map to reflect changes
        await Task.Delay(400);
        if (objRef == null) objRef = DotNetObjectReference.Create(this);
        
        await JS.InvokeVoidAsync("listingGoongMap.initMap", objRef, "map", listing.Latitude, listing.Longitude, 14);
        await DrawPois();
    }
    
    private async Task OpenLargeMap()
    {
        if (isMapLoading || showLargeMap) return;
        
        isMapLoading = true;
        showLargeMap = true;
        StateHasChanged();
        
        // Wait for modal to render element
        await Task.Delay(400); 
        
        try 
        {
            if (objRef == null) objRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("listingGoongMap.initMap", objRef, "largeSelectionMap", listing.Latitude, listing.Longitude, 16);
            await DrawPois();
        }
        finally
        {
            isMapLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (listing != null && !mapInitialized)
        {
            mapInitialized = true;
            objRef = DotNetObjectReference.Create(this);

            var mapKey = Configuration["GoongSettings:MapKey"];
            var apiKey = Configuration["GoongSettings:ApiKey"];
            await JS.InvokeVoidAsync("listingGoongMap.setKeys", mapKey, apiKey);

            await JS.InvokeVoidAsync("listingGoongMap.initMap", objRef, "map", listing.Latitude, listing.Longitude, 14);
            await DrawPois();
        }
    }
    public class NominatimLocation { public string lat { get; set; } public string lon { get; set; } }

    async Task SearchAddressOnMap()
    {
        if(string.IsNullOrWhiteSpace(listing.Address)) 
        {
            uploadErrorMessage = "Please enter an address to search.";
            return;
        }
        
        try {
            locationErrorMessage = "";
            var addressText = listing.Address ?? "";
            var districtText = listing.District ?? "";
            
            var searchStr = addressText;
            if (!string.IsNullOrWhiteSpace(districtText) && !addressText.Contains(districtText, StringComparison.OrdinalIgnoreCase))
            {
                searchStr += $", {districtText}";
            }
            if (!addressText.Contains("Da Nang", StringComparison.OrdinalIgnoreCase) && !addressText.Contains("Đà Nẵng", StringComparison.OrdinalIgnoreCase))
            {
                searchStr += ", Da Nang, Vietnam";
            }
            
            var url = $"https://nominatim.openstreetmap.org/search?q={Uri.EscapeDataString(searchStr)}&format=json&limit=1&email=uninest.noreply@gmail.com";
            
            using var client = new HttpClient();
            var result = await client.GetFromJsonAsync<List<NominatimLocation>>(url);
            
            // Fallback: nếu không tìm thấy địa chỉ cụ thể như số nhà dài, thử tìm Phường/Quận
            if (result == null || result.Count == 0)
            {
                var fallbackStr = districtText;
                if (!fallbackStr.Contains("Da Nang", StringComparison.OrdinalIgnoreCase) && !fallbackStr.Contains("Đà Nẵng", StringComparison.OrdinalIgnoreCase))
                {
                    fallbackStr += ", Da Nang, Vietnam";
                }
                
                var fallbackUrl = $"https://nominatim.openstreetmap.org/search?q={Uri.EscapeDataString(fallbackStr)}&format=json&limit=1&email=uninest.noreply@gmail.com";
                result = await client.GetFromJsonAsync<List<NominatimLocation>>(fallbackUrl);
                
                if (result != null && result.Count > 0)
                {
                    locationErrorMessage = "Không tìm thấy số nhà chính xác, bản đồ tạm hiển thị trung tâm khu vực. Bạn hãy nhấp chuột lên bản đồ để chọn lại vị trí đúng nhất nhé!";
                }
            }
            
            if(result != null && result.Count > 0)
            {
                var loc = result[0];
                listing.Latitude = double.Parse(loc.lat, System.Globalization.CultureInfo.InvariantCulture);
                listing.Longitude = double.Parse(loc.lon, System.Globalization.CultureInfo.InvariantCulture);
                
                await JS.InvokeVoidAsync("listingGoongMap.updateMarker", listing.Latitude, listing.Longitude, listing.Address);
                StateHasChanged();
            }
            else {
                 locationErrorMessage = "Could not find location on map. Try adjusting your address text.";
            }
        } catch(Exception e) { 
            Console.WriteLine(e); 
            locationErrorMessage = "Error requesting location: Bạn đang bị chặn IP do nhấn quá nhanh. Vui lòng đợi 5 phút.";
        }
    }

    private bool isGeocoding = false;
    private string locationErrorMessage = "";

    [JSInvokable]
    public async Task OnMapClick(double lat, double lng)
    {
        if (isGeocoding) return;

        try
        {
            isGeocoding = true;
            locationErrorMessage = "";
            listing.Latitude = lat;
            listing.Longitude = lng;

            var latStr = lat.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var lonStr = lng.ToString(System.Globalization.CultureInfo.InvariantCulture);
            var url = $"https://nominatim.openstreetmap.org/reverse?lat={latStr}&lon={lonStr}&format=json&email=uninest.noreply@gmail.com";

            // Khởi tạo HttpClient mới thay vì dùng Http đang chứa Bearer Token 
            // Điều này phòng tránh Nominatim từ chối request do header lạ và CORS
            using var nominatimClient = new HttpClient();
            var result = await nominatimClient.GetFromJsonAsync<NominatimResponse>(url);

            if (result != null)
            {
                // full address
                string rawDistrict = result.address?.city_district ?? result.address?.suburb ?? result.address?.city ?? "Unknown";
                listing.District = rawDistrict.Replace(" Ward", "").Trim();

                // Cập nhật marker
                await JS.InvokeVoidAsync("listingGoongMap.updateMarker", lat, lng, listing.Address);

                StateHasChanged(); // refresh UI
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
            locationErrorMessage = "Không thể tải địa chỉ! IP mạng của bạn đang bị chặn tạm thời vì thao tác quá nhanh. Xin vui lòng chờ 5 phút rồi thử lại!";
            StateHasChanged();
        }
        finally
        {
            isGeocoding = false;
        }
    }


