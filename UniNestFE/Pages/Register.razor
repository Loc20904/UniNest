@page "/register"
@inject HttpClient Http
@inject NavigationManager NavManager
@using UniNestFE.DTOs
@using System.Net.Http.Json

<PageTitle>Register | Da Nang Student Housing</PageTitle>

<div class="w-full min-h-screen overflow-y-auto custom-scrollbar flex items-center justify-center bg-[#fafaf9] dark:bg-[#121416] p-4 relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-primary/20 rounded-full blur-3xl opacity-50 mix-blend-screen"></div>
        <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent-green/10 rounded-full blur-3xl opacity-50 mix-blend-screen"></div>
    </div>

    <!-- Register Card -->
    <div class="w-full max-w-lg bg-white dark:bg-[#1c2126] rounded-2xl shadow-2xl border border-slate-200 dark:border-[#27353a] p-8 z-10 animate-fade-in-up">
        
        <!-- Header -->
        <div class="text-center mb-6">
            <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white mb-3 tracking-tight">Create Account</h1>
            <div class="inline-flex items-center gap-1.5 bg-primary/10 text-primary px-4 py-1.5 rounded-full text-xs font-semibold">
                <span class="material-icons-round text-[16px]">verified_user</span>
                Verify student status for a trusted community
            </div>
        </div>

        <!-- Form -->
        <EditForm Model="@model" OnValidSubmit="HandleSubmit" class="space-y-5">
            <DataAnnotationsValidator />

            <!-- Role Selection -->
            <div class="space-y-2">
                <label class="block text-xs font-bold uppercase text-slate-500 dark:text-slate-400 tracking-wider">I Am A:</label>
                <InputRadioGroup @bind-Value="model.Role">
                    <div class="flex bg-slate-100 dark:bg-[#27353a] p-1 rounded-xl border border-slate-200 dark:border-[#3a4e55]">
                        <label class="flex-1 text-center cursor-pointer @(model.Role == "student" ? "bg-white dark:bg-[#1c2126] text-slate-900 dark:text-white shadow-sm" : "text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200") py-2.5 rounded-lg transition-all text-sm font-bold">
                            STUDENT
                            <InputRadio class="hidden" Value="@("student")" />
                        </label>
                        <label class="flex-1 text-center cursor-pointer @(model.Role == "landlord" ? "bg-white dark:bg-[#1c2126] text-slate-900 dark:text-white shadow-sm" : "text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200") py-2.5 rounded-lg transition-all text-sm font-bold">
                            LANDLORD
                            <InputRadio class="hidden" Value="@("landlord")" />
                        </label>
                    </div>
                </InputRadioGroup>
                <ValidationMessage For="@(() => model.Role)" class="text-red-500 text-xs mt-1" />
            </div>

            <!-- Full Name -->
            <div class="space-y-2">
                <label class="text-xs font-bold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Full Name</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="material-icons-round text-slate-400 group-focus-within:text-primary transition-colors">person</span>
                    </div>
                    <InputText @bind-Value="model.FullName" class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-slate-800 dark:text-white" placeholder="Hồ Xuân Hương" />
                </div>
                <ValidationMessage For="@(() => model.FullName)" class="text-red-500 text-xs mt-1" />
            </div>

            <!-- Email -->
            <div class="space-y-2">
                <label class="text-xs font-bold uppercase text-slate-500 dark:text-slate-400 tracking-wider">University Email</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <span class="material-icons-round text-slate-400 group-focus-within:text-primary transition-colors">email</span>
                    </div>
                    <InputText @bind-Value="model.Email" type="email" class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-slate-800 dark:text-white" placeholder="student@duytan.edu.vn" />
                </div>
                <ValidationMessage For="@(() => model.Email)" class="text-red-500 text-xs mt-1" />
            </div>

            <!-- Passwords Row -->
            <div class="flex gap-4">
                <div class="flex-1 space-y-2">
                    <label class="text-xs font-bold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Password</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-icons-round text-slate-400 group-focus-within:text-primary transition-colors">lock</span>
                        </div>
                        <InputText @bind-Value="model.Password" type="password" class="w-full pl-10 pr-10 py-3 bg-slate-50 dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-slate-800 dark:text-white tracking-widest" placeholder="••••••••" />
                        <div class="absolute inset-y-0 right-0 pr-3 flex items-center cursor-pointer">
                            <span class="material-icons-round text-slate-400 hover:text-slate-600 transition-colors">visibility</span>
                        </div>
                    </div>
                    <ValidationMessage For="@(() => model.Password)" class="text-red-500 text-xs mt-1" />
                </div>
                <div class="flex-1 space-y-2">
                    <label class="text-xs font-bold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Confirm Password</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-icons-round text-slate-400 group-focus-within:text-primary transition-colors">lock</span>
                        </div>
                        <InputText @bind-Value="model.ConfirmPassword" type="password" class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-slate-800 dark:text-white tracking-widest" placeholder="••••••••" />
                    </div>
                    <ValidationMessage For="@(() => model.ConfirmPassword)" class="text-red-500 text-xs mt-1" />
                </div>
            </div>

            <!-- Terms -->
            <div class="flex items-start gap-2 pt-2">
                <div class="flex items-center h-5 mt-0.5">
                    <InputCheckbox @bind-Value="model.AcceptTerms" class="w-4 h-4 text-primary bg-slate-100 border-slate-300 rounded focus:ring-primary dark:focus:ring-primary dark:ring-offset-slate-800 focus:ring-2 dark:bg-slate-700 dark:border-slate-600 cursor-pointer" />
                </div>
                <div class="ml-1 text-xs text-slate-500 dark:text-slate-400">
                    <label class="font-medium">
                        I agree to the <a href="#" class="text-primary hover:underline">Terms of Service</a> and <a href="#" class="text-primary hover:underline">Privacy Policy</a>
                    </label>
                    <ValidationMessage For="@(() => model.AcceptTerms)" class="text-red-500 text-xs block mt-1" />
                </div>
            </div>

            <!-- Error/Success Message -->
            @if (!string.IsNullOrEmpty(ErrorMessage))
            {
                <div class="p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50 flex items-center gap-2">
                    <span class="material-icons-round text-red-500 text-sm">error</span>
                    <span class="text-xs text-red-600 dark:text-red-400">@ErrorMessage</span>
                </div>
            }

            @if (IsSuccess)
            {
                <div class="p-3 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/50 flex items-center gap-2">
                    <span class="material-icons-round text-green-500 text-sm">check_circle</span>
                    <span class="text-xs text-green-600 dark:text-green-400">Account created successfully! Redirecting...</span>
                </div>
            }

            <!-- Submit Button -->
            <button type="submit" disabled="@IsLoading" class="w-full mt-2 py-3.5 rounded-xl bg-primary hover:bg-primary/90 text-white font-bold text-sm shadow-lg shadow-primary/30 transition-all transform active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed flex items-center justify-center gap-2 uppercase tracking-wide">
                @if (IsLoading)
                {
                    <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                    <span>Creating Account...</span>
                }
                else
                {
                    <span>Create Account</span>
                    <span class="material-icons-round text-sm">person_add</span>
                }
            </button>
        </EditForm>
        
        <!-- Footer -->
        <div class="mt-6 text-center">
            <p class="text-slate-400 text-xs">
                Already have an account? 
                <a href="/login" class="text-primary font-bold hover:underline">Login here</a>
            </p>
        </div>
    </div>
</div>

<style>
    .text-primary { color: #06b5ef; }
    .bg-primary { background-color: #06b5ef; }
    .bg-accent-green { background-color: #7CD933; }
    .animate-fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private RegisterDto model = new();
    private string ErrorMessage = "";
    private bool IsLoading = false;
    private bool IsSuccess = false;

    private async Task HandleSubmit()
    {
        ErrorMessage = "";
        IsLoading = true;
        IsSuccess = false;
        
        try
        {
            // API Endpoint (Make sure this matches your actual Auth backend API route)
            var response = await Http.PostAsJsonAsync("api/Auth/register", model);
            
            if (response.IsSuccessStatusCode)
            {
                IsSuccess = true;
                StateHasChanged(); // Render the success message

                // Wait 1.5 seconds so the user can see the success message
                await Task.Delay(1500);
                
                // Redirect user to login page
                NavManager.NavigateTo("/login");
            }
            else
            {
                var content = await response.Content.ReadAsStringAsync();
                ErrorMessage = "Registration failed. Please check your inputs.";
                if(content.Contains("message") || content.Contains("Email already exists"))
                {
                   ErrorMessage = "This email is already registered or invalid inputs."; // Adjust based on your backend response format
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred. Please try again.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }
}
