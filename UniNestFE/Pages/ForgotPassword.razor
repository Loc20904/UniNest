@page "/forgot-password"
@inject HttpClient Http
@inject NavigationManager NavManager
@using UniNestFE.DTOs
@using System.Net.Http.Json

<PageTitle>Forgot Password | Da Nang Student Housing</PageTitle>

<div class="w-full min-h-screen overflow-y-auto custom-scrollbar flex items-center justify-center bg-[#fafaf9] dark:bg-[#121416] p-4 relative overflow-hidden">
    <!-- Background Decor -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
        <div class="absolute -top-32 -left-32 w-96 h-96 bg-primary/20 rounded-full blur-3xl opacity-50 mix-blend-screen"></div>
        <div class="absolute bottom-10 right-10 w-80 h-80 bg-accent-green/10 rounded-full blur-3xl opacity-50 mix-blend-screen"></div>
    </div>

    <!-- Forgot Password Card -->
    <div class="w-full max-w-[440px] bg-white dark:bg-[#1c2126] rounded-2xl shadow-2xl border border-slate-200 dark:border-[#27353a] relative z-10 animate-fade-in-up flex flex-col overflow-hidden">
        
        <!-- Top accent line -->
        <div class="absolute top-0 left-0 w-32 h-1.5 bg-primary rounded-br-lg"></div>

        <div class="p-8 pb-6">
            <!-- Icon -->
            <div class="w-10 h-10 rounded-full bg-primary/10 flex items-center justify-center mb-6">
                <span class="material-icons-round text-primary">lock_reset</span>
            </div>

            <!-- Header -->
            <div class="mb-6">
                <h1 class="text-2xl font-extrabold text-slate-900 dark:text-white mb-3 tracking-tight">Forgot Password?</h1>
                <p class="text-slate-500 dark:text-slate-400 text-sm leading-relaxed">
                    Enter the email address associated with your student housing account. We'll send you a secure link to reset your password.
                </p>
            </div>

            <!-- Form -->
            <EditForm Model="@model" OnValidSubmit="HandleSubmit" class="space-y-4">
                <DataAnnotationsValidator />

                <!-- Email -->
                <div class="space-y-2">
                    <label class="text-xs font-bold uppercase text-slate-500 dark:text-slate-400 tracking-wider">Student Email</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <span class="material-icons-round text-slate-400 group-focus-within:text-primary transition-colors">email</span>
                        </div>
                        <InputText @bind-Value="model.Email" type="email" class="w-full pl-10 pr-4 py-3 bg-slate-50 dark:bg-[#27353a] border border-slate-200 dark:border-[#3a4e55] rounded-xl focus:ring-2 focus:ring-primary/50 focus:border-primary outline-none transition-all text-slate-800 dark:text-white text-sm" placeholder="e.g. student@university.edu.vn" />
                    </div>
                    <ValidationMessage For="@(() => model.Email)" class="text-red-500 text-xs mt-1" />
                </div>

                <!-- Tip Box -->
                <div class="bg-sky-50 dark:bg-sky-900/20 border border-sky-100 dark:border-sky-800/30 rounded-lg p-3 flex items-start gap-2 mt-4">
                    <span class="material-icons-round text-sky-500 text-base mt-0.5">info</span>
                    <p class="text-xs text-sky-600 dark:text-sky-400 leading-relaxed font-medium">
                        Tip: For security, the reset link will expire in <span class="font-bold">15 minutes</span>.
                    </p>
                </div>

                <!-- Error/Success Message -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="p-3 rounded-lg bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800/50 flex items-center gap-2 mt-2">
                        <span class="material-icons-round text-red-500 text-sm">error</span>
                        <span class="text-xs text-red-600 dark:text-red-400">@ErrorMessage</span>
                    </div>
                }

                @if (IsSuccess)
                {
                    <div class="p-3 rounded-lg bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800/50 flex flex-col gap-1 mt-2">
                        <div class="flex items-center gap-2">
                            <span class="material-icons-round text-green-500 text-sm">check_circle</span>
                            <span class="text-sm font-bold text-green-700 dark:text-green-400">Check your email</span>
                        </div>
                        <p class="text-xs text-green-600 dark:text-green-500 ml-6">We've sent password reset instructions to your address.</p>
                    </div>
                }

                <!-- Submit Button -->
                <button type="submit" disabled="@(IsLoading || IsSuccess)" class="w-full mt-4 py-3 rounded-xl bg-[#4eb1d1] hover:bg-[#3ca4c5] dark:bg-primary dark:hover:bg-primary/90 text-white font-bold text-sm shadow-md transition-all transform active:scale-95 disabled:opacity-70 disabled:cursor-not-allowed flex items-center justify-center gap-2 tracking-wide">
                    @if (IsLoading)
                    {
                        <div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>
                        <span>Sending Link...</span>
                    }
                    else
                    {
                        <span>Send Reset Link</span>
                    }
                </button>
            </EditForm>
            
            <!-- Back to Login -->
            <div class="mt-6 text-center">
                <a href="/login" class="inline-flex items-center gap-1 text-slate-500 dark:text-slate-400 hover:text-slate-700 dark:hover:text-slate-200 text-xs font-medium transition-colors">
                    <span class="material-icons-round text-[14px]">arrow_back</span>
                    Back to Login
                </a>
            </div>
        </div>

        <!-- Card Footer -->
        <div class="bg-slate-50 dark:bg-[#161a1e] border-t border-slate-100 dark:border-[#27353a] px-8 py-4 flex items-center justify-between mt-auto">
            <span class="text-[10px] text-slate-400 dark:text-slate-500 tracking-wider">Student Housing Da Nang © 2024</span>
            <div class="flex items-center gap-2 text-slate-300 dark:text-slate-600">
                <span class="material-icons-round text-[14px] cursor-pointer hover:text-slate-400 transition-colors">help_outline</span>
                <span class="material-icons-round text-[14px] cursor-pointer hover:text-slate-400 transition-colors">language</span>
            </div>
        </div>
    </div>
</div>

<style>
    .text-primary { color: #06b5ef; }
    .bg-primary { background-color: #06b5ef; }
    .bg-accent-green { background-color: #7CD933; }
    .animate-fade-in-up { animation: fadeInUp 0.5s ease-out forwards; }
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    private ForgotPasswordDto model = new();
    private string ErrorMessage = "";
    private bool IsLoading = false;
    private bool IsSuccess = false;

    private async Task HandleSubmit()
    {
        ErrorMessage = "";
        IsLoading = true;
        IsSuccess = false;
        
        try
        {
            // API Endpoint for forgot password
            var response = await Http.PostAsJsonAsync("api/Auth/forgot-password", model);
            
            if (response.IsSuccessStatusCode)
            {
                IsSuccess = true;
                model.Email = ""; // Clear input on success
            }
            else
            {
                try 
                {
                    var errorObj = await response.Content.ReadFromJsonAsync<dynamic>();
                    ErrorMessage = errorObj?.GetProperty("message").GetString() ?? "Failed to send reset link. Please verify your email address.";
                }
                catch
                {
                    ErrorMessage = "Failed to send reset link. Please verify your email address.";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = "An unexpected error occurred. Please try again.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            IsLoading = false;
        }
    }
}
