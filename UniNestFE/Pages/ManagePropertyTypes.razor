@page "/admin/property-types"
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container py-8 max-w-4xl mx-auto px-4">
    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white">Manage Property Types</h1>
            <p class="text-slate-500 dark:text-slate-400">Define the categories for listing accommodations.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center p-12">
            <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-slate-800 rounded-3xl border border-slate-100 dark:border-slate-700 shadow-xl overflow-hidden mb-8">
            <table class="w-full text-left">
                <thead class="bg-slate-50 dark:bg-slate-700/50 border-b border-slate-100 dark:border-slate-700">
                    <tr>
                        <th class="px-6 py-4 font-bold text-slate-700 dark:text-slate-200">ID</th>
                        <th class="px-6 py-4 font-bold text-slate-700 dark:text-slate-200">Property Type Name</th>
                        <th class="px-6 py-4 font-bold text-slate-700 dark:text-slate-200 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50 dark:divide-slate-700">
                    @foreach (var pType in propertyTypes)
                    {
                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-700/30 transition-colors">
                            <td class="px-6 py-4 text-slate-400 dark:text-slate-500 font-mono text-sm">#@pType.PropertyTypeId</td>
                            <td class="px-6 py-4 font-bold text-slate-800 dark:text-slate-100">@pType.Name</td>
                            <td class="px-6 py-4 text-right">
                                <button @onclick="() => DeletePropertyType(pType.PropertyTypeId)" class="text-red-400 hover:text-red-600 p-2 transition-colors">
                                    <i class="material-icons text-xl">delete</i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="bg-[#00BAF2]/5 dark:bg-[#00BAF2]/10 border border-[#00BAF2]/10 dark:border-[#00BAF2]/20 rounded-3xl p-6">
            <h3 class="text-lg font-bold text-slate-800 dark:text-slate-100 mb-4 flex items-center gap-2">
                <i class="material-icons text-[#00BAF2]">add_circle</i> Add New Property Type
            </h3>
            <div class="flex gap-3">
                <input type="text" @bind="newTypeName" 
                       class="flex-1 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-700 rounded-2xl px-4 py-3 text-slate-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-[#00BAF2] transition-all" 
                       placeholder="e.g. Studio, Shared Room, Apartment..." />
                <button @onclick="AddPropertyType" class="bg-[#00BAF2] text-white px-8 py-3 rounded-2xl font-bold hover:bg-[#05a0d3] transition-all transform active:scale-95 shadow-lg shadow-[#00BAF2]/20">
                    Add Type
                </button>
            </div>

            @if (showSuccessToast)
            {
                <div class="mt-4 p-3 bg-green-500/10 border border-green-500/20 text-green-600 dark:text-green-400 rounded-xl flex items-center gap-2 animate-fade-in">
                    <i class="material-icons text-sm">check_circle</i>
                    <span class="text-sm font-bold">Property type added successfully!</span>
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <p class="text-red-500 text-sm mt-3 font-medium">@errorMessage</p>
            }
        </div>
    }
</div>

<style>
    .animate-fade-in {
        animation: fadeIn 0.3s ease-out;
    }
    @System.Text.RegularExpressions.Regex.Unescape("@")keyframes fadeIn {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

@code {
    public class PropertyType
    {
        public int PropertyTypeId { get; set; }
        public string Name { get; set; } = "";
    }

    private List<PropertyType> propertyTypes = new();
    private string newTypeName = "";
    private string errorMessage = "";
    private bool isLoading = true;
    private bool showSuccessToast = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPropertyTypes();
    }

    private async Task LoadPropertyTypes()
    {
        isLoading = true;
        try 
        {
            propertyTypes = await Http.GetFromJsonAsync<List<PropertyType>>("api/PropertyTypes") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task AddPropertyType()
    {
        if (string.IsNullOrWhiteSpace(newTypeName))
        {
            errorMessage = "Name cannot be empty.";
            return;
        }

        var newType = new PropertyType { Name = newTypeName };
        var response = await Http.PostAsJsonAsync("api/PropertyTypes", newType);

        if (response.IsSuccessStatusCode)
        {
            newTypeName = "";
            errorMessage = "";
            showSuccessToast = true;
            await LoadPropertyTypes();
            StateHasChanged();
            
            // Tự động ẩn thông báo sau 3 giây
            _ = Task.Delay(3000).ContinueWith(_ => {
                showSuccessToast = false;
                InvokeAsync(StateHasChanged);
            });
        }
        else
        {
            errorMessage = "Failed to add property type.";
        }
    }

    private async Task DeletePropertyType(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this property type?");
        if (!confirmed) return;

        var response = await Http.DeleteAsync($"api/PropertyTypes/{id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadPropertyTypes();
        }
    }
}
