@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime

<div class="text-[#171c1f] min-h-screen bg-[#f6fafe] font-body" style="font-family: 'Inter', sans-serif;">
    <!-- SideNavBar Anchor -->
    <aside class="h-screen w-64 fixed left-0 top-0 overflow-y-auto bg-[#f0f4f8] dark:bg-slate-900 flex flex-col py-6 shadow-sm z-50">
        <div class="px-6 mb-10">
            <h1 class="text-xl font-bold text-[#004ac6] dark:text-blue-400">UniNest DashBoard</h1>
            <p class="text-xs text-[#515f74] mt-1">Admin Management System</p>
        </div>

        <nav class="flex-grow space-y-1">
            <a href="/admin/dashboard" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] dark:hover:text-blue-300 pl-5 py-3 transition-colors hover:bg-[#f6fafe] dark:hover:bg-slate-800">
                <span class="material-symbols-outlined mr-3" data-icon="dashboard">dashboard</span>
                <span class="text-sm font-medium">Dashboard</span>
            </a>
            
            <a href="/admin/student-verification" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] dark:hover:text-blue-300 pl-5 py-3 transition-colors hover:bg-[#f6fafe] dark:hover:bg-slate-800">
                <span class="material-symbols-outlined mr-3" data-icon="verified_user">verified_user</span>
                <span class="text-sm font-medium">Student Verification</span>
            </a>

            <a href="/admin/reports" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] dark:hover:text-blue-300 pl-5 py-3 transition-colors hover:bg-[#f6fafe] dark:hover:bg-slate-800">

                <span class="material-symbols-outlined mr-3" data-icon="report">report</span>
                <span class="text-sm font-medium">Report Manage</span>
            </a>

            <a href="/admin/listings" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] dark:hover:text-blue-300 pl-5 py-3 transition-colors hover:bg-[#f6fafe] dark:hover:bg-slate-800">
                <span class="material-symbols-outlined mr-3" data-icon="fact_check">fact_check</span>
                <span class="text-sm font-medium">Listing Management</span>
            </a>
            
            <a href="/admin/settings" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] dark:hover:text-blue-300 pl-5 py-3 transition-colors hover:bg-[#f6fafe] dark:hover:bg-slate-800">
                <span class="material-symbols-outlined mr-3" data-icon="settings">settings</span>
                <span class="text-sm font-medium">System Settings</span>
            </a>
        </nav>

        <div class="px-6 mt-8">
            <button class="w-full bg-gradient-to-br from-[#004ac6] to-[#2563eb] text-white py-3 rounded-xl font-bold text-sm shadow-md active:scale-95 transition-transform flex items-center justify-center gap-2">
                <span class="material-symbols-outlined text-[18px]">download</span> Export Report
            </button>
        </div>

        <div class="mt-auto px-1 space-y-1">
            <a href="/admin/help" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] pl-5 py-3 transition-colors">
                <span class="material-symbols-outlined mr-3" data-icon="help">help</span>
                <span class="text-sm font-medium">Help Center</span>
            </a>
            <a href="/" class="flex items-center text-[#515f74] dark:text-slate-400 hover:text-[#004ac6] pl-5 py-3 transition-colors text-[#ba1a1a]">
                <span class="material-symbols-outlined mr-3 text-[#ba1a1a]" data-icon="logout">logout</span>
                <span class="text-sm font-medium text-[#ba1a1a]">Logout</span>
            </a>
        </div>
    </aside>

    <!-- TopNavBar Anchor -->
    <header class="fixed top-0 right-0 left-64 h-16 z-40 bg-[#f6fafe]/80 dark:bg-slate-950/80 backdrop-blur-xl border-b border-[#dfe3e7]">
        <div class="flex justify-between items-center px-8 w-full h-full">
            <div class="flex items-center w-1/3">
                <div class="relative w-full">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#515f74] text-lg" data-icon="search">search</span>
                    <input type="text" placeholder="Search accounts, students, listings..." class="w-full pl-10 pr-4 py-2 bg-[#dfe3e7] rounded-full border-none focus:ring-2 focus:ring-[#004ac6] text-sm transition-all outline-none" />
                </div>
            </div>

            <div class="flex items-center space-x-6">
                <div class="flex items-center space-x-2">
                    <button class="hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-full p-2 transition-all relative">
                        <span class="material-symbols-outlined text-[#515f74]" data-icon="notifications">notifications</span>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-[#ba1a1a] rounded-full"></span>
                    </button>
                    <button class="hover:bg-slate-200/50 dark:hover:bg-slate-800/50 rounded-full p-2 transition-all">
                        <span class="material-symbols-outlined text-[#515f74]" data-icon="mail">mail</span>
                    </button>
                    <button @onclick="ToggleTheme" class="p-2 rounded-full bg-slate-100 dark:bg-[#27353a] text-slate-500 dark:text-emerald-400 hover:scale-110 transition-transform">
                        @if (IsDarkMode)
                        {
                            <span class="material-icons-round text-xl">light_mode</span>
                        }
                        else
                        {
                            <span class="material-icons-round text-xl">dark_mode</span>
                        }
                    </button>
                </div>
                
                <div class="h-8 w-px bg-[#c3c6d7]/30 mx-2"></div>
                
                <div class="flex items-center space-x-4">
                    <button class="text-xs font-bold tracking-wider uppercase text-[#515f74] hover:text-[#004ac6] transition-colors">Support</button>
                    <button class="bg-[#004ac6] text-white px-5 py-2 rounded-full text-xs font-bold tracking-wider uppercase hover:opacity-90 transition-opacity">Create Notice</button>
                    <img src="https://ui-avatars.com/api/?name=Admin&background=004ac6&color=fff" 
                        alt="Admin Avatar" class="w-10 h-10 rounded-full object-cover ring-2 ring-white shadow-sm" />
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content Canvas -->
    <main class="ml-64 mt-16 p-10 space-y-10">
        @Body
    </main>
</div>
@code {
    private bool IsDarkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JSRuntime.InvokeAsync<string>("eval", "localStorage.getItem('theme')");
            if (theme == "dark")
            {
                IsDarkMode = true;
                StateHasChanged();
                await JSRuntime.InvokeVoidAsync("uniNestMap.toggleTheme", true);
            }
        }
    }

    private async Task ToggleTheme()
    {
        IsDarkMode = !IsDarkMode;
        await JSRuntime.InvokeVoidAsync("uniNestMap.toggleTheme", IsDarkMode);
    }
}