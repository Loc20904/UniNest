@inherits LayoutComponentBase

<div class="h-screen flex flex-col">
    <header class="flex items-center justify-between border-b border-solid border-slate-200 dark:border-[#27353a] px-6 py-3 bg-background-light dark:bg-background-dark z-50">
        <div class="flex items-center gap-4">
            <div class="size-8 text-primary">
                <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M44 4H30.6666V17.3334H17.3334V30.6666H4V44H44V4Z" fill="currentColor"></path>
                </svg>
            </div>
            <h2 class="text-lg font-extrabold leading-tight tracking-tight">
                RoomFinder <span class="text-primary font-medium">Da Nang</span>
            </h2>
        </div>

        <div class="flex items-center gap-8">
            <nav class="hidden md:flex items-center gap-8">
                <a class="text-sm font-semibold hover:text-primary transition-colors" href="#">Explore</a>
                <a class="text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1" href="#">
                    AI Matching
                    <span class="text-[10px] bg-primary/20 text-primary px-1.5 py-0.5 rounded-full uppercase tracking-widest">New</span>
                </a>
                <a class="text-sm font-semibold hover:text-primary transition-colors" href="#">My Favorites</a>
            </nav>
            <div class="h-6 w-px bg-slate-200 dark:bg-[#27353a] mx-2"></div>
            <button class="flex items-center justify-center rounded-xl h-10 px-5 bg-primary text-background-dark text-sm font-bold transition-transform active:scale-95">
                List Your Room
            </button>
            <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border-2 border-primary/30 bg-slate-700"></div>
        </div>
    </header>

    <main class="flex flex-1 overflow-hidden">
        @Body
    </main>
</div>