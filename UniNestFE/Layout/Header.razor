@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.WebAssembly
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Routing
@using System.Security.Claims

@inject IJSRuntime JSRuntime
@inject NavigationManager NavManager

<header class="flex items-center justify-between border-b border-solid border-slate-200 dark:border-[#27353a] px-6 py-3 bg-background-light dark:bg-background-dark z-50">
    @* Logo Section *@
    <div class="flex items-center gap-4 cursor-pointer" @onclick='() => NavManager.NavigateTo("/")'>
        <div class="size-8 text-primary">
            <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                <path d="M44 4H30.6666V17.3334H17.3334V30.6666H4V44H44V4Z" fill="currentColor"></path>
            </svg>
        </div>
        <h2 class="text-lg font-extrabold leading-tight tracking-tight">
            UniNest <span class="text-primary font-medium">Da Nang</span>
        </h2>
    </div>

    <div class="flex items-center gap-8">
        @* Navigation Links *@
        <nav class="hidden md:flex items-center gap-8">
            <NavLink href="advanced-search" class="text-slate-500 hover:text-primary transition-transform hover:scale-110 flex items-center gap-1" title="Advanced Search">
                <span class="material-icons-round text-xl">search</span>
            </NavLink>
            
            <NavLink href="" Match="NavLinkMatch.All" class="text-sm font-semibold hover:text-primary transition-colors">
                Explore
            </NavLink>

            <AuthorizeView>
    <Authorized>
        @if (context.User.Claims.FirstOrDefault(c => c.Type == "IsPremium")?.Value == "True")
        {
            @* Người dùng đã có Premium: Đi đến trang AI *@
            <NavLink href="ai-matching" class="text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1">
                AI Matching
                <span class="text-[10px] bg-primary/20 text-primary px-1.5 py-0.5 rounded-full uppercase tracking-widest">New</span>
            </NavLink>
        }
        else
        {
            @* Người dùng ĐÃ đăng nhập nhưng CHƯA có Premium: Chuyển hướng đến trang nạp tiền *@
            <NavLink href="premium-info" class="text-sm font-semibold text-slate-500 hover:text-primary transition-colors flex items-center gap-1" title="Upgrade to use this feature">
                AI Matching
                <span class="text-[10px] bg-amber-100 text-amber-600 px-1.5 py-0.5 rounded-full uppercase tracking-widest">Upgrade</span>
            </NavLink>
        }
        
        <NavLink href="chat" class="text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1">
            Messages
        </NavLink>
    </Authorized>
    <NotAuthorized>
        @* Người dùng CHƯA đăng nhập: Cũng cho click nhưng dẫn đến trang giới thiệu Premium *@
        <NavLink href="premium-info" class="text-sm font-semibold text-slate-500 hover:text-primary transition-colors flex items-center gap-1">
            AI Matching
            <span class="text-[10px] bg-gray-200 text-gray-500 px-1.5 py-0.5 rounded-full uppercase tracking-widest">Premium</span>
        </NavLink>
    </NotAuthorized>
</AuthorizeView>
        </nav>

        <div class="h-6 w-px bg-slate-200 dark:bg-[#27353a] mx-2"></div>

        @* Theme Toggle *@
        <button @onclick="ToggleTheme" class="p-2 rounded-full bg-slate-100 dark:bg-[#27353a] text-slate-500 dark:text-emerald-400 hover:scale-110 transition-transform">
            <span class="material-icons-round text-xl">@(IsDarkMode ? "light_mode" : "dark_mode")</span>
        </button>

        @* Authentication Section *@
        <AuthorizeView>
            <Authorized>
                <button class="flex items-center justify-center rounded-xl h-10 px-5 bg-primary text-background-dark text-sm font-bold transition-transform active:scale-95 hover:brightness-110" 
                        @onclick='() => NavManager.NavigateTo("/create-listing")'>
                    List Your Room
                </button>
                
                <div class="relative">
                    <button @onclick="ToggleUserMenu" aria-label="User menu" class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border-2 border-primary/30 bg-slate-700 cursor-pointer transition-transform hover:scale-105 appearance-none focus:outline-none focus:ring-2 focus:ring-primary/50 shadow-sm"
                            style="background-image: url('https://ui-avatars.com/api/?name=@(context.User.FindFirst("FullName")?.Value ?? "User")&background=06b5ef&color=fff');" title="@(context.User.FindFirst("FullName")?.Value ?? "User")">
                    </button>

                    @if (isUserMenuOpen)
                    {
                        <div class="absolute right-0 mt-2 w-56 bg-white dark:bg-[#1c2126] rounded-xl shadow-xl py-2 border border-slate-200 dark:border-[#27353a] z-50 animate-fade-in-up">
                            <div class="px-4 py-3 border-b border-slate-200 dark:border-[#27353a] mb-1">
                                <p class="text-xs text-slate-500 font-medium uppercase tracking-wider">Signed in as</p>
                                <p class="text-sm font-bold text-slate-900 dark:text-white truncate mt-0.5">@(context.User.FindFirst("FullName")?.Value ?? "User")</p>
                            </div>
                                
                            <a href="profile" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                <span class="material-icons-round text-slate-400 text-lg">person</span>
                                <span>My Profile</span>
                            </a>
                            <a href="myListings" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                <span class="material-icons-round text-slate-400 text-lg">list_alt</span>
                                <span>My Listings</span>
                            </a>
                            <a href="favorites" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                <span class="material-icons-round text-slate-400 text-lg">favorite_border</span>
                                <span>Save Listing</span>
                            </a>

                            @if (context.User.IsInRole("Admin") || context.User.IsInRole("admin"))
                            {
                                <div class="h-px bg-slate-100 dark:bg-[#27353a] my-1 mx-2"></div>
                                <a href="admin/amenities" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                    <span class="material-icons-round text-slate-400 text-lg">bolt</span>
                                    <span>Add Amenities</span>
                                </a>
                                <a href="admin/habits" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                    <span class="material-icons-round text-slate-400 text-lg">accessibility</span>
                                    <span>Add Lifestyle Habits</span>
                                </a>
                                <a href="admin/property-types" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                    <span class="material-icons-round text-slate-400 text-lg">category</span>
                                    <span>Manage Property Types</span>
                                </a>
                            }

                            <div class="h-px bg-slate-200 dark:bg-[#27353a] my-1 mx-2"></div>

                            <a href="settings" class="w-full text-left px-4 py-2 text-sm text-slate-700 dark:text-gray-200 hover:bg-slate-50 dark:hover:bg-slate-800 transition-colors flex items-center gap-3">
                                <span class="material-icons-round text-slate-400 text-lg">settings</span>
                                <span>Settings</span>
                            </a>
                                
                            <button @onclick="Logout" class="w-full text-left px-4 py-2 text-sm text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors flex items-center gap-3">
                                <span class="material-icons-round text-red-500/70 text-lg">logout</span>
                                <span>Logout</span>
                            </button>
                        </div>
                    }
                </div>
            </Authorized>
            <NotAuthorized>
                <a href="login" class="text-sm font-bold text-slate-500 hover:text-primary mr-4">Sign In</a>
                <a href="register" class="flex items-center justify-center rounded-xl h-10 px-5 bg-slate-800 text-white text-sm font-bold hover:bg-slate-700 transition-all">
                    Join Now
                </a>
            </NotAuthorized>
        </AuthorizeView>
    </div>
</header>

@code {
    private bool isUserMenuOpen = false;
    private bool IsDarkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var theme = await JSRuntime.InvokeAsync<string>("localStorage.getItem", "theme");
            if (theme == "dark")
            {
                IsDarkMode = true;
                StateHasChanged();
                await JSRuntime.InvokeVoidAsync("uniNestMap.toggleTheme", true);
            }
        }
    }

    private void ToggleUserMenu()
    {
        isUserMenuOpen = !isUserMenuOpen;
    }

    private async Task Logout()
    {
        isUserMenuOpen = false;
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "authToken");
        await JSRuntime.InvokeVoidAsync("localStorage.removeItem", "userFullName");
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    private async Task ToggleTheme()
    {
        IsDarkMode = !IsDarkMode;
        var themeValue = IsDarkMode ? "dark" : "light";
        await JSRuntime.InvokeVoidAsync("localStorage.setItem", "theme", themeValue);
        await JSRuntime.InvokeVoidAsync("uniNestMap.toggleTheme", IsDarkMode);
    }
}