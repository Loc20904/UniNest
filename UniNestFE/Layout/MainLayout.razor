@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization

<div class="h-screen flex flex-col bg-background-light dark:bg-background-dark text-slate-900 dark:text-white font-display">

    <header class="flex items-center justify-between border-b border-solid border-slate-200 dark:border-[#27353a] px-6 py-3 bg-background-light dark:bg-background-dark z-50">
        <div class="flex items-center gap-4 cursor-pointer" @onclick='() => NavigationManager.NavigateTo("/")'>
            <div class="size-8 text-primary">
                <svg fill="none" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                    <path d="M44 4H30.6666V17.3334H17.3334V30.6666H4V44H44V4Z" fill="currentColor"></path>
                </svg>
            </div>
            <h2 class="text-lg font-extrabold leading-tight tracking-tight">
                UniNest <span class="text-primary font-medium">Da Nang</span>
            </h2>
        </div>

        <div class="flex items-center gap-8">
            <nav class="hidden md:flex items-center gap-8">
                <NavLink href="" Match="NavLinkMatch.All" class="text-sm font-semibold hover:text-primary transition-colors">
                    Explore
                </NavLink>
                <NavLink href="ai-matching" class="text-sm font-semibold hover:text-primary transition-colors flex items-center gap-1">
                    AI Matching
                    <span class="text-[10px] bg-primary/20 text-primary px-1.5 py-0.5 rounded-full uppercase tracking-widest">New</span>
                </NavLink>
            </nav>

            <div class="h-6 w-px bg-slate-200 dark:bg-[#27353a] mx-2"></div>

            <AuthorizeView>
                <Authorized>
                    <button class="flex items-center justify-center rounded-xl h-10 px-5 bg-primary text-background-dark text-sm font-bold transition-transform active:scale-95 hover:brightness-110">
                        List Your Room
                    </button>
                    <div class="bg-center bg-no-repeat aspect-square bg-cover rounded-full size-10 border-2 border-primary/30 cursor-pointer"
                         style="background-image: url('@(context.User.FindFirst("avatar")?.Value ?? "https://i.pravatar.cc/150")');">
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a href="login" class="text-sm font-bold text-slate-500 hover:text-primary mr-4">Sign In</a>
                    <a href="register" class="flex items-center justify-center rounded-xl h-10 px-5 bg-slate-800 text-white text-sm font-bold hover:bg-slate-700 transition-all">
                        Join Now
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="flex flex-1 overflow-hidden relative">
        @Body
    </main>
</div>

@code {
    [Inject] NavigationManager NavigationManager { get; set; }
}