@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject IJSRuntime JSRuntime

<div class="h-[100dvh] flex flex-col bg-background-light dark:bg-background-dark text-slate-900 dark:text-white font-display overflow-hidden">

    <Header />

    <main class="flex flex-1 overflow-hidden relative">
        @Body
    </main>
</div>

@code {
    [Inject] NavigationManager NavigationManager { get; set; }

    private bool IsDarkMode = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Check current theme from localStorage if possible, or just default
            // Here we assume light, but we could check JS
            var theme = await JSRuntime.InvokeAsync<string>("eval", "localStorage.getItem('theme')");
            if (theme == "dark")
            {
                IsDarkMode = true;
                StateHasChanged();
                // Ensure class is set
                 await JSRuntime.InvokeVoidAsync("uniNestMap.toggleTheme", true);
            }
        }
    }

    private async Task ToggleTheme()
    {
        IsDarkMode = !IsDarkMode;
        await JSRuntime.InvokeVoidAsync("uniNestMap.toggleTheme", IsDarkMode);
    }
}